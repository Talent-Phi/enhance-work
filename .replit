modules = ["nodejs-22", "postgresql-16"]
[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 4321
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js & npm run dev"
waitForPort = 5000

[deployment]
build = ["npm", "run", "build"]
run = ["node", "server.js"]
deploymentTarget = "autoscale"
publicDir = "dist"

[nix]
channel = "stable-25_05"

[userenv]

