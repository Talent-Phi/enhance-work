---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav        from '../components/Nav.astro';
import Hero       from '../sections/Hero.astro';
import Demand     from '../sections/Demand.astro';
import WhyChoose  from '../sections/WhyChoose.astro';
import Gateway    from '../sections/Gateway.astro';
import HowItWorks from '../sections/HowItWorks.astro';
import Roles      from '../sections/Roles.astro';
import CTA        from '../sections/CTA.astro';
import FAQ        from '../sections/FAQ.astro';
import SeoContent from '../sections/SeoContent.astro';
import FinalCTA   from '../sections/FinalCTA.astro';
// import TrustedBy  from '../sections/TrustedBy.astro'; // hidden temporarily
import Footer     from '../sections/Footer.astro';
import ApplyModal from '../components/ApplyModal.astro';
---

<BaseLayout
  title="Aesthetic Medicine Jobs in South Florida | Enhance.work"
  description="Nurse injector, esthetician, laser tech, and medical assistant roles at med spas across Miami-Dade, Broward, and Palm Beach. Free to register. Practices contact you."
  ogImage="/images/og-image.png"
  canonicalUrl="https://enhance.work/"
>
  <Nav />
  <script type="application/ld+json">{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "Enhance.work",
        "url": "https://enhance.work",
        "logo": "https://enhance.work/images/form/enhance-logo.png",
        "sameAs": []
      },
      {
        "@type": "WebSite",
        "name": "Enhance.work",
        "url": "https://enhance.work",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://enhance.work/blog?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is it free for candidates?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, completely free. Practices pay for access to candidates. There is no cost to sign up or be found."
            }
          },
          {
            "@type": "Question",
            "name": "How does it work for candidates?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fill out a short form with your specialty, license type, and experience. You do not get a dashboard of jobs to browse. Practices on Enhance.work find your information and contact you directly when they have an opening that fits."
            }
          },
          {
            "@type": "Question",
            "name": "What roles does Enhance.work cover?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nurse injectors, medical aestheticians, laser technicians, medical assistants, medical directors, medical sales representatives, and medical marketing professionals. Every role is specific to aesthetic medicine."
            }
          },
          {
            "@type": "Question",
            "name": "Do I need to apply for jobs?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Once you register, clinics reach out to you. If your experience matches what a practice is looking for, you will hear from them directly."
            }
          },
          {
            "@type": "Question",
            "name": "What med spa jobs are available near Miami?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Open positions for nurse injectors, estheticians, laser technicians, medical assistants, and support roles at med spas and aesthetic clinics across Miami-Dade, Broward, and Palm Beach are listed on Enhance.work."
            }
          },
          {
            "@type": "Question",
            "name": "Can I find med spa jobs as a registered nurse?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, though Florida law limits injectable procedures to NPs and PAs. RN roles at med spas typically cover patient coordination, IV therapy, and clinical support. All role types are listed on the platform."
            }
          },
          {
            "@type": "Question",
            "name": "What areas does Enhance.work cover?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Miami-Dade, Broward, and Palm Beach counties. Every practice on the platform is in South Florida."
            }
          },
          {
            "@type": "Question",
            "name": "How is this different from Indeed or ZipRecruiter?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Those platforms are built for general job seekers. Aesthetic practices rarely post there because the applicant quality is too broad. Enhance.work is specific to aesthetic medicine, so every candidate and every practice on the platform is in this industry."
            }
          },
          {
            "@type": "Question",
            "name": "How do I become a nurse injector?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You need an active NP or PA license in Florida plus hands-on aesthetic training in neurotoxin and dermal filler. Enhance.work connects licensed NPs and PAs with practices that offer mentorship for candidates transitioning into aesthetic medicine."
            }
          },
          {
            "@type": "Question",
            "name": "How do I get started?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Fill out the registration form. It takes about 2 minutes. Once you are in, South Florida practices can find you and reach out when they are hiring."
            }
          }
        ]
      }
    ]
  }</script>
  <main>
    <Hero />
    <Demand />
    <WhyChoose />
    <Gateway />
    <HowItWorks />
    <Roles />
    <CTA />
    <FAQ />
    <SeoContent />
    <FinalCTA />
    {/* <TrustedBy /> */}
  </main>
  <Footer />
  <ApplyModal />
</BaseLayout>
