---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
---

<BaseLayout
  title="The South Florida Med Spa Directory | Enhance.work"
  description="The complete directory of medical spas in South Florida. Clinics, locations, services, and contacts across Miami-Dade, Broward, and Palm Beach. Instant PDF download."
  canonicalUrl="https://enhance.work/directory"
>
  <Nav />

  <main class="dir-page">

    <!-- Hero -->
    <section class="dir-hero">
      <div class="dir-hero__inner">
        <span class="dir-badge">PDF Instant Download</span>
        <h1 class="dir-hero__title">The South Florida<br /><span class="accent">Med Spa Directory</span></h1>
        <p class="dir-hero__sub">The most complete database of medical spas in Miami-Dade, Broward &amp; Palm Beach — curated for aesthetic professionals.</p>

        <div class="dir-price-block">
          <span class="dir-price">$35</span>
          <span class="dir-price-note">One-time · Instant PDF download</span>
        </div>

        <button class="dir-cta-btn" id="buyBtn">Get Instant Access →</button>
        <p class="dir-guarantee">🔒 Secure checkout via Stripe · Immediate download after payment</p>
      </div>

      <div class="dir-hero__mockup">
        <div class="mockup-card">
          <div class="mockup-header">
            <span class="mockup-dot red"></span>
            <span class="mockup-dot yellow"></span>
            <span class="mockup-dot green"></span>
          </div>
          <div class="mockup-body">
            <div class="mockup-title">South Florida Med Spa Directory</div>
            <div class="mockup-row"><span class="mockup-label">Clinic Name</span><span class="mockup-val">Example Aesthetics</span></div>
            <div class="mockup-row"><span class="mockup-label">City</span><span class="mockup-val">Miami Beach, FL</span></div>
            <div class="mockup-row"><span class="mockup-label">Services</span><span class="mockup-val">Botox, Fillers, Laser</span></div>
            <div class="mockup-row"><span class="mockup-label">Contact</span><span class="mockup-val">••••••••••</span></div>
            <div class="mockup-divider"></div>
            <div class="mockup-row"><span class="mockup-label">Clinic Name</span><span class="mockup-val">Glow Medical Spa</span></div>
            <div class="mockup-row"><span class="mockup-label">City</span><span class="mockup-val">Fort Lauderdale, FL</span></div>
            <div class="mockup-row"><span class="mockup-label">Services</span><span class="mockup-val">PRP, Morpheus8, IV</span></div>
            <div class="mockup-row"><span class="mockup-label">Contact</span><span class="mockup-val">••••••••••</span></div>
            <div class="mockup-divider"></div>
            <div class="mockup-blur-row">+ 200 more clinics inside...</div>
          </div>
        </div>
      </div>
    </section>

    <!-- What's inside -->
    <section class="dir-inside">
      <div class="dir-inside__inner">
        <h2>What's Inside</h2>
        <div class="dir-features">
          <div class="dir-feature">
            <span class="dir-feature__icon">📍</span>
            <h3>200+ Med Spas Listed</h3>
            <p>Every major clinic across Miami-Dade, Broward, and Palm Beach counties.</p>
          </div>
          <div class="dir-feature">
            <span class="dir-feature__icon">📞</span>
            <h3>Direct Contact Info</h3>
            <p>Phone numbers, emails, and websites so you can reach out directly.</p>
          </div>
          <div class="dir-feature">
            <span class="dir-feature__icon">💉</span>
            <h3>Services Offered</h3>
            <p>Know what each clinic offers before you apply — Botox, fillers, laser, body contouring, and more.</p>
          </div>
          <div class="dir-feature">
            <span class="dir-feature__icon">⚡</span>
            <h3>Instant PDF Download</h3>
            <p>Download immediately after payment. No waiting, no shipping. Yours to keep forever.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="dir-for">
      <div class="dir-for__inner">
        <h2>Perfect For</h2>
        <ul class="dir-for__list">
          <li>Nurse injectors looking for their next opportunity</li>
          <li>Estheticians exploring med spa openings in South Florida</li>
          <li>Aesthetic professionals relocating to Miami, Fort Lauderdale, or Boca Raton</li>
          <li>Medical assistants breaking into the aesthetics space</li>
          <li>Practice managers scouting the competition</li>
        </ul>
        <button class="dir-cta-btn" id="buyBtn2">Get Instant Access — $35 →</button>
      </div>
    </section>

    <!-- FAQ -->
    <section class="dir-faq">
      <div class="dir-faq__inner">
        <h2>FAQ</h2>
        <div class="faq-item">
          <h3>How do I receive the directory?</h3>
          <p>Immediately after completing your payment, you'll see a download button on the confirmation page. The PDF is yours to keep.</p>
        </div>
        <div class="faq-item">
          <h3>Is this a subscription?</h3>
          <p>No. This is a one-time payment of $35. No recurring charges.</p>
        </div>
        <div class="faq-item">
          <h3>How current is the data?</h3>
          <p>The directory is regularly updated with new clinics and verified contact information across South Florida.</p>
        </div>
        <div class="faq-item">
          <h3>What format is the file?</h3>
          <p>A clean, easy-to-navigate PDF file that works on any device — phone, tablet, or computer.</p>
        </div>
      </div>
    </section>

  </main>

  <script>
    async function startCheckout() {
      const btn = document.getElementById('buyBtn') || document.getElementById('buyBtn2');
      const allBtns = document.querySelectorAll('.dir-cta-btn');
      allBtns.forEach(b => { b.disabled = true; b.textContent = 'Redirecting to checkout...'; });
      try {
        const res = await fetch('/api/stripe/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({})
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error(data.error || 'Unknown error');
        }
      } catch (err) {
        allBtns.forEach(b => { b.disabled = false; b.textContent = 'Get Instant Access →'; });
        alert('Something went wrong. Please try again.');
        console.error(err);
      }
    }

    document.getElementById('buyBtn')?.addEventListener('click', startCheckout);
    document.getElementById('buyBtn2')?.addEventListener('click', startCheckout);
  </script>

</BaseLayout>

<style>
.dir-page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* Hero */
.dir-hero {
  background: var(--color-bg-dark);
  padding: 7rem 1.5rem 5rem;
  display: flex;
  justify-content: center;
  gap: 4rem;
  align-items: center;
  flex-wrap: wrap;
}
.dir-hero__inner {
  max-width: 540px;
  flex: 1 1 360px;
}
.dir-badge {
  display: inline-block;
  background: var(--color-accent);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.35rem 0.85rem;
  border-radius: 99px;
  margin-bottom: 1.25rem;
}
.dir-hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 1rem;
}
.dir-hero__title .accent { color: var(--color-accent); }
.dir-hero__sub {
  color: rgba(255,255,255,0.72);
  font-size: 1.05rem;
  line-height: 1.65;
  margin-bottom: 2rem;
}
.dir-price-block {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}
.dir-price {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 700;
  color: #fff;
}
.dir-price-note {
  color: rgba(255,255,255,0.55);
  font-size: 0.9rem;
}
.dir-cta-btn {
  display: inline-block;
  background: var(--color-accent);
  color: #fff;
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 600;
  padding: 0.9rem 2.2rem;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  text-decoration: none;
  margin-bottom: 1rem;
}
.dir-cta-btn:hover:not(:disabled) {
  background: var(--color-accent-hover);
  transform: translateY(-1px);
}
.dir-cta-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}
.dir-guarantee {
  color: rgba(255,255,255,0.5);
  font-size: 0.82rem;
  margin-top: 0.25rem;
}

/* Mockup */
.dir-hero__mockup {
  flex: 1 1 320px;
  max-width: 380px;
}
.mockup-card {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.35);
  overflow: hidden;
}
.mockup-header {
  background: #f0f0f0;
  padding: 0.6rem 0.9rem;
  display: flex;
  gap: 0.4rem;
  align-items: center;
}
.mockup-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  display: inline-block;
}
.mockup-dot.red { background: #ff5f57; }
.mockup-dot.yellow { background: #ffbd2e; }
.mockup-dot.green { background: #28ca42; }
.mockup-body { padding: 1.25rem 1.25rem 1rem; }
.mockup-title {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--color-text-heading);
  margin-bottom: 1rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.mockup-row {
  display: flex;
  justify-content: space-between;
  font-size: 0.78rem;
  padding: 0.22rem 0;
  color: var(--color-text-body);
}
.mockup-label { font-weight: 600; color: #888; }
.mockup-val { color: var(--color-text-heading); }
.mockup-divider { border-top: 1px solid #f0f0f0; margin: 0.6rem 0; }
.mockup-blur-row {
  font-size: 0.78rem;
  color: var(--color-accent);
  font-weight: 600;
  text-align: center;
  padding: 0.4rem;
  background: var(--color-accent-light);
  border-radius: 6px;
  margin-top: 0.5rem;
}

/* Inside */
.dir-inside {
  padding: 5rem 1.5rem;
  background: #fff;
}
.dir-inside__inner, .dir-for__inner, .dir-faq__inner {
  max-width: 900px;
  margin: 0 auto;
}
.dir-inside h2, .dir-for h2, .dir-faq h2 {
  font-family: var(--font-heading);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 700;
  color: var(--color-text-heading);
  margin-bottom: 2.5rem;
  text-align: center;
}
.dir-features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2rem;
}
.dir-feature {
  text-align: center;
  padding: 1.5rem 1rem;
  border-radius: 12px;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
}
.dir-feature__icon {
  display: block;
  font-size: 2rem;
  margin-bottom: 0.75rem;
}
.dir-feature h3 {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-heading);
  margin-bottom: 0.5rem;
}
.dir-feature p {
  font-size: 0.9rem;
  color: var(--color-text-body);
  line-height: 1.6;
}

/* For */
.dir-for {
  padding: 5rem 1.5rem;
  background: var(--color-bg-dark);
  text-align: center;
}
.dir-for h2 { color: #fff; }
.dir-for__list {
  list-style: none;
  margin-bottom: 2.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}
.dir-for__list li {
  color: rgba(255,255,255,0.75);
  font-size: 1rem;
  padding-left: 1.5rem;
  position: relative;
}
.dir-for__list li::before {
  content: '✓';
  position: absolute;
  left: 0;
  color: var(--color-accent);
  font-weight: 700;
}

/* FAQ */
.dir-faq {
  padding: 5rem 1.5rem;
  background: #fff;
}
.faq-item {
  border-bottom: 1px solid var(--color-border);
  padding: 1.5rem 0;
}
.faq-item:last-child { border-bottom: none; }
.faq-item h3 {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-heading);
  margin-bottom: 0.5rem;
}
.faq-item p {
  font-size: 0.95rem;
  color: var(--color-text-body);
  line-height: 1.7;
}
</style>
