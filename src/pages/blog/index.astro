---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../sections/Footer.astro';
import { blogPosts } from '../../data/blogPosts';

const posts = blogPosts;
---

<BaseLayout title="Blog — enhance.work" description="Career tips, industry news, and everything you need to succeed in medical aesthetics.">
  <Nav />

  <main class="blog-page">

    <!-- Hero banner -->
    <section class="blog-hero">
      <div class="blog-hero__inner">
        <h1 class="blog-hero__title">Blog <span class="blog-hero__accent">enhance.work</span></h1>
        <p class="blog-hero__sub">Your gateway to a thriving aesthetic career in South Florida</p>
      </div>
    </section>

    <!-- Content -->
    <section class="blog-main">
      <div class="blog-main__inner">

        {posts.length === 0 ? (
          <div class="blog-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="#d0d0d0"/>
            </svg>
            <h2>Coming soon</h2>
            <p>We're working on something great. Check back soon for articles, guides, and career resources.</p>
          </div>
        ) : (
          <>
            <!-- Featured post (first) -->
            <div class="blog-featured-label">
              <h2 class="section-title">Latest blogs</h2>
            </div>
            <a href={`/blog/${posts[0].slug}`} class="blog-featured">
              <div class="blog-featured__img-wrap">
                {posts[0].image
                  ? <img src={posts[0].image} alt={posts[0].title} class="blog-featured__img" loading="eager" />
                  : <div class="blog-featured__img-placeholder" />}
              </div>
              <div class="blog-featured__body">
                <p class="blog-card__date">On {posts[0].date}</p>
                <h3 class="blog-featured__title">{posts[0].title}</h3>
                <p class="blog-featured__excerpt">{posts[0].excerpt}</p>
                <span class="blog-card__read-more">Read more →</span>
              </div>
            </a>

            <!-- All posts grid -->
            <h2 class="section-title section-title--spaced">All posts</h2>
            <div class="blog-grid">
              {posts.map(post => (
                <a href={`/blog/${post.slug}`} class="blog-card">
                  <div class="blog-card__img-wrap">
                    {post.image
                      ? <img src={post.image} alt={post.title} class="blog-card__img" loading="lazy" />
                      : <div class="blog-card__img-placeholder" />}
                  </div>
                  <div class="blog-card__body">
                    <p class="blog-card__date">On {post.date}</p>
                    <h3 class="blog-card__title">{post.title}</h3>
                    <p class="blog-card__excerpt">{post.excerpt}</p>
                  </div>
                </a>
              ))}
            </div>
          </>
        )}
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Base ── */
  .blog-page {
    padding-top: 68px;
    min-height: 100vh;
    background: #f2f2f2;
    font-family: 'Montserrat', 'Poppins', sans-serif;
  }

  /* ── Hero ── */
  .blog-hero {
    background: #1b2936;
    padding: 4rem 2rem 3rem;
  }
  .blog-hero__inner {
    max-width: 1175px;
    margin: 0 auto;
  }
  .blog-hero__title {
    font-family: 'Poppins', sans-serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }
  .blog-hero__accent {
    color: #2bbcb0;
  }
  .blog-hero__sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    margin: 0;
  }

  /* ── Main ── */
  .blog-main {
    padding: 3rem 2rem 5rem;
  }
  .blog-main__inner {
    max-width: 1175px;
    margin: 0 auto;
  }

  /* ── Section titles ── */
  .section-title {
    font-family: 'Poppins', sans-serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: #555252;
    margin: 0 0 1.5rem;
  }
  .section-title--spaced {
    margin-top: 3.5rem;
  }

  /* ── Featured post ── */
  .blog-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    text-decoration: none;
    color: inherit;
    margin-bottom: 1rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .blog-featured:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }
  .blog-featured__img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #e8f8f7;
    min-height: 300px;
  }
  .blog-featured__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .blog-featured:hover .blog-featured__img {
    transform: scale(1.03);
  }
  .blog-featured__img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8f8f7 0%, #d0f0ee 100%);
  }
  .blog-featured__body {
    padding: 2rem 2rem 2rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }
  .blog-featured__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #000;
    line-height: 1.35;
    margin: 0;
  }
  .blog-featured__excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    color: #444;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  /* ── Card ── */
  .blog-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.1);
  }
  .blog-card__img-wrap {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: #e8f8f7;
  }
  .blog-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8f8f7 0%, #d0f0ee 100%);
  }
  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .blog-card:hover .blog-card__img {
    transform: scale(1.04);
  }
  .blog-card__body {
    padding: 1rem 1.25rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .blog-card__date {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #000;
    margin: 0;
  }
  .blog-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #000;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card__excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    color: #333;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card__read-more {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: #2bbcb0;
    margin-top: 0.25rem;
  }

  /* ── Empty ── */
  .blog-empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #999;
  }
  .blog-empty svg { margin-bottom: 1.5rem; }
  .blog-empty h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }
  .blog-empty p {
    font-size: 1rem;
    line-height: 1.6;
    max-width: 420px;
    margin: 0 auto;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .blog-featured { grid-template-columns: 1fr; }
    .blog-featured__body { padding: 1.5rem; }
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .blog-hero { padding: 2.5rem 1.25rem 2rem; }
    .blog-main { padding: 2rem 1.25rem 4rem; }
    .blog-grid { grid-template-columns: 1fr; gap: 1.25rem; }
    .section-title { font-size: 1.75rem; }
  }
</style>
