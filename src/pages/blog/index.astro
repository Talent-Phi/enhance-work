---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../sections/Footer.astro';
import { blogPosts } from '../../data/blogPosts';

const posts = blogPosts;
const featured = posts[0] ?? null;
const rest = posts.slice(1);
---

<BaseLayout title="Blog — enhance.work" description="Career tips, industry news, and everything you need to succeed in medical aesthetics.">
  <Nav />

  <main class="blog-page">

    <!-- Hero -->
    <section class="blog-hero">
      <h1 class="blog-hero__title">Blog</h1>
      <p class="blog-hero__sub">Aesthetic professionals</p>
    </section>

    <div class="blog-main">

      {posts.length === 0 ? (
        <div class="blog-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="#d0d0d0"/>
          </svg>
          <h2>Coming soon</h2>
          <p>We're working on something great. Check back soon for articles, guides, and career resources.</p>
        </div>
      ) : (
        <>
          <!-- Latest blogs: 3-card row -->
          <h2 class="section-label">Latest blogs</h2>
          <div class="blog-grid blog-grid--latest">
            {posts.slice(0, 3).map(post => (
              <a href={`/blog/${post.slug}`} class="blog-card">
                <div class="blog-card__img-wrap">
                  {post.image
                    ? <img src={post.image} alt={post.title} class="blog-card__img" loading="lazy" />
                    : <div class="blog-card__img-placeholder" />}
                </div>
                <div class="blog-card__body">
                  <p class="blog-card__date">On {post.date}</p>
                  <h3 class="blog-card__title">{post.title}</h3>
                  <p class="blog-card__excerpt">{post.excerpt}</p>
                </div>
              </a>
            ))}
          </div>

          <!-- Featured post: large image + text -->
          {featured && (
            <div class="blog-featured-section">
              <a href={`/blog/${featured.slug}`} class="blog-featured">
                <div class="blog-featured__img-wrap">
                  {featured.image
                    ? <img src={featured.image} alt={featured.title} class="blog-featured__img" loading="eager" />
                    : <div class="blog-featured__img-placeholder" />}
                </div>
                <div class="blog-featured__body">
                  <h2 class="blog-featured__title">{featured.title}</h2>
                  <p class="blog-featured__location">South Florida.</p>
                  <p class="blog-featured__excerpt">{featured.excerpt}</p>
                  <a href={`/blog/${featured.slug}`} class="btn-primary blog-featured__cta">Join for free</a>
                </div>
              </a>
            </div>
          )}

          <!-- All posts grid -->
          <h2 class="section-label section-label--spaced">All posts</h2>
          <div class="blog-grid blog-grid--all">
            {posts.map(post => (
              <a href={`/blog/${post.slug}`} class="blog-card">
                <div class="blog-card__img-wrap">
                  {post.image
                    ? <img src={post.image} alt={post.title} class="blog-card__img" loading="lazy" />
                    : <div class="blog-card__img-placeholder" />}
                </div>
                <div class="blog-card__body">
                  <p class="blog-card__date">On {post.date}</p>
                  <h3 class="blog-card__title">{post.title}</h3>
                  <p class="blog-card__excerpt">{post.excerpt}</p>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Base ── */
  .blog-page {
    padding-top: 68px;
    min-height: 100vh;
    background: #fff;
  }

  /* ── Hero ── */
  .blog-hero {
    background: #fff;
    text-align: center;
    padding: 3rem 2rem 1.5rem;
    border-bottom: 1px solid #f0f0f0;
  }
  .blog-hero__title {
    font-family: 'Poppins', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #2bbcb0;
    margin: 0 0 0.25rem;
  }
  .blog-hero__sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    color: #3d3d3d;
    margin: 0;
  }

  /* ── Main container ── */
  .blog-main {
    max-width: 1175px;
    margin: 0 auto;
    padding: 2.5rem 2rem 5rem;
  }

  /* ── Section labels ── */
  .section-label {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #555252;
    margin: 0 0 1.5rem;
  }
  .section-label--spaced {
    margin-top: 3rem;
  }

  /* ── Grid (latest & all) ── */
  .blog-grid {
    display: grid;
    gap: 1.5rem;
  }
  .blog-grid--latest {
    grid-template-columns: repeat(3, 1fr);
    margin-bottom: 2.5rem;
  }
  .blog-grid--all {
    grid-template-columns: repeat(3, 1fr);
  }

  /* ── Card ── */
  .blog-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }
  .blog-card__img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #e8f8f7;
  }
  .blog-card__img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8f8f7 0%, #c8eeeb 100%);
  }
  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .blog-card:hover .blog-card__img { transform: scale(1.04); }
  .blog-card__body {
    padding: 0.75rem 0.25rem 0.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .blog-card__date {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #000;
    margin: 0;
  }
  .blog-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: #000;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card__excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.82rem;
    color: #444;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Featured (A growing demand...) ── */
  .blog-featured-section {
    margin-bottom: 2rem;
  }
  .blog-featured {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2rem;
    text-decoration: none;
    color: inherit;
    align-items: start;
  }
  .blog-featured__img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #e8f8f7;
    border-radius: 6px;
  }
  .blog-featured__img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8f8f7, #c8eeeb);
  }
  .blog-featured__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-featured__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }
  .blog-featured__title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #404040;
    line-height: 1.2;
    margin: 0;
  }
  .blog-featured__location {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #3d3d3d;
    margin: 0;
  }
  .blog-featured__excerpt {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    color: #3d3d3d;
    line-height: 1.7;
    margin: 0;
  }
  .blog-featured__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 2rem;
    border-radius: 53px;
    background: #2bbcb0;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }
  .blog-featured__cta:hover { opacity: 0.88; }

  /* ── Empty ── */
  .blog-empty {
    text-align: center;
    padding: 5rem 1rem;
    color: #999;
  }
  .blog-empty h2 { font-size: 1.5rem; font-weight: 700; color: #1a1a1a; margin: 1rem 0 0.75rem; }
  .blog-empty p { font-size: 1rem; line-height: 1.6; max-width: 420px; margin: 0 auto; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .blog-grid--latest,
    .blog-grid--all { grid-template-columns: repeat(2, 1fr); }
    .blog-featured { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .blog-main { padding: 2rem 1.25rem 4rem; }
    .blog-grid--latest,
    .blog-grid--all { grid-template-columns: 1fr; gap: 1.25rem; }
    .section-label { font-size: 1.6rem; }
  }
</style>
