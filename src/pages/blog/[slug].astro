---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../sections/Footer.astro';
import { blogPosts } from '../../data/blogPosts';

export async function getStaticPaths() {
  return blogPosts.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = blogPosts.find(p => p.slug === slug);

if (!post) {
  return Astro.redirect('/blog');
}

// Auto-generate TOC from <h2> tags in content
const tocItems: { id: string; label: string }[] = [];
let contentWithIds = post.content;
let counter = 1;
const h2Regex = /<h2([^>]*)>([\s\S]*?)<\/h2>/gi;
let match;
const replacements: [string, string][] = [];
while ((match = h2Regex.exec(post.content)) !== null) {
  const label = match[2].replace(/<[^>]+>/g, '').trim();
  const id = `section-${counter++}`;
  tocItems.push({ id, label });
  replacements.push([match[0], `<h2${match[1]} id="${id}">${match[2]}</h2>`]);
}
for (const [orig, rep] of replacements) {
  contentWithIds = contentWithIds.replace(orig, rep);
}
---

<BaseLayout title={`${post.title} — enhance.work Blog`} description={post.excerpt}>
  <Nav />

  <main class="post-page">

    <!-- Hero -->
    <section class="post-hero">
      <div class="post-hero__inner">
        <a href="/blog" class="post-back">← Blog</a>
        <h1 class="post-title">{post.title}</h1>
        {post.subtitle && <p class="post-subtitle">{post.subtitle}</p>}
      </div>
    </section>

    <!-- Author bar -->
    <div class="post-author-bar">
      <div class="post-author-bar__inner">
        <div class="post-author__avatar">
          {post.author.split(' ').map((w: string) => w[0]).join('').slice(0, 2)}
        </div>
        <div class="post-author__info">
          <p class="post-author__name">By {post.author}</p>
          {post.authorCredential && <span class="post-author__cred">{post.authorCredential} ·</span>}
          {post.authorBio && <p class="post-author__bio">{post.authorBio}</p>}
          {post.authorExpertise && post.authorExpertise.length > 0 && (
            <div class="post-author__tags">
              <span class="post-author__exp-label">EXPERTISE:</span>
              {post.authorExpertise.map((tag: string) => <span class="post-author__tag">{tag}</span>)}
            </div>
          )}
        </div>
        <div class="post-author__meta">
          <span>{post.date}</span>
          <span>·</span>
          <span>{post.readTime} read</span>
        </div>
      </div>
    </div>

    <!-- Cover image (full-width below author bar) -->
    {post.image && (
      <div class="post-cover">
        <img src={post.image} alt={post.title} class="post-cover__img" />
      </div>
    )}

    <!-- Three-column layout: TOC | content | share -->
    <div class="post-layout">

      <!-- LEFT: TOC -->
      {tocItems.length > 0 && (
        <aside class="post-toc">
          <p class="post-toc__title">Index</p>
          <nav>
            {tocItems.map((item, i) => (
              <a href={`#${item.id}`} class="post-toc__item">
                <span class="post-toc__num">{i + 1}.</span>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </aside>
      )}
      {tocItems.length === 0 && <div class="post-toc-empty" />}

      <!-- CENTER: Article content -->
      <article class="post-body">
        <div class="post-content" set:html={contentWithIds} />
      </article>

      <!-- RIGHT: Share -->
      <aside class="post-share">
        <span class="post-share__label">SHARE THIS ARTICLE</span>
        <a class="post-share__btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(`https://enhance.work/blog/${post.slug}`)}`} target="_blank" rel="noopener" aria-label="Share on X">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a class="post-share__btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://enhance.work/blog/${post.slug}`)}`} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <button class="post-share__btn" id="copy-link-btn" aria-label="Copy link" title="Copy link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
      </aside>

    </div>

    <!-- Back link -->
    <div class="post-footer-link">
      <a href="/blog" class="post-back">← Back to Blog</a>
    </div>

  </main>

  <Footer />
</BaseLayout>

<script>
  // Copy link
  const btn = document.getElementById('copy-link-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        btn.setAttribute('title', 'Copied!');
        setTimeout(() => btn.setAttribute('title', 'Copy link'), 2000);
      });
    });
  }

  // Active TOC on scroll
  const headings = document.querySelectorAll('.post-content h2[id]');
  const tocLinks = document.querySelectorAll('.post-toc__item');
  if (headings.length && tocLinks.length) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.post-toc__item[href="#${e.target.id}"]`);
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    headings.forEach(h => observer.observe(h));
  }
</script>

<style>
  /* ── Base ── */
  .post-page {
    padding-top: 68px;
    min-height: 100vh;
    background: #f8fafc;
    font-family: 'Inter', sans-serif;
  }

  /* ── Hero ── */
  .post-hero {
    background: #f8fafc;
    padding: 2rem 2rem 1.5rem;
  }
  .post-hero__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .post-back {
    font-size: 0.82rem;
    color: #2bbcb0;
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  .post-back:hover { text-decoration: underline; }
  .post-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 600;
    color: #403e3e;
    line-height: 1.2;
    margin: 0 0 0.5rem;
  }
  .post-subtitle {
    font-size: 1.1rem;
    color: #403e3e;
    margin: 0;
    font-style: italic;
  }

  /* ── Author bar ── */
  .post-author-bar {
    background: #f8fafc;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
    padding: 1rem 2rem;
  }
  .post-author-bar__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .post-author__avatar {
    width: 52px;
    height: 52px;
    min-width: 52px;
    border-radius: 50%;
    background: #2bbcb0;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .post-author__info { flex: 1; }
  .post-author__name {
    font-size: 1rem;
    font-weight: 400;
    color: #403e3e;
    margin: 0 0 0.15rem;
  }
  .post-author__cred {
    font-size: 0.75rem;
    color: #888;
  }
  .post-author__bio {
    font-size: 0.72rem;
    color: #403e3e;
    margin: 0.2rem 0 0;
    line-height: 1.4;
    max-width: 360px;
  }
  .post-author__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    margin-top: 0.3rem;
    font-size: 0.7rem;
  }
  .post-author__exp-label { color: #403e3e; }
  .post-author__tag {
    background: #f0fffe;
    color: #2bbcb0;
    border: 1px solid #c0eeeb;
    border-radius: 20px;
    padding: 0.1rem 0.55rem;
    font-size: 0.68rem;
    font-weight: 600;
  }
  .post-author__meta {
    display: flex;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: #888;
    margin-left: auto;
  }

  /* ── Cover image ── */
  .post-cover {
    max-width: 700px;
    margin: 1.5rem auto 0;
    padding: 0 2rem;
  }
  .post-cover__img {
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }

  /* ── Three-column layout: TOC | content | share ── */
  .post-layout {
    max-width: 1200px;
    margin: 2rem auto 0;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 260px 1fr 48px;
    gap: 2rem;
    align-items: start;
  }
  .post-toc-empty { /* placeholder when no TOC */ }

  /* ── TOC (left) ── */
  .post-toc {
    position: sticky;
    top: 88px;
    background: #f8fafc;
    border-radius: 12px;
    padding: 1.25rem;
    border: 1px solid #eee;
  }
  .post-toc__title {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #2bbcb0;
    margin: 0 0 0.75rem;
  }
  .post-toc__item {
    display: flex;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #323030;
    text-decoration: none;
    padding: 0.3rem 0;
    line-height: 1.35;
    transition: color 0.15s;
  }
  .post-toc__item:hover,
  .post-toc__item.active { color: #2bbcb0; }
  .post-toc__num {
    min-width: 20px;
    color: #999;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Content (center) ── */
  .post-body {
    min-width: 0;
    padding-bottom: 4rem;
  }
  .post-content {
    font-size: 1rem;
    line-height: 1.75;
    color: #403e3e;
  }
  .post-content h2 {
    font-family: 'Inter', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: #323030;
    margin: 2.5rem 0 0.75rem;
    padding-top: 0.5rem;
  }
  .post-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #323030;
    margin: 1.75rem 0 0.5rem;
  }
  .post-content p { margin: 0 0 1.2rem; }
  .post-content ul, .post-content ol {
    margin: 0 0 1.2rem;
    padding-left: 1.5rem;
  }
  .post-content li { margin-bottom: 0.4rem; }
  .post-content strong { color: #323030; font-weight: 600; }
  .post-content a { color: #2bbcb0; }
  .post-content blockquote {
    font-size: 1.25rem;
    font-style: italic;
    color: #403e3e;
    border-left: none;
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: #f8fafc;
    border-radius: 8px;
    border: 1px solid #eee;
    line-height: 1.6;
  }
  .post-content img {
    width: 100%;
    border-radius: 10px;
    margin: 1.5rem 0;
    display: block;
  }
  .post-content hr {
    border: none;
    border-top: 1px solid #eee;
    margin: 2rem 0;
  }

  /* ── Share (right) ── */
  .post-share {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    position: sticky;
    top: 88px;
  }
  .post-share__label {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.65rem;
    font-weight: 400;
    color: #403e3e;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }
  .post-share__btn {
    width: 38px;
    height: 38px;
    background: #f8fafc;
    border: 1px solid #eee;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #403e3e;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    padding: 0;
  }
  .post-share__btn:hover {
    background: #2bbcb0;
    color: #fff;
    border-color: #2bbcb0;
  }

  /* ── Footer link ── */
  .post-footer-link {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 3rem;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .post-layout {
      grid-template-columns: 1fr;
    }
    .post-toc {
      position: static;
      order: -1;
    }
    .post-share {
      flex-direction: row;
      position: static;
      order: -2;
    }
    .post-share__label {
      writing-mode: initial;
      transform: none;
    }
  }
  @media (max-width: 560px) {
    .post-hero { padding: 1.5rem 1.25rem 1rem; }
    .post-author-bar { padding: 1rem 1.25rem; }
    .post-cover { padding: 0 1.25rem; }
    .post-layout { padding: 0 1.25rem; }
    .post-footer-link { padding: 0 1.25rem 2.5rem; }
  }
</style>
