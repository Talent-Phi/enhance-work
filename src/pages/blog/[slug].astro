---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../sections/Footer.astro';
import { getPostBySlug, getAllPublishedPosts } from '../../lib/blogDb';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/blog');
}

// Normalize field names (DB uses snake_case, template uses camelCase)
const postNorm = {
  ...post,
  readTime: post.read_time,
  authorBio: post.author_bio,
  authorCredential: post.author_credential,
  authorExpertise: post.author_expertise ?? [],
};

// Related posts
const allPosts = await getAllPublishedPosts();
const related = allPosts.filter(p => p.slug !== slug).slice(0, 3);

// Auto-generate TOC from <h2> tags in content
const tocItems: { id: string; label: string }[] = [];
let contentWithIds = postNorm.content;
let counter = 1;
const h2Regex = /<h2([^>]*)>([\s\S]*?)<\/h2>/gi;
let match;
const replacements: [string, string][] = [];
while ((match = h2Regex.exec(postNorm.content)) !== null) {
  const label = match[2].replace(/<[^>]+>/g, '').trim();
  const id = `section-${counter++}`;
  tocItems.push({ id, label });
  replacements.push([match[0], `<h2${match[1]} id="${id}">${match[2]}</h2>`]);
}
for (const [orig, rep] of replacements) {
  contentWithIds = contentWithIds.replace(orig, rep);
}

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://enhance.work/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://enhance.work/blog/" },
    { "@type": "ListItem", "position": 3, "name": postNorm.title, "item": `https://enhance.work/blog/${postNorm.slug}` }
  ]
});

const blogPostingSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": postNorm.title,
  "description": postNorm.excerpt,
  "image": postNorm.image ? `https://enhance.work${postNorm.image}` : "https://enhance.work/images/hero-photo.png",
  "datePublished": postNorm.date,
  "author": { "@type": "Person", "name": postNorm.author },
  "publisher": { "@type": "Organization", "name": "Enhance.work", "url": "https://enhance.work" },
  "url": `https://enhance.work/blog/${postNorm.slug}`,
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://enhance.work/blog/${postNorm.slug}` }
});
---

<BaseLayout
  title={postNorm.seo_title || `${postNorm.title} — enhance.work Blog`}
  description={postNorm.seo_description || postNorm.excerpt}
  ogImage={postNorm.seo_og_image || postNorm.image || '/images/hero-photo.png'}
  canonicalUrl={postNorm.canonical_url || `https://enhance.work/blog/${postNorm.slug}`}
  ogType="article"
  publishedTime={postNorm.date}
  author={postNorm.author}
>
  <Nav />
  <script type="application/ld+json" set:html={blogPostingSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <main class="post-page">

    <!-- ── HERO ── -->
    <section class="post-hero">
      <div class="post-hero__inner">
        <!-- Left: title + subtitle + author -->
        <div class="post-hero__text">
          <h1 class="post-title">{postNorm.title}</h1>
          {post.subtitle && <p class="post-subtitle">{postNorm.subtitle}</p>}
        </div>

        <!-- Right: hero image flush to right/bottom -->
        <div class="post-hero__visual">
          {post.image
            ? <img src={postNorm.image} alt={postNorm.title} class="post-hero__img" loading="eager" />
            : <div class="post-hero__img-placeholder" />}
        </div>
      </div>

      <!-- Author strip below the 2-col grid -->
      <div class="post-hero__author-strip">
        <div class="post-author-card">
          <div class="post-author-card__avatar">{postNorm.author.split(' ').map((w: string) => w[0]).join('').slice(0, 2)}</div>
          <div class="post-author-card__body">
            <div class="post-author-card__top">
              <span class="post-author-card__by">By</span>
              <span class="post-author-card__name">{postNorm.author}</span>
              {postNorm.authorCredential && (
                <span class="post-author-card__cred">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="#2bbcb0"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                  {postNorm.authorCredential}
                </span>
              )}
            </div>
            {postNorm.authorBio && <p class="post-author-card__bio">{postNorm.authorBio}</p>}
            {postNorm.authorExpertise && postNorm.authorExpertise.length > 0 && (
              <div class="post-author-card__expertise">
                <span class="post-author-card__expertise-label">EXPERTISE:</span>
                {postNorm.authorExpertise.map((tag: string) => (
                  <span class="post-author-card__tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- ── THREE-COLUMN BODY: TOC | content | share ── -->
    <div class="post-layout">

      <!-- LEFT: TOC -->
      <aside class="post-toc">
        {tocItems.length > 0 && (
          <>
            <p class="post-toc__title">Index</p>
            <nav>
              {tocItems.map((item, i) => (
                <a href={`#${item.id}`} class="post-toc__item">
                  <span class="post-toc__num">{i + 1}.</span>
                  <span>{item.label}</span>
                </a>
              ))}
            </nav>
          </>
        )}
      </aside>

      <!-- CENTER: Article -->
      <article class="post-body">
        <div class="post-content" set:html={contentWithIds} />
      </article>

      <!-- RIGHT: Share (vertical) -->
      <aside class="post-share">
        <span class="post-share__label">SHARE THIS ARTICLE</span>
        <a class="post-share__btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(`https://enhance.work/blog/${postNorm.slug}`)}`} target="_blank" rel="noopener" aria-label="Share on X">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a class="post-share__btn" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://enhance.work/blog/${postNorm.slug}`)}`} target="_blank" rel="noopener" aria-label="Share on LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a class="post-share__btn" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://enhance.work/blog/${postNorm.slug}`)}`} target="_blank" rel="noopener" aria-label="Share on Facebook">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </aside>

    </div>

    <!-- ── CTA BANNER ── -->
    <section class="post-cta">
      <div class="post-cta__inner">
        <div class="post-cta__text">
          <h2>Ready to elevate your career in aesthetic medicine? Apply today and discover the right opportunity for your growth.</h2>
          <a href="/candidate/registration" class="post-cta__btn">Find out</a>
        </div>
        <div class="post-cta__visual">
          <img src="/images/blog/cta-illustration.png" alt="Aesthetic professionals" class="post-cta__img" loading="lazy" onerror="this.style.display='none'" />
        </div>
      </div>
    </section>

    <!-- ── OTHER CONTENT ── -->
    {related.length > 0 && (
      <section class="post-related">
        <div class="post-related__inner">
          <h2 class="post-related__title">Other <span class="post-related__accent">content</span> we recomend</h2>
          <div class="post-related__grid">
            {related.slice(0, 2).map(p => (
              <a href={`/blog/${p.slug}`} class="post-related__card">
                <div class="post-related__img-wrap">
                  {p.image
                    ? <img src={p.image} alt={p.title} class="post-related__img" loading="lazy" />
                    : <div class="post-related__img-placeholder" />}
                </div>
                <div class="post-related__card-body">
                  <p class="post-related__card-date">On {p.date}</p>
                  <h3 class="post-related__card-title">{p.title}</h3>
                  {p.excerpt && <p class="post-related__card-excerpt">{p.excerpt}</p>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>

  <Footer />
</BaseLayout>

<script>
  // Copy link
  const btn = document.getElementById('copy-link-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const original = btn.innerHTML;
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2bbcb0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      });
    });
  }

  // Active TOC on scroll
  const headings = document.querySelectorAll('.post-content h2[id]');
  const tocLinks = document.querySelectorAll('.post-toc__item');
  if (headings.length && tocLinks.length) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.post-toc__item[href="#${e.target.id}"]`);
          if (active) active.classList.add('active');
        }
      });
    }, { rootMargin: '-10% 0px -75% 0px' });
    headings.forEach(h => observer.observe(h));
  }
</script>

<style>
  /* ── Base ── */
  .post-page {
    padding-top: 68px;
    background: #e8eaed;
    font-family: 'Inter', 'Poppins', sans-serif;
  }

  /* ═══════════════════════════════
     HERO
  ═══════════════════════════════ */
  /* ── HERO CARD ── */
  .post-hero {
    background: #fff;
    width: 100%;
    overflow: hidden;
    border-bottom: 1px solid #f0f0f0;
    margin: 0;
  }

  /* 2-col grid: text left, image right */
  .post-hero__inner {
    display: grid;
    grid-template-columns: 1fr 48%;
    align-items: stretch;
    min-height: 420px;
  }
  .post-hero__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
    padding: 2rem 3rem 2rem 20%;
  }
  .post-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #1a1a2e;
    line-height: 1.2;
    margin: 0;
  }
  .post-subtitle {
    font-size: 1rem;
    color: #606060;
    line-height: 1.55;
    margin: 0;
  }

  /* Hero image — flush right, full height */
  .post-hero__visual {
    position: relative;
    overflow: hidden;
  }
  .post-hero__img {
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
    object-position: center top;
    display: block;
    border-radius: 0;
  }
  .post-hero__img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 420px;
    background: #e5e7eb;
  }

  /* Author strip — uses same grid as the hero inner so avatar aligns with title */
  .post-hero__author-strip {
    border-top: 1px solid #f0f0f0;
    display: grid;
    grid-template-columns: 1fr 48%;
  }
  .post-hero__author-strip > .post-author-card {
    padding: 1.25rem 3rem 1.5rem 20%;
  }
  .post-author-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .post-author-card__avatar {
    width: 56px;
    height: 56px;
    min-width: 56px;
    border-radius: 50%;
    background: #2bbcb0;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .post-author-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .post-author-card__top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .post-author-card__by { font-size: 0.78rem; color: #999; }
  .post-author-card__name { font-size: 0.95rem; font-weight: 700; color: #1a1a2e; }
  .post-author-card__cred {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: #555;
  }
  .post-author-card__bio {
    font-size: 0.8rem;
    color: #666;
    line-height: 1.55;
    max-width: 560px;
  }
  .post-author-card__expertise {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.15rem;
  }
  .post-author-card__expertise-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: #999;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-right: 0.2rem;
  }
  .post-author-card__tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: #374151;
    background: transparent;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    padding: 0.15rem 0.55rem;
  }

  /* ═══════════════════════════════
     THREE-COLUMN LAYOUT
  ═══════════════════════════════ */
  .post-layout {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* TOC */
  .post-toc {
    position: sticky;
    top: 84px;
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .post-toc__title {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #2bbcb0;
    margin-bottom: 1rem;
    text-transform: none;
    letter-spacing: 0;
  }
  .post-toc__item {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    padding: 0.45rem 0;
    line-height: 1.4;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .post-toc__item:hover,
  .post-toc__item.active {
    color: #2bbcb0;
    border-left-color: #2bbcb0;
  }
  .post-toc__num {
    min-width: 20px;
    color: #bbb;
    font-weight: 600;
    flex-shrink: 0;
  }

  /* CONTENT */
  .post-body { 
    min-width: 0;
    background: #fff;
    border-radius: 12px;
    padding: 2.5rem 3rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .post-content {
    font-size: 1rem;
    line-height: 1.8;
    color: #333;
  }
  .post-content h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 4rem 0 1.25rem;
    padding-top: 0.5rem;
    border-top: 1px solid #efefef;
  }
  .post-content h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 2.25rem 0 0.75rem;
  }
  .post-content p { margin: 0 0 1.25rem; }
  .post-content ul, .post-content ol {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }
  .post-content li { margin-bottom: 0.6rem; }
  .post-content strong { color: #1a1a1a; font-weight: 600; }
  .post-content a { color: #2bbcb0; text-decoration: underline; text-underline-offset: 2px; }
  .post-content a:hover { color: #1a9f94; }
  .post-content blockquote {
    font-size: 1.2rem;
    font-style: italic;
    color: #333;
    border-left: 4px solid #2bbcb0;
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: #f8fffe;
    border-radius: 0 8px 8px 0;
    line-height: 1.65;
  }
  .post-content img {
    width: 100%;
    border-radius: 10px;
    margin: 1.5rem 0;
    display: block;
  }
  .post-content hr {
    border: none;
    border-top: 1px solid #eee;
    margin: 2rem 0;
  }
  .post-content details {
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
  }
  .post-content details summary {
    cursor: pointer;
    font-weight: 600;
    color: #1a1a1a;
    font-size: 0.95rem;
    list-style: none;
  }
  .post-content details summary::-webkit-details-marker { display: none; }
  .post-content details[open] summary { color: #2bbcb0; }
  .post-content details p { margin: 0.75rem 0 0; font-size: 0.92rem; }

  /* Share sidebar */
  .post-share {
    display: none;
  }

  /* ═══════════════════════════════
     CTA BANNER
  ═══════════════════════════════ */
  .post-cta {
    background: #e8eaed;
    margin: 0;
    padding: 2.5rem 2rem;
  }
  .post-cta__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    align-items: stretch;
    background: #18232c;
    border-radius: 16px;
    overflow: hidden;
    min-height: 180px;
  }
  .post-cta__text {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: 2rem 0 2rem 2.5rem;
  }
  .post-cta__arrow {
    font-size: 1.2rem;
    color: #fff;
    margin: 0;
    line-height: 1;
    position: absolute;
    left: 2.5rem;
    top: 2rem;
  }
  .post-cta__text h2 {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.45;
    margin: 0;
    max-width: 100%;
    padding-left: 2.5rem;
    position: relative;
  }
  .post-cta__text h2::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0;
    font-size: 1.2rem;
  }
  .post-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 2rem;
    background: #2bbcb0;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 50px;
    text-decoration: none;
    align-self: flex-start;
    transition: background 0.2s;
    margin-left: 2.5rem;
  }
  .post-cta__btn:hover { background: #22a89d; }
  .post-cta__visual {
    display: flex;
    align-items: stretch;
    justify-content: center;
    align-self: stretch;
    overflow: hidden;
  }
  .post-cta__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ═══════════════════════════════
     RELATED POSTS
  ═══════════════════════════════ */
  .post-related {
    background: #fff;
    padding: 3rem 2rem 4rem;
  }
  .post-related__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .post-related__title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
  }
  .post-related__accent { color: #2bbcb0; font-weight: 700; }
  .post-related__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .post-related__card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .post-related__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }
  .post-related__img-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #e8f8f7;
    border-radius: 6px;
  }
  .post-related__img-placeholder {
