---
import HospitalIcon from '/icons/hospital.svg?raw';
import PortfolioIcon from '/icons/portfolio.svg?raw';
import CertificateIcon from '/icons/certificate.svg?raw';

const benefits = [
  {
    iconSrc: '/icons/hospital.svg',
    iconAlt: 'Hospital icon',
    title: 'Work with leading aesthetic clinics',
    desc: 'Get matched with top practices in the aesthetic industry across South Florida.',
  },
  {
    iconSrc: '/icons/portfolio.svg',
    iconAlt: 'Portfolio icon',
    title: 'Industry-specific job opportunities',
    desc: 'Access a curated list of jobs that fit your aesthetic skills and experience level.',
  },
  {
    iconSrc: '/icons/certificate.svg',
    iconAlt: 'Certificate icon',
    title: 'Build your professional reputation',
    desc: 'Highlight certifications, get endorsements, and improve your profile visibility.',
  },
];
---

<section class="why" id="why-join">
  <div class="container">
    <div class="why__header">
      <span class="label">Why professionals join</span>
      <h2 class="h2">Built for your career<br />in aesthetics</h2>
    </div>

    <div class="why__grid">
      {benefits.map((b) => (
        <div class="why__card">
          <div class="why__icon-wrap">
            <img src={b.iconSrc} alt={b.iconAlt} width="44" height="44" />
          </div>
          <h3 class="h3">{b.title}</h3>
          <p>{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why {
    padding: var(--section-padding);
    background: var(--color-card-bg);
  }

  .why__header {
    max-width: 520px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .why__card {
    background: #fbf9fd;
    border-radius: 15px;
    padding: 2.25rem 2rem 2rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    cursor: pointer;

    /* Transition for hover animation */
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.28s ease,
      background 0.28s ease;
    will-change: transform;
  }

  .why__card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 20px 40px rgba(107, 92, 231, 0.18), 0 6px 16px rgba(0, 0, 0, 0.1);
    background: #ffffff;
  }

  .why__card:hover .why__icon-wrap {
    background: #d8d3ff;
    transform: scale(1.1) rotate(-4deg);
  }

  .why__icon-wrap {
    width: 68px;
    height: 68px;
    background: #e9e6ff;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.28s ease, transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .why__icon-wrap img {
    width: 44px;
    height: 44px;
    object-fit: contain;
  }

  .why__card .h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .why__card p {
    color: var(--color-text-secondary);
    font-size: .95rem;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .why__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 560px) {
    .why__grid { grid-template-columns: 1fr; }
  }
</style>
