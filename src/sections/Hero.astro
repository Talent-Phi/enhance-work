---
import StatCard from '../components/StatCard.astro';
---

<section class="hero" id="hero">

  <!-- Main hero grid -->
  <div class="hero__inner">

    <!-- LEFT: text content -->
    <div class="hero__left">

      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        Now live — 1,200+ professionals in South Florida
      </div>

      <h1 class="hero__headline">
        The platform built for <em>your aesthetic career in</em> South Florida
      </h1>

      <p class="hero__body">
        Whether you're an experienced injector or just starting out, Enhance
        connects you with top aesthetic clinics across Miami, Doral, and
        surrounding areas. Create your profile, get discovered, and apply to
        real opportunities near you.
      </p>

      <!-- Social proof row -->
      <div class="hero__social">
        <div class="hero__avatars">
          <span class="hero__av" style="background:#6bbdb6">KL</span>
          <span class="hero__av" style="background:#9b8ec4">MR</span>
          <span class="hero__av" style="background:#5bb5a2">SN</span>
          <span class="hero__av" style="background:#7BAFD4">TP</span>
        </div>
        <div class="hero__social-text">
          <strong>Join 1,200+ professionals</strong>
          <span>already building their career on Enhance</span>
        </div>
      </div>

      <!-- CTAs — side by side -->
      <div class="hero__actions">
        <a href="#apply" class="btn btn-primary">Create your profile</a>
        <a href="#roles" class="btn btn-secondary">Browse opportunities</a>
      </div>

    </div>

    <!-- RIGHT: composite mockup (photo + New profiles card + Top hiring areas card) -->
    <div class="hero__right">
      <img
        src="/images/mockups/hero-right-mockup.png"
        alt="Aesthetic professional — top hiring areas in South Florida"
        class="hero__mockup"
      />
    </div>
  </div>

  <!-- Stats band below hero -->
  <div class="hero__stats-band">
    <StatCard value="1.2k" suffix="+" label="Active professionals" />
    <div class="hero__divider"></div>
    <StatCard value="318"  suffix="+" label="Partner clinics" />
    <div class="hero__divider"></div>
    <StatCard value="94%"  suffix="+" label="Match satisfaction" />
  </div>

</section>

<style>
  .hero {
    background: #d9d9d9;
    padding-top: 68px;
    position: relative;
    overflow: hidden;   /* clip ::before/::after pseudo-elements (prevent horizontal scroll) */
  }

  /* Dot grid texture from Figma EFM-1410 2 (PATTERN fill) */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/images/hero-texture.png') repeat center center;
    background-size: 300px auto;
    opacity: 0.09;   /* subtle but visible like in the frame */
    pointer-events: none;
    z-index: 0;
  }

  /* Curved separator — very subtle concave arc at hero bottom (Frame 3544) */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120%;
    height: 40px;
    background: #ebebeb;   /* slightly lighter than hero #d9d9d9 — matches stats area tone */
    border-radius: 50% 50% 0 0 / 40px 40px 0 0;
    z-index: 2;
  }

  /* ── Main layout: 2 cols, left 52% right 48% ── */
  .hero__inner, .hero__stats-band {
    position: relative;
    z-index: 1;
  }

  .hero__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 80px 3rem 141px;
    display: grid;
    grid-template-columns: 520px 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 76vh;
  }

  /* ── LEFT ── */
  .hero__left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: .82rem;
    font-weight: 500;
    padding: .45rem 1rem;
    border-radius: 100px;
    width: fit-content;
  }

  .hero__badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .hero__headline {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.6vw, 3.1rem);
    font-weight: 600;
    color: #3a3a3a;
    line-height: 1.15;
    margin: 0;
  }

  /* Only "your aesthetic career" in teal italic */
  .hero__headline em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: #606362;
    margin: 0;
  }

  /* Social proof */
  .hero__social {
    display: flex;
    align-items: center;
    gap: .85rem;
  }

  .hero__avatars {
    display: flex;
    flex-shrink: 0;
  }

  .hero__av {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .6rem;
    font-weight: 700;
    color: #fff;
    font-family: var(--font-heading);
    margin-left: -9px;
    flex-shrink: 0;
  }

  .hero__avatars .hero__av:first-child { margin-left: 0; }

  .hero__social-text {
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    font-size: .85rem;
    color: #606362;
    line-height: 1.4;
  }

  .hero__social-text strong {
    color: #333;
    font-weight: 600;
  }

  /* Buttons — horizontal row */
  .hero__actions {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: center;
    flex-wrap: nowrap;
  }

  /* ── RIGHT ── */
  .hero__right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 20px;
  }

  /* Single composite mockup PNG (photo + New profiles card + Top hiring areas card) */
  .hero__mockup {
    width: 100%;
    max-width: 580px;
    height: auto;
    display: block;
  }

  /* ── STATS BAND ── */
  .hero__stats-band {
    background: #f2f2f2;
    padding: 2rem 141px 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3.5rem;
    position: relative;
    z-index: 3;   /* above hero ::after curve, no gap */
    margin-top: -2px;
  }

  .hero__divider {
    width: 1px;
    height: 52px;
    background: rgba(0,0,0,0.12);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1280px) {
    .hero__inner {
      grid-template-columns: 480px 1fr;
      padding: 3.5rem 60px 2.5rem 80px;
      gap: 3rem;
    }
    .hero__stats-band { padding: 2rem 80px; }
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .hero__inner { grid-template-columns: 480px 1fr; padding: 3.5rem 60px 2.5rem 80px; gap: 3rem; }
    .hero__stats-band { padding: 2rem 80px; }
  }

  /* Mobile: single column, show hero right below text */
  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; padding: 2rem 1.5rem 1rem; gap: 1.5rem; min-height: auto; }
    .hero__right { display: flex; justify-content: center; padding-right: 0; }
    .hero__mockup { max-width: 100%; }
    .hero__headline { font-size: 2rem; }
    .hero__actions { flex-wrap: wrap; }
    .hero__stats-band { padding: 1.5rem 1.5rem; gap: 2rem; }
    .hero__divider { display: none; }
  }
</style>
