---
import StatCard from '../components/StatCard.astro';
---

<section class="hero" id="hero">

  <!-- Main hero grid -->
  <div class="hero__inner">

    <!-- LEFT: text content -->
    <div class="hero__left">

      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        Now live — 1,200+ professionals in South Florida
      </div>

      <h1 class="hero__headline">
        The platform built for <em>your aesthetic career</em> in South Florida
      </h1>

      <p class="hero__body">
        Whether you're an experienced injector or just starting out, Enhance
        connects you with top aesthetic clinics across Miami, Doral, and
        surrounding areas. Create your profile, get discovered, and apply to
        real opportunities near you.
      </p>

      <!-- Social proof row -->
      <div class="hero__social">
        <div class="hero__avatars">
          <span class="hero__av" style="background:#6bbdb6">KL</span>
          <span class="hero__av" style="background:#9b8ec4">MR</span>
          <span class="hero__av" style="background:#5bb5a2">SN</span>
          <span class="hero__av" style="background:#7BAFD4">TP</span>
        </div>
        <div class="hero__social-text">
          <strong>Join 1,200+ professionals</strong>
          <span>already building their career on Enhance</span>
        </div>
      </div>

      <!-- CTAs — side by side -->
      <div class="hero__actions">
        <a href="#apply" class="btn btn-primary">Create your profile</a>
        <a href="#roles" class="btn btn-secondary">Browse opportunities</a>
      </div>

    </div>

    <!-- RIGHT: photo + floating cards -->
    <div class="hero__right">

      <!-- "New profiles" floating card — top left -->
      <div class="hero__float hero__float--profiles">
        <div class="hero__profiles-card">
          <span class="hero__profiles-label">New profiles</span>
          <span class="hero__profiles-value">847</span>
          <span class="hero__profiles-delta">↑ +12%</span>
        </div>
      </div>

      <!-- Main photo -->
      <div class="hero__photo-card">
        <img
          src="/images/hero-photo.png"
          alt="Aesthetic professional"
          class="hero__photo"
        />
      </div>

      <!-- "Top hiring areas" floating card — bottom right -->
      <div class="hero__float hero__float--hiring">
        <img
          src="/images/hero-top-hiring.png"
          alt="Top hiring areas in South Florida"
          class="hero__float-img"
        />
      </div>

    </div>
  </div>

  <!-- Stats band below hero -->
  <div class="hero__stats-band">
    <StatCard value="1.2k" suffix="+" label="Active professionals" />
    <div class="hero__divider"></div>
    <StatCard value="318"  suffix="+" label="Partner clinics" />
    <div class="hero__divider"></div>
    <StatCard value="94%"  suffix="+" label="Match satisfaction" />
  </div>

</section>

<style>
  .hero {
    background: var(--color-bg);
    padding-top: 68px;
  }

  /* ── Main layout: 2 cols, left 52% right 48% ── */
  .hero__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 80px 3rem 141px;
    display: grid;
    grid-template-columns: 520px 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 76vh;
  }

  /* ── LEFT ── */
  .hero__left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: .82rem;
    font-weight: 500;
    padding: .45rem 1rem;
    border-radius: 100px;
    width: fit-content;
  }

  .hero__badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .hero__headline {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.6vw, 3.1rem);
    font-weight: 600;
    color: #3a3a3a;
    line-height: 1.15;
    margin: 0;
  }

  /* Only "your aesthetic career" in teal italic */
  .hero__headline em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: #606362;
    margin: 0;
  }

  /* Social proof */
  .hero__social {
    display: flex;
    align-items: center;
    gap: .85rem;
  }

  .hero__avatars {
    display: flex;
    flex-shrink: 0;
  }

  .hero__av {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .6rem;
    font-weight: 700;
    color: #fff;
    font-family: var(--font-heading);
    margin-left: -9px;
    flex-shrink: 0;
  }

  .hero__avatars .hero__av:first-child { margin-left: 0; }

  .hero__social-text {
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    font-size: .85rem;
    color: #606362;
    line-height: 1.4;
  }

  .hero__social-text strong {
    color: #333;
    font-weight: 600;
  }

  /* Buttons — horizontal row */
  .hero__actions {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: center;
    flex-wrap: nowrap;
  }

  /* ── RIGHT ── */
  .hero__right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: 480px;
  }

  /* Main photo card */
  .hero__photo-card {
    width: 100%;
    max-width: 540px;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 24px 70px rgba(0,0,0,0.10);
    position: relative;
    z-index: 1;
  }

  .hero__photo {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Floating cards ── */
  .hero__float {
    position: absolute;
    z-index: 2;
  }

  /* "New profiles" — top left, partially above photo */
  .hero__float--profiles {
    top: 20px;
    left: -30px;
  }

  /* Inline card (built in HTML so we can show real values) */
  .hero__profiles-card {
    background: #fff;
    border-radius: 14px;
    padding: .85rem 1.1rem;
    box-shadow: 0 8px 24px rgba(0,0,0,0.10);
    display: flex;
    flex-direction: column;
    gap: .15rem;
    min-width: 140px;
  }

  .hero__profiles-label {
    font-family: var(--font-body);
    font-size: .72rem;
    color: #888;
    font-weight: 500;
    letter-spacing: .02em;
  }

  .hero__profiles-value {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.1;
  }

  .hero__profiles-delta {
    font-family: var(--font-body);
    font-size: .78rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* "Top hiring areas" — bottom right */
  .hero__float--hiring {
    bottom: 10px;
    right: -15px;
  }

  .hero__float-img {
    display: block;
    width: 260px;
    border-radius: 16px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.10);
  }

  /* ── STATS BAND ── */
  .hero__stats-band {
    max-width: 1440px;
    margin: 0 auto;
    padding: 2.5rem 141px;
    border-top: 1px solid rgba(0,0,0,0.09);
    display: flex;
    align-items: center;
    gap: 3.5rem;
  }

  .hero__divider {
    width: 1px;
    height: 52px;
    background: rgba(0,0,0,0.12);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1280px) {
    .hero__inner {
      grid-template-columns: 480px 1fr;
      padding: 3.5rem 60px 2.5rem 80px;
      gap: 3rem;
    }
    .hero__stats-band { padding: 2rem 80px; }
  }

  @media (max-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding: 3rem 2rem 2rem;
      min-height: auto;
    }
    .hero__right { display: none; }
    .hero__stats-band { padding: 2rem 2rem; gap: 2rem; }
  }

  @media (max-width: 600px) {
    .hero__actions { flex-wrap: wrap; }
    .hero__stats-band { gap: 1.25rem; }
    .hero__divider { display: none; }
  }
</style>
