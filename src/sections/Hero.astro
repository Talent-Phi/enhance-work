---
import StatCard from '../components/StatCard.astro';
---

<section class="hero" id="hero">
  <!-- decorative blobs -->
  <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--2" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <span class="badge">Now live — 1,200+ professionals in South Florida</span>

      <h1 class="h1 hero__headline">
        The platform built for your aesthetic career
        <span class="hero__headline-accent"> in South Florida</span>
      </h1>

      <p class="hero__sub">
        Enhance.work is a hiring platform built specifically for aesthetic professionals.
        Get matched with top clinics, build your reputation, and grow your career.
      </p>

      <div class="hero__actions">
        <a href="#apply" class="btn btn-primary">Create your profile</a>
        <a href="#roles" class="btn btn-secondary">Browse opportunities</a>
      </div>

      <div class="hero__stats">
        <StatCard value="1.2k" suffix="+" label="Active professionals" />
        <div class="hero__stats-divider" aria-hidden="true"></div>
        <StatCard value="318" suffix="+" label="Partner clinics" />
        <div class="hero__stats-divider" aria-hidden="true"></div>
        <StatCard value="94%" suffix="+" label="Match satisfaction" />
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__img-wrap">
        <!-- Placeholder — replace with actual hero image from Figma export -->
        <div class="hero__img-placeholder">
          <span>Aesthetic professional</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 4rem 1.5rem 6rem;
  }

  /* Decorative blobs */
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: .18;
    pointer-events: none;
    z-index: 0;
  }
  .hero__blob--1 {
    width: 500px; height: 500px;
    background: var(--color-accent);
    top: -120px; right: -80px;
  }
  .hero__blob--2 {
    width: 350px; height: 350px;
    background: #b2f5f0;
    bottom: 0; left: -60px;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__headline {
    margin-top: .25rem;
  }

  .hero__headline-accent { color: var(--color-accent); }

  .hero__sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: flex-start;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    margin-top: .5rem;
  }

  .hero__stats-divider {
    width: 1px;
    height: 60px;
    background: var(--color-border);
    align-self: center;
  }

  /* Visual */
  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__img-wrap {
    width: 100%;
    max-width: 520px;
    aspect-ratio: 4/5;
    border-radius: 24px;
    overflow: hidden;
    background: var(--color-accent-light);
  }

  .hero__img-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .85rem;
    color: var(--color-text-muted);
    border: 2px dashed var(--color-border);
    border-radius: 24px;
  }

  @media (max-width: 900px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__visual { display: none; }
    .hero__stats-divider { display: none; }
  }
</style>
