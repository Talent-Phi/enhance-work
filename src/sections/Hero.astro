---
import StatCard from '../components/StatCard.astro';
---

<section class="hero" id="hero">

  <!-- Main hero grid -->
  <div class="hero__inner">

    <!-- LEFT: text content -->
    <div class="hero__left">

      <!-- Active professionals badge (randomized 5-15, updates every 30s) -->
      <div class="hero__badge" id="hero-active-badge">
        <span class="hero__badge-dot hero__active-dot"></span>
        <span class="hero__badge-count"><u><span id="hero-active-count">8</span> professionals</u></span>
        <span class="hero__badge-rest">live right now</span>
      </div>

      <h1 class="hero__headline">
        Jobs in <em>Aesthetics</em><br>for South Florida.
      </h1>

      <p class="hero__body">
        Your skills deserve the right clinic. Find serious opportunities in
        medical aesthetics, curated by people who know the industry.
      </p>

      <!-- Social proof row -->
      <div class="hero__social">
        <div class="hero__avatars">
          <span class="hero__av" style="background:#6bbdb6">KL</span>
          <span class="hero__av" style="background:#9b8ec4">MR</span>
          <span class="hero__av" style="background:#5bb5a2">SN</span>
          <span class="hero__av" style="background:#7BAFD4">TP</span>
        </div>
        <div class="hero__social-text">
          <strong>Join 2,500+ aesthetic professionals</strong>
        </div>
      </div>

      <!-- CTA — single pill button -->
      <div class="hero__actions">
        <a href="/candidate/registration/" class="btn btn-primary hero__join-btn">Join for free</a>
      </div>

      <!-- Trust signal below button (Frame 3930) -->
      <div class="hero__trust">
        <span class="hero__trust-check">✓</span>
        <span>Professionals in aesthetics only</span>
      </div>

    </div>

    <!-- RIGHT: photo (Figma 825:3437) + Top hiring areas card (Figma 825:3666 / group 3118) -->
    <div class="hero__right">
      <div class="hero__mockup-wrap">
        <img
          src="/images/hero-professional.png"
          alt="Aesthetic professional performing treatment"
          class="hero__mockup"
        />
        <!-- Top hiring areas card — direct Figma export (node 1027:1786) -->
        <img
          src="/images/hero/top-hiring-card.png"
          alt="Top hiring areas — Coral Gables, Miramar, Aventura, Boca Raton"
          class="hero__hiring-card"
        />
      </div>
    </div>
  </div>

  <!-- Stats band below hero -->
  <div class="hero__stats-band">
    <div class="hero__stats-row">
      <StatCard value="1.2k" suffix="+" label="Aesthetic practices" />
      <div class="hero__divider"></div>
      <StatCard value="308" suffix="+" label="Practices hiring" />
      <div class="hero__divider"></div>
      <StatCard value="100" suffix="%" label="South FL focused" />
    </div>
    <p class="hero__tagline">#1 <em><u>aesthetic job platform</u></em> in South Florida</p>
  </div>

</section>

<style>
  .hero {
    background-color: #e0e0e0;
    background-image: radial-gradient(circle, #c8c8c8 1px, transparent 1px);
    background-size: 20px 20px;
    padding-top: 0;   /* nav is transparent overlay — hero bg extends behind it */
    position: relative;
    overflow: hidden;
  }

  /* no extra pseudo-element texture needed — bg handles it */
  .hero::before {
    display: none;
  }

  /* Curved separator — very subtle concave arc at hero bottom (Frame 3544) */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120%;
    height: 40px;
    background: #ebebeb;   /* slightly lighter than hero #d9d9d9 — matches stats area tone */
    border-radius: 50% 50% 0 0 / 40px 40px 0 0;
    z-index: 2;
  }

  /* ── Main layout: 2 cols, left 52% right 48% ── */
  .hero__inner, .hero__stats-band {
    position: relative;
    z-index: 1;
  }

  .hero__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: calc(68px + 3rem) 80px 3rem 141px;
    display: grid;
    grid-template-columns: 520px 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 76vh;
  }

  /* ── LEFT ── */
  .hero__left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: .82rem;
    font-weight: 500;
    padding: .45rem 1rem;
    border-radius: 100px;
    width: fit-content;
  }

  .hero__badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  /* Active professionals badge */
  .hero__active-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(43,188,176,0.1);
    border: 1px solid rgba(43,188,176,0.3);
    border-radius: 100px;
    padding: 0.3rem 0.85rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: #0f6b65;
    width: fit-content;
  }
  .hero__active-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #2bbcb0;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .hero__headline {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.6vw, 3.1rem);
    font-weight: 600;
    color: #3a3a3a;
    line-height: 1.15;
    margin: 0;
  }

  /* "Aesthetics" — teal italic */
  .hero__headline em {
    font-style: italic;
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: #606362;
    margin: 0;
  }

  /* Social proof */
  .hero__social {
    display: flex;
    align-items: center;
    gap: .85rem;
  }

  .hero__avatars {
    display: flex;
    flex-shrink: 0;
  }

  .hero__av {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .6rem;
    font-weight: 700;
    color: #fff;
    font-family: var(--font-heading);
    margin-left: -9px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .hero__av {
      margin-left: -14px;
    }
  }

  .hero__avatars .hero__av:first-child { margin-left: 0; }

  .hero__social-text {
    display: flex;
    flex-direction: column;
    font-family: var(--font-body);
    font-size: .85rem;
    color: #606362;
    line-height: 1.4;
  }

  .hero__social-text strong {
    color: #333;
    font-weight: 600;
  }

  /* Buttons — horizontal row */
  .hero__actions {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: center;
    flex-wrap: nowrap;
  }

  /* Badge count — larger, semibold, teal */
  .hero__badge-count {
    font-size: .95rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .hero__badge-count u {
    text-underline-offset: 2px;
  }

  .hero__badge-rest {
    font-size: .82rem;
    font-weight: 400;
    color: #555;
  }

  /* Trust signal */
  .hero__trust {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-family: var(--font-body);
    font-size: .88rem;
    font-weight: 600;
    color: #333;
  }

  .hero__trust-check {
    color: var(--color-accent);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
  }

  .hero__join-btn {
    padding: 1rem 3rem;
    font-size: 1.1rem;
    border-radius: 100px;
    width: 100%;
    max-width: 320px;
  }

  @media (max-width: 768px) {
    .hero__join-btn {
      max-width: 100%;
    }
  }

  /* ── RIGHT ── */
  .hero__right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 20px;
  }

  /* Mockup wrap — positions cards over the composite photo */
  .hero__mockup-wrap {
    position: relative;
    display: block;
    width: 100%;
    max-width: 580px;
    /* Space for the card that overhangs the photo bottom */
    padding-bottom: 8%;
  }
  .hero__mockup {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 20px;
  }
  /* Top hiring areas card — Figma PNG export */
  .hero__hiring-card {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 88%;
    height: auto;
    display: block;
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.14);
  }

  .hiring__left {
    flex: 1;
    padding: 16px 14px 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hiring__title {
    font-family: var(--font-heading);
    font-size: .88rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
  }

  .hiring__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .hiring__list li {
    font-family: var(--font-body);
    font-size: .78rem;
    color: #333;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .hiring__num {
    color: var(--color-accent);
    font-weight: 700;
    min-width: 18px;
  }

  .hiring__map {
    width: 46%;
    flex-shrink: 0;
    overflow: hidden;
  }

  .hiring__map img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 20% center;
    display: block;
  }

  /* ── STATS BAND ── */
  .hero__stats-band {
    background: #f2f2f2;
    padding: 2.5rem 141px 2.5rem 141px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 3;
    margin-top: -2px;
  }

  .hero__stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3.5rem;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    color: #444;
    margin: 0;
    font-style: italic;
  }

  .hero__tagline u {
    text-underline-offset: 2px;
  }

  .hero__divider {
    width: 1px;
    height: 52px;
    background: rgba(0,0,0,0.12);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1280px) {
    .hero__inner {
      grid-template-columns: 480px 1fr;
      padding: 3.5rem 60px 2.5rem 80px;
      gap: 3rem;
    }
    .hero__stats-band { padding: 2rem 80px; }
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .hero__inner { grid-template-columns: 480px 1fr; padding: calc(68px + 2.5rem) 60px 2.5rem 80px; gap: 3rem; }
    .hero__stats-band { padding: 2rem 80px; }
  }

  /* Mobile: single column, show hero right below text */
  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; padding: calc(68px + 1.5rem) 1.5rem 1rem; gap: 1.5rem; min-height: auto; }
    .hero__right { display: flex; justify-content: center; padding-right: 0; }
    .hero__mockup { max-width: 100%; }
    .hero__headline { font-size: 2rem; }
    .hero__actions { flex-wrap: wrap; }
    .hero__stats-band {
      padding: 1.25rem 1rem;
      gap: 0;
      justify-content: space-around;
    }
    .hero__divider { display: none; }
  }

  /* Small mobile — reduce stat number size */
  @media (max-width: 480px) {
    :global(.stat__value) {
      font-size: 2.2rem !important;
    }
    :global(.stat__label) {
      font-size: 0.75rem !important;
    }
  }
</style>

<script>
  function randomActive() {
    return Math.floor(Math.random() * 11) + 5; // 5–15
  }
  const countEl = document.getElementById('hero-active-count');
  if (countEl) {
    countEl.textContent = randomActive();
    setInterval(() => {
      if (countEl) countEl.textContent = randomActive();
    }, 30000);
  }
</script>
