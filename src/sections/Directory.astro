---
// Directory.astro — South Florida Med Spa Directory CTA section
---

<section class="directory" id="directory">
  <div class="directory__container">
    
    <!-- Title — always first (desktop: left-top, mobile: top) -->
    <div class="directory__title-area">
      <h2 class="directory__title">
        Get instant access to<br />
        every <span class="directory__highlight">aesthetic practice<br />in South Florida</span>.
      </h2>
    </div>
    
    <!-- Mockup — desktop: right column spanning both rows, mobile: second -->
    <div class="directory__mockup">
      <div class="directory__pages-stack">
        <!-- Page 3: Back page (clinic listing) -->
        <div class="directory__page directory__page--3">
          <img 
            src="/images/mockups/access-to-manual/directory-page-listing.png" 
            alt="Clinic listing page"
            loading="lazy"
          />
        </div>
        
        <!-- Page 2: Middle page (index) -->
        <div class="directory__page directory__page--2">
          <img 
            src="/images/mockups/access-to-manual/directory-page-index.png" 
            alt="Directory index page"
            loading="lazy"
          />
        </div>
        
        <!-- Page 1: Front cover -->
        <div class="directory__page directory__page--1">
          <img 
            src="/images/mockups/access-to-manual/directory-cover.png" 
            alt="Everything You Need to Know about every aesthetic practice in South Florida"
            loading="lazy"
          />
        </div>
      </div>
      
      <!-- Label below stack -->
      <div class="directory__mockup-label">
        <span>The South Florida Med Spa Directory</span>
      </div>
    </div>
    
    <!-- Content — desktop: left-bottom, mobile: third -->
    <div class="directory__content">
      <p class="directory__subtitle">Stop guessing and start applying smarter.</p>
      
      <ul class="directory__benefits">
        <li class="directory__benefit">
          <svg class="directory__check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>7,000+ aesthetic clinics</span>
        </li>
        <li class="directory__benefit">
          <svg class="directory__check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Contact info & hiring insights</span>
        </li>
        <li class="directory__benefit">
          <svg class="directory__check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Services, specialties, and reputation</span>
        </li>
        <li class="directory__benefit">
          <svg class="directory__check" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Where and how to apply</span>
        </li>
      </ul>
      
      <div class="directory__pricing">
        <p class="directory__pricing-label">LIMITED ACCESS</p>
        <div class="directory__price-row">
          <span class="directory__price-old">$50</span>
          <span class="directory__price-current">$35</span>
        </div>
      </div>
      
      <button type="button" class="directory__cta" id="directoryCta"><span>GET INSTANT ACCESS</span></button>
      
      <p class="directory__fine-print">Instant download • One-time payment • No subscription</p>
    </div>
    
  </div>
</section>

<script>
  // Checkout button
  const dirCta = document.getElementById('directoryCta');
  if (dirCta) {
    dirCta.addEventListener('click', async () => {
      const btn = dirCta;
      const span = btn.querySelector('span');
      btn.disabled = true;
      if (span) span.textContent = 'Redirecting...';
      try {
        const res = await fetch('/api/stripe/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({})
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error(data.error || 'Unknown error');
        }
      } catch (err) {
        btn.disabled = false;
        if (span) span.textContent = 'GET INSTANT ACCESS';
        alert('Something went wrong. Please try again.');
        console.error(err);
      }
    });
  }

  // Auto-rotate pages animation — cover (page--1) always starts in front
  const pages = Array.from(document.querySelectorAll('.directory__page'));
  const totalPages = pages.length;
  const rotationInterval = 3500;

  // pages NodeList order: [page--3 (listing), page--2 (index), page--1 (cover)]
  // We want cover first, so start at index 2
  let currentPage = totalPages - 1; // points to page--1 (cover)

  function rotatePage() {
    pages.forEach(p => p.classList.remove('active'));
    pages[currentPage].classList.add('active');
    currentPage = (currentPage + 1) % totalPages;
  }

  // Show cover immediately, then rotate
  rotatePage();
  setInterval(rotatePage, rotationInterval);
</script>

<style>
  .directory {
    padding: 6rem 1.5rem;
    background-image: url('/images/mockups/access-to-manual/BG%20Enhance.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    overflow: clip;
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
  }
  
  .directory::before {
    content: '';
    position: absolute;
    top: 65%;
    left: 21%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(43,188,176,0.3) 0%, rgba(43,188,176,0.15) 40%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    animation: float 8s ease-in-out infinite;
    transform: translate(-50%, -50%);
    z-index: 0;
  }
  
  @keyframes float {
    0%, 100% { transform: translate(-50%, -50%) translateY(0px); opacity: 0.6; }
    50%       { transform: translate(-50%, -50%) translateY(-20px); opacity: 0.8; }
  }
  
  /* Desktop: 2-col grid — title+content left, mockup right spanning both rows */
  .directory__container {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "title   mockup"
      "content mockup";
    grid-template-rows: auto 1fr;
    gap: 1.5rem 2rem;
    position: relative;
    z-index: 2;
  }

  .directory__title-area {
    grid-area: title;
    animation: slideInLeft 0.8s ease-out;
  }

  .directory__mockup {
    grid-area: mockup;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    animation: slideInRight 0.8s ease-out;
    perspective: 2000px;
    overflow: visible;
  }

  .directory__content {
    grid-area: content;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: slideInLeft 0.8s ease-out 0.1s both;
  }

  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-30px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(30px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  
  /* Title */
  .directory__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 400;
    color: #ffffff;
    line-height: 1.2;
    margin: 0;
  }
  
  .directory__highlight {
    color: #ffffff;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: #2bbcb0;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  
  .directory__subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    margin: 0;
    line-height: 1.5;
  }
  
  /* Benefits */
  .directory__benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  
  .directory__benefit {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: #ffffff;
    font-weight: 400;
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
  }
  
  .directory__benefit:nth-child(1) { animation-delay: 0.2s; }
  .directory__benefit:nth-child(2) { animation-delay: 0.3s; }
  .directory__benefit:nth-child(3) { animation-delay: 0.4s; }
  .directory__benefit:nth-child(4) { animation-delay: 0.5s; }
  
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  
  .directory__check { flex-shrink: 0; }
  
  /* Pricing */
  .directory__pricing { margin-top: 0.5rem; }
  
  .directory__pricing-label {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 0.5rem;
    letter-spacing: 0.02em;
  }
  
  .directory__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  
  .directory__price-old {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-decoration: line-through;
    text-decoration-thickness: 2px;
  }
  
  .directory__price-current {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1;
  }
  
  /* CTA */
  .directory__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    appearance: none;
    border: none;
    cursor: pointer;
    background: linear-gradient(180deg, #2BBCB0 0%, #208D84 100%);
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
    line-height: 23px;
    text-transform: uppercase;
    text-align: center;
    padding: 10px 26px;
    border-radius: 53px;
    text-decoration: none;
    transition: all 0.25s ease;
    align-self: flex-start;
    margin-top: 0.5rem;
    letter-spacing: 0.03em;
    position: relative;
    overflow: hidden;
    box-shadow: 0px 4px 4px rgba(0,0,0,0.25), 0px 0px 20px rgba(43,188,176,0.4);
    min-width: 250px;
    height: 44px;
  }
  
  .directory__cta::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 0; height: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transform: translate(-50%, -50%);
    transition: width 0.6s ease, height 0.6s ease;
  }
  
  .directory__cta:hover::before { width: 300px; height: 300px; }
  .directory__cta:hover {
    background: linear-gradient(180deg, #27A99E 0%, #1a7a73 100%);
    transform: translateY(-2px);
    box-shadow: 0px 6px 6px rgba(0,0,0,0.3), 0px 0px 25px rgba(43,188,176,0.6);
  }
  
  .directory__cta span { position: relative; z-index: 1; }
  
  .directory__fine-print {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    margin: 0;
    line-height: 1.5;
  }
  
  /* Pages stack (desktop) */
  .directory__pages-stack {
    position: relative;
    width: 420px;
    height: 540px;
    margin-left: 80px;
    flex-shrink: 0;
  }

  .directory__page {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-origin: bottom center;
  }

  .directory__page img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
  }

  .directory__page--3 {
    z-index: 1;
    transform: translate(130px, -34px) rotate(16deg) scale(0.95);
    opacity: 0.80;
  }

  .directory__page--2 {
    z-index: 2;
    transform: translate(65px, -17px) rotate(7deg) scale(0.975);
    opacity: 0.90;
  }

  .directory__page--1 {
    z-index: 3;
    transform: translate(0, 0) rotate(-6deg) scale(1);
  }

  .directory__page.active {
    z-index: 10 !important;
    transform: translate(-10px, -20px) rotate(-4deg) scale(1.04) !important;
    opacity: 1 !important;
  }

  .directory__mockup:hover .directory__page--3 {
    transform: translate(145px, -40px) rotate(18deg) scale(0.95);
    opacity: 0.85;
  }
  .directory__mockup:hover .directory__page--2 {
    transform: translate(72px, -20px) rotate(8deg) scale(0.975);
    opacity: 0.92;
  }
  .directory__mockup:hover .directory__page--1 {
    transform: translate(-5px, -8px) rotate(-5deg) scale(1.01);
  }
  
  /* Label */
  .directory__mockup-label {
    position: absolute;
    bottom: -2rem;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.2);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    color: #ffffff;
    font-weight: 500;
    white-space: nowrap;
    z-index: 15;
    animation: fadeIn 1s ease-out 0.6s both;
    text-align: center;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  
  /* ── TABLET ── */
  @media (max-width: 968px) {
    .directory__container {
      grid-template-columns: 1fr;
      grid-template-areas:
        "title"
        "mockup"
        "content";
      gap: 0;
    }

    .directory__title-area {
      padding-bottom: 2rem;
    }

    .directory__mockup {
      align-items: center;
      justify-content: center;
      min-height: 420px;
      overflow: visible;
    }

    .directory__pages-stack {
      width: 100%;
      max-width: 300px;
      height: 400px;
      margin: 0 auto;
    }

    /* Fan RIGHT on mobile (match reference) */
    .directory__page--3 {
      transform: translate(80px, -30px) rotate(16deg) scale(0.88);
      opacity: 0.80;
    }
    .directory__page--2 {
      transform: translate(40px, -15px) rotate(8deg) scale(0.94);
      opacity: 0.90;
    }
    .directory__page--1 {
      transform: translate(0, 0) rotate(-3deg) scale(1);
    }
    .directory__page.active {
      transform: translate(-8px, -16px) rotate(-3deg) scale(1.03) !important;
    }

    .directory__mockup-label {
      bottom: -0.5rem;
      font-size: 0.85rem;
      padding: 0.6rem 1.2rem;
      white-space: normal;
      text-align: center;
      width: max-content;
      max-width: 90vw;
    }

    .directory__content {
      text-align: left;
      align-items: flex-start;
      padding-top: 3rem;
    }

    .directory__cta {
      align-self: stretch;
      width: 100%;
      min-width: unset;
    }
  }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .directory {
      padding: 3rem 1.25rem;
    }

    .directory__title {
      font-size: 1.6rem;
    }

    .directory__title-area {
      padding-bottom: 1.75rem;
    }

    .directory__mockup {
      min-height: 360px;
    }

    .directory__pages-stack {
      max-width: 260px;
      height: 340px;
    }

    /* Fan RIGHT — tighter for small screens */
    .directory__page--3 {
      transform: translate(65px, -25px) rotate(15deg) scale(0.86);
    }
    .directory__page--2 {
      transform: translate(33px, -13px) rotate(8deg) scale(0.93);
    }
    .directory__page--1 {
      transform: translate(0, 0) rotate(-3deg) scale(1);
    }

    .directory__mockup-label {
      font-size: 0.78rem;
      padding: 0.5rem 1rem;
    }

    .directory__subtitle { font-size: 0.95rem; }
    .directory__pricing-label { font-size: 1.25rem; }
    .directory__price-old { font-size: 1.5rem; }
    .directory__price-current { font-size: 2.5rem; }

    .directory__fine-print {
      text-align: center;
    }
  }
</style>
