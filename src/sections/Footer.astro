---
---

<footer class="footer">
  <!-- Clinic photo bg with dark overlay -->
  <div class="footer__bg"></div>

  <div class="footer__content">
    <!-- Top row: logo/tagline + nav cols -->
    <div class="footer__top">

      <!-- Left: logo + tagline -->
      <div class="footer__brand">
        <a href="/" aria-label="Enhance.work home">
          <img src="/images/logo-white.svg" alt="Enhance.work" class="footer__logo-img" />
        </a>
        <p class="footer__tagline">Your platform for a thriving aesthetic<br />career in South Florida.</p>
      </div>

      <!-- Right: single nav column -->
      <nav class="footer__nav" aria-label="Footer navigation">
        <div class="footer__col">
          <a href="/blog">Blog</a>
          <a href="#how-it-works">How it works</a>
          <a href="#roles">Roles</a>
        </div>
      </nav>
    </div>

    <!-- Divider -->
    <hr class="footer__divider" />

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <span>© 2026 enhance.work · All rights reserved.</span>
      <span>A growing demand for aesthetic professionals in South Florida.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background: #1b2936;
  }

  .footer__bg {
    position: absolute;
    inset: 0;
    background: url('/images/gateway-bg.png') center 15% / cover no-repeat;
    z-index: 0;
  }

  .footer__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(27, 41, 54, 0.35);
  }

  .footer__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 3.5rem 4rem;
  }

  /* Top row */
  .footer__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer__logo-img {
    height: 32px;
    width: auto;
    display: block;
    margin-bottom: .75rem;
    filter: none;
  }

  .footer__tagline {
    font-size: .88rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.55;
    margin: 0;
    max-width: 220px;
  }

  /* Nav */
  .footer__nav {
    display: flex;
    gap: 4rem;
    flex-shrink: 0;
    margin-right: 6rem;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .footer__col-title {
    font-family: var(--font-heading);
    font-size: .78rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: .1em;
    margin: 0 0 .5rem;
    text-transform: uppercase;
  }

  .footer__col a {
    font-size: .95rem;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color .2s;
    display: block;
    font-weight: 500;
  }

  .footer__col a:hover {
    color: #ffffff;
  }

  /* Divider */
  .footer__divider {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.18);
    margin: 0 0 1.5rem;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: .82rem;
    color: rgba(255,255,255,0.5);
  }

  @media (max-width: 768px) {
    .footer__content { padding: 2rem 1.5rem; }
    .footer__top {
      flex-direction: column;
      gap: 1.5rem;
    }
    .footer__nav {
      display: none;
    }
    .footer__bottom {
      flex-direction: column;
      gap: .5rem;
      text-align: center;
    }
  }
</style>
