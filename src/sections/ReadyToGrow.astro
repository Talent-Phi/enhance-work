---
---

<section class="rtg" id="ready-to-grow">
  <div class="rtg__inner">

    <div class="rtg__mockups">
      <img src="/images/mockups/how-it-works.png" alt="Enhance.work platform preview" class="rtg__mockup-img" />
    </div>

    <div class="rtg__content">
      <h2 class="rtg__title"><em class="rtg__accent">Ready to grow</em> your<br />career in aesthetics?</h2>
      <p class="rtg__sub">Start getting discovered by top clinics in South Florida. Create your profile in minutes and connect with real opportunities.</p>

      <ul class="rtg__checklist">
        <li>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          No spam
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Only real clinics
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Opportunities tailored to your skills
        </li>
      </ul>

      <div class="rtg__actions">
        <a href="/candidate/registration/" class="btn btn-primary rtg__btn apply-btn">Join for free</a>
      </div>
    </div>

  </div>
</section>

<style>
  .rtg {
    background: #1b2936;
    position: relative;
    overflow: hidden;
  }

  /* Teal radial glow */
  .rtg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 90% at 50% 50%, rgba(43,188,176,0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .rtg__inner {
    position: relative;
    z-index: 1;
    max-width: 1380px;
    margin: 0 auto;
    padding: 5rem 6%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .rtg__mockups {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .rtg__mockup-img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
  }

  .rtg__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.1rem;
  }

  .rtg__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    margin: 0;
  }

  .rtg__accent {
    font-style: normal;
    color: var(--color-accent);
  }

  .rtg__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.65;
    margin: 0;
  }

  .rtg__checklist {
    list-style: none;
    padding: 0;
    margin: .5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: .65rem;
    align-items: flex-start;
    text-align: left;
  }

  .rtg__checklist li {
    display: flex;
    align-items: center;
    gap: .65rem;
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
  }

  .rtg__actions {
    margin-top: 1rem;
  }

  .rtg__btn {
    padding: 1rem 3rem;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .rtg__inner {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem;
      gap: 2rem;
      text-align: left;
    }
    .rtg__mockups { order: -1; }
    .rtg__content {
      align-items: flex-start;
      gap: 1rem;
    }
    .rtg__title {
      font-size: 1.9rem;
    }
    .rtg__sub {
      font-size: .95rem;
    }
    .rtg__checklist {
      align-items: flex-start;
      gap: .55rem;
    }
    .rtg__checklist li {
      font-size: .95rem;
    }
    .rtg__actions {
      width: 100%;
      margin-top: .5rem;
    }
    .rtg__btn {
      width: 100%;
      text-align: center;
      padding: .9rem 1.5rem;
    }
  }
</style>
