---
---

<section class="rtg" id="ready-to-grow">
  <div class="rtg__inner">

    <div class="rtg__content">
      <h2 class="rtg__title">Ready to grow your career<br />in aesthetics?</h2>
      <p class="rtg__sub">Start getting discovered by top clinics in South Florida.</p>
      <p class="rtg__sub2">Create your profile in minutes and connect with real opportunities.</p>

      <ul class="rtg__checklist">
        <li>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          No spam
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Only real clinics
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="10" fill="#2bbcb0"/>
            <path d="M5.5 10l3 3 6-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Opportunities tailored to your skills
        </li>
      </ul>

      <div class="rtg__actions">
        <a href="/candidate/registration/" class="btn btn-primary rtg__btn apply-btn">Join for free</a>
      </div>
    </div>

  </div>
</section>

<style>
  .rtg {
    background: #1b2936;
    position: relative;
    overflow: hidden;
  }

  /* Teal radial glow */
  .rtg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 90% at 50% 50%, rgba(43,188,176,0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .rtg__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .rtg__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  .rtg__title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.2;
    margin: 0;
  }

  .rtg__sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.75);
    margin: 0;
  }

  .rtg__sub2 {
    font-size: .95rem;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }

  .rtg__checklist {
    list-style: none;
    padding: 0;
    margin: .5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: .65rem;
    align-items: flex-start;
    text-align: left;
  }

  .rtg__checklist li {
    display: flex;
    align-items: center;
    gap: .65rem;
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
  }

  .rtg__actions {
    margin-top: 1rem;
  }

  .rtg__btn {
    padding: 1rem 3rem;
    font-size: 1rem;
  }

  @media (max-width: 640px) {
    .rtg__title { font-size: 2rem; }
  }
</style>
