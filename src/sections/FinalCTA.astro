---

<section class="finalcta" id="final-cta">
  <div class="container finalcta__wrap">

    <!-- Two-column row -->
    <div class="finalcta__row">

      <!-- Left: form mockup collage -->
      <div class="finalcta__visual">
        <img
          src="/images/form-mockup-collage.png"
          alt="Enhance.work registration form — multi-step"
          class="finalcta__mockup"
        />
      </div>

      <!-- Right: copy -->
      <div class="finalcta__copy">
        <h2 class="finalcta__title">
          <span class="finalcta__accent">Ready to grow</span> your<br />career in aesthetics?
        </h2>
        <p class="finalcta__sub">
          Start getting discovered by top clinics in South Florida.
          Create your profile in minutes and connect with real opportunities.
        </p>
        <ul class="finalcta__checklist">
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9l3.5 3.5L14.5 5" stroke="#2bbcb0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            No spam
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9l3.5 3.5L14.5 5" stroke="#2bbcb0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Only real clinics
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9l3.5 3.5L14.5 5" stroke="#2bbcb0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Opportunities tailored to your skills
          </li>
        </ul>
      </div>
    </div>

    <!-- Button centered below both columns -->
    <div class="finalcta__btn-wrap">
      <a href="/candidate/registration/" class="btn btn-primary finalcta__btn apply-btn">
        Join for free
      </a>
    </div>

  </div>
</section>

<style>
  .finalcta {
    background: #f5f5f5;
  }

  .finalcta__wrap {
    padding: 7rem 0;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Two-column row */
  .finalcta__row {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }

  /* Left: collage */
  .finalcta__visual {
    display: flex;
    justify-content: center;
  }

  .finalcta__mockup {
    width: 100%;
    max-width: 560px;
    height: auto;
    display: block;
    filter: drop-shadow(0 6px 24px rgba(0,0,0,0.09));
  }

  /* Right: copy */
  .finalcta__copy {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .finalcta__title {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 400;       /* regular — as in Figma */
    color: #1a1a1a;
    line-height: 1.15;
    margin: 0;
  }

  .finalcta__accent {
    color: var(--color-accent);   /* teal */
    font-weight: 400;
  }

  .finalcta__sub {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.65;
    margin: 0;
  }

  .finalcta__checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .finalcta__checklist li {
    display: flex;
    align-items: center;
    gap: .55rem;
    font-size: 1rem;
    color: #333;
  }

  /* Button — centered pill, constrained width */
  .finalcta__btn-wrap {
    display: flex;
    justify-content: center;
  }

  .finalcta__btn {
    padding: .9rem 4rem;
    font-size: 1rem;
    width: auto;
    max-width: 320px;
    min-width: 200px;
  }

  @media (max-width: 768px) {
    .finalcta__wrap { padding: 3.5rem 1.25rem; }
    .finalcta__row { grid-template-columns: 1fr; gap: 2rem; }
    .finalcta__visual { display: none; } /* hide image on mobile to save space */
    .finalcta__title { font-size: 1.85rem; }
    .finalcta__sub { font-size: 0.95rem; }
    .finalcta__btn { width: 100%; text-align: center; max-width: 100%; }
    .finalcta__btn-wrap { padding: 0; }
  }
</style>
