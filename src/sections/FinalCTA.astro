---
---

<section class="finalcta" id="final-cta">
  <div class="container finalcta__inner">

    <!-- Top row: collage left, copy right -->
    <div class="finalcta__row">

      <!-- Left: form mockup collage -->
      <div class="finalcta__visual">
        <img
          src="/images/form-mockup-collage.png"
          alt="Enhance.work registration form — multi-step"
          class="finalcta__mockup"
        />
      </div>

      <!-- Right: copy -->
      <div class="finalcta__copy">
        <h2 class="finalcta__title">
          <em class="finalcta__accent">Ready to grow</em> your<br />career in aesthetics?
        </h2>
        <p class="finalcta__sub">
          Start getting discovered by top clinics in South Florida.
          Create your profile in minutes and connect with real opportunities.
        </p>
        <ul class="finalcta__checklist">
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9l3.5 3.5L14.5 5" stroke="#2bbcb0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            No spam
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9l3.5 3.5L14.5 5" stroke="#2bbcb0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Only real clinics
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9l3.5 3.5L14.5 5" stroke="#2bbcb0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Opportunities tailored to your skills
          </li>
        </ul>
      </div>
    </div>

    <!-- Button centered below both columns -->
    <div class="finalcta__btn-row">
      <a href="/candidate/registration/" class="btn btn-primary finalcta__btn apply-btn">
        Join for free
      </a>
    </div>

  </div>
</section>

<style>
  .finalcta {
    background: #f5f5f5;
  }

  .finalcta__inner {
    padding: 5rem 0;
  }

  /* Two-column row */
  .finalcta__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  /* Left: mockup collage */
  .finalcta__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .finalcta__mockup {
    width: 100%;
    max-width: 480px;
    height: auto;
    display: block;
    filter: drop-shadow(0 8px 28px rgba(0,0,0,0.10));
  }

  /* Right: copy */
  .finalcta__copy {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .finalcta__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.2;
    margin: 0;
  }

  .finalcta__accent {
    font-style: italic;
    color: var(--color-accent);
  }

  .finalcta__sub {
    font-size: .97rem;
    color: #444;
    line-height: 1.65;
    margin: 0;
    max-width: 340px;
  }

  .finalcta__checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .55rem;
  }

  .finalcta__checklist li {
    display: flex;
    align-items: center;
    gap: .55rem;
    font-size: .95rem;
    color: #333;
  }

  /* CTA button — centered below */
  .finalcta__btn-row {
    display: flex;
    justify-content: center;
  }

  .finalcta__btn {
    padding: 1rem 3rem;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .finalcta__row {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .finalcta__title { font-size: 1.85rem; }
    .finalcta__sub { max-width: 100%; }
  }
</style>
