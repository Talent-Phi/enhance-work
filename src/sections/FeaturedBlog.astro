---
// FeaturedBlog.astro
// Shows the most popular/featured blog post on the homepage.
// Layout: title top → full-width image → excerpt text → "Join for free" button bottom-right

const post = {
  title: "A growing demand for aesthetic professionals in South Florida.",
  slug: "aesthetic-rn-florida",
  image: "/images/blog/aesthetic-rn-florida-hero.webp",
  excerpt: `South Florida has one of the highest concentrations of aesthetic practices in the country. Miami-Dade, Broward, and Palm Beach counties are home to hundreds of medical spas, dermatology clinics, and aesthetic centers actively looking for qualified professionals.

The demand for nurse injectors, medical aestheticians, laser technicians, and clinical coordinators has grown steadily year over year. Practices are expanding their service menus, investing in new technology, and competing for a limited pool of experienced providers.

Most of those openings never get posted on Indeed or LinkedIn. In this industry, hiring happens through networks, referrals, and platforms built specifically for this space. Enhance.work connects qualified aesthetic professionals directly with South Florida practices that are hiring now — without the noise of general job boards.`,
};
---

<section class="featured-blog" id="featured-blog">
  <div class="featured-blog__inner">

    <h2 class="featured-blog__title">
      {post.title}
    </h2>

    <a href={`/blog/${post.slug}`} class="featured-blog__img-link">
      <div class="featured-blog__img-wrap">
        <img
          src={post.image}
          alt={post.title}
          class="featured-blog__img"
          loading="lazy"
        />
      </div>
    </a>

    <div class="featured-blog__content">
      <div class="featured-blog__text">
        <p class="featured-blog__location">South Florida.</p>
        {post.excerpt.split('\n\n').map(para => (
          <p>{para}</p>
        ))}
      </div>
      <div class="featured-blog__cta-wrap">
        <a href="/candidate/registration" class="featured-blog__cta">Join for free</a>
      </div>
    </div>

  </div>
</section>

<style>
  .featured-blog {
    background: #ffffff;
    border-top: 1px solid #ebebeb;
    padding: 4rem 2rem 4.5rem;
  }

  .featured-blog__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Title */
  .featured-blog__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.2;
    margin: 0;
  }

  /* Image */
  .featured-blog__img-link {
    display: block;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
  }
  .featured-blog__img-wrap {
    width: 100%;
    aspect-ratio: 16/6;
    overflow: hidden;
    background: #e8f8f7;
  }
  .featured-blog__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.35s ease;
    display: block;
  }
  .featured-blog__img-link:hover .featured-blog__img {
    transform: scale(1.02);
  }

  /* Content: text + CTA */
  .featured-blog__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .featured-blog__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .featured-blog__location {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.25rem;
  }
  .featured-blog__text p {
    font-family: var(--font-body);
    font-size: 0.97rem;
    color: #444;
    line-height: 1.75;
    margin: 0;
  }

  /* CTA button aligned bottom-right */
  .featured-blog__cta-wrap {
    display: flex;
    justify-content: flex-end;
  }
  .featured-blog__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 2.25rem;
    background: var(--color-accent, #2bbcb0);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .featured-blog__cta:hover {
    background: #22a89d;
    transform: translateY(-1px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .featured-blog {
      padding: 2.5rem 1.25rem 3rem;
    }
    .featured-blog__img-wrap {
      aspect-ratio: 16/9;
    }
    .featured-blog__text p {
      font-size: 0.9rem;
    }
  }
</style>
