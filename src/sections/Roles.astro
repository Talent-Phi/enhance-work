---
// Exported directly from Figma (instances with IMAGE fill + gradient overlay + title baked in)
const roles = [
  { image: '/images/role-1.png', title: 'Nurse Injector' },
  { image: '/images/role-2.png', title: 'Medical Aesthetician' },
  { image: '/images/role-3.png', title: 'Laser Technician' },
  { image: '/images/role-4.png', title: 'Dermatology Assistant' },
  { image: '/images/role-5.png', title: 'Clinic Manager' },
];
---

<section class="roles" id="roles">
  <div class="container">
    <div class="roles__header">
      <span class="label">Roles on the platform</span>
      <h2 class="h2">Aesthetic professionals<br />across South Florida</h2>
    </div>

    <div class="roles__grid">
      {roles.map((role) => (
        <div class="roles__card">
          <img src={role.image} alt={role.title} class="roles__img" />
          <div class="roles__overlay"></div>
          <div class="roles__info">
            <span class="roles__title">{role.title}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .roles { padding: var(--section-padding); }

  .roles__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    max-width: 560px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .roles__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .roles__card {
    position: relative;
    border-radius: 15px;
    overflow: hidden;
    aspect-ratio: 207 / 212;
    cursor: pointer;
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.28s ease;
  }

  .roles__card:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 20px 40px rgba(43, 188, 176, 0.2), 0 6px 16px rgba(0, 0, 0, 0.15);
  }

  .roles__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Gradient overlay: rgba(0,0,0,0.55) → transparent  (from bottom) */
  .roles__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.60) 0%, rgba(0,0,0,0) 55%);
    transition: background 0.28s ease;
  }

  .roles__card:hover .roles__overlay {
    background: linear-gradient(to top, rgba(43,188,176,0.75) 0%, rgba(0,0,0,0) 65%);
  }

  .roles__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem .9rem;
  }

  .roles__title {
    font-family: var(--font-heading);
    font-size: .9rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
    display: block;
  }

  @media (max-width: 1000px) {
    .roles__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 600px) {
    .roles__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
