---
---

<section class="demand" id="demand">
  <div class="container">
    <div class="demand__header">
      <h2 class="h2">A growing demand for<br />aesthetic professionals<br />in <em class="accent">South Florida.</em></h2>
      <p class="demand__sub">
        Clinics across Miami, Doral, and Broward County are actively hiring qualified aesthetic professionals.
      </p>
    </div>

    <div class="demand__cards">
      <!-- Chart 1: Line chart -->
      <div class="demand__card-wrap">
        <div class="demand__card-img-box">
          <img src="/images/demand-chart.png" alt="Demand for aesthetic professional — U.S. Jobs growth chart" class="demand__chart-img" />
        </div>
        <p class="demand__card-label"><strong><em>Demand for Aesthetic Professionals Is Accelerating</em></strong></p>
        <!-- Data sources under left card -->
        <div class="demand__sources">
          <span class="demand__sources-label">Data sources:</span>
          <ul class="demand__sources-list">
            <li><a href="https://www.bls.gov/ooh/personal-care-and-service/skincare-specialists.htm" target="_blank" rel="noopener">Skincare specialists provide ↗</a></li>
            <li><a href="https://www.bls.gov/ooh/healthcare/nurse-anesthetists-nurse-midwives-and-nurse-practitioners.htm" target="_blank" rel="noopener">Healthcare nurse practitioners ↗</a></li>
          </ul>
        </div>
      </div>

      <!-- Chart 2: Bar chart -->
      <div class="demand__card-wrap">
        <div class="demand__card-img-box">
          <img src="/images/mockups/chart-bars.png" alt="Most in-demand roles" class="demand__chart-img" />
        </div>
        <p class="demand__card-label">10-year projected growth</p>
      </div>
    </div>
  </div>
</section>

<style>
  .demand {
    padding: var(--section-padding);
    background: var(--color-bg);  /* #f2f2f2 — Figma frame base */
  }

  .demand__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    max-width: 900px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .accent { font-style: normal; color: var(--color-accent); }

  .demand__sub {
    color: #606362;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 640px;
    text-align: center;
  }

  .demand__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start; /* allow each col to define its own height */
  }

  .demand__card-wrap {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  /* White card box — chart image with padding so it doesn't bleed edge-to-edge */
  .demand__card-img-box {
    background: #ffffff;
    border-radius: 16px;
    padding: 1.25rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  }

  .demand__card-label {
    font-family: var(--font-body);
    font-size: .9rem;
    color: #3a3a3a;
    text-align: left;
    margin: 0;
  }

  /* Data sources — left-aligned under left card */
  .demand__sources {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    margin-top: .25rem;
  }

  .demand__sources-label {
    font-size: .82rem;
    color: #666;
    font-weight: 500;
  }

  .demand__sources-list {
    list-style: disc;
    padding-left: 1.2rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .demand__sources-list a {
    font-size: .82rem;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .demand__sources-list a:hover {
    opacity: .8;
  }

  .demand__card {
    background: #ffffff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 27px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.28s ease;
  }

  .demand__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(43,188,176,0.12), 0 4px 12px rgba(0,0,0,0.06);
  }

  .demand__card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .demand__card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    color: #404040;
    line-height: 1.4;
  }

  .demand__card-sub {
    font-size: .875rem;
    font-weight: 400;
    color: #595959;
    margin-top: .2rem;
  }

  .demand__badge {
    background: #dff5f3;
    color: #208d84;
    font-family: var(--font-heading);
    font-size: .8rem;
    font-weight: 600;
    padding: .3rem .75rem;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .demand__view-all {
    font-size: .95rem;
    color: #bababa;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .demand__chart-wrap {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .demand__chart-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  /* Bar chart */
  .demand__bars {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .demand__bar-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    align-items: center;
    gap: .75rem;
  }

  .demand__bar-label {
    font-size: .875rem;
    color: #595959;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .demand__bar-track {
    height: 24px;
    background: #bdeae7;
    border-radius: 4px;
    overflow: hidden;
  }

  .demand__bar-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 4px;
    transition: width 1s ease;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 2.5rem;
  }

  .demand__bar-pct {
    font-size: .8rem;
    font-weight: 600;
    color: #fff;
    padding-right: 0.5rem;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .demand__cards { grid-template-columns: 1fr; }
    .demand__bar-row { grid-template-columns: 110px 1fr; }
  }
</style>
