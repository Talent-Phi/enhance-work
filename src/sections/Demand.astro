---
---

<section class="demand" id="demand">
  <div class="container">
    <div class="demand__header">
      <h2 class="h2">A growing demand for<br />aesthetic professionals<br />in <em class="accent">South Florida.</em></h2>
      <p class="demand__sub">
        Clinics across Miami, Doral, and surrounding areas are looking for skilled professionals like you.
      </p>
    </div>

    <div class="demand__cards">
      <!-- Chart 1: Line chart (Figma node 825:3593) — already styled as a card -->
      <img src="/images/demand-chart.png" alt="Demand for aesthetic professional — U.S. Jobs growth chart" class="demand__chart-img" />

      <!-- Chart 2: Bar chart (Figma node 825:3637) — already styled as a card -->
      <img src="/images/mockups/chart-bars.png" alt="Most in-demand roles" class="demand__chart-img" />
    </div>
  </div>
</section>

<style>
  .demand {
    padding: var(--section-padding);
    background: var(--color-bg);  /* #f2f2f2 — Figma frame base */
  }

  .demand__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    max-width: 720px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .accent { font-style: normal; color: var(--color-accent); }

  .demand__sub {
    color: #606362;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 560px;
  }

  .demand__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .demand__card {
    background: #ffffff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 27px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.28s ease;
  }

  .demand__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(43,188,176,0.12), 0 4px 12px rgba(0,0,0,0.06);
  }

  .demand__card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .demand__card-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    color: #404040;
    line-height: 1.4;
  }

  .demand__card-sub {
    font-size: .875rem;
    font-weight: 400;
    color: #595959;
    margin-top: .2rem;
  }

  .demand__badge {
    background: #dff5f3;
    color: #208d84;
    font-family: var(--font-heading);
    font-size: .8rem;
    font-weight: 600;
    padding: .3rem .75rem;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .demand__view-all {
    font-size: .95rem;
    color: #bababa;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .demand__chart-wrap {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .demand__chart-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
  }

  /* Bar chart */
  .demand__bars {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .demand__bar-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    align-items: center;
    gap: .75rem;
  }

  .demand__bar-label {
    font-size: .875rem;
    color: #595959;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .demand__bar-track {
    height: 24px;
    background: #bdeae7;
    border-radius: 4px;
    overflow: hidden;
  }

  .demand__bar-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: 4px;
    transition: width 1s ease;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-width: 2.5rem;
  }

  .demand__bar-pct {
    font-size: .8rem;
    font-weight: 600;
    color: #fff;
    padding-right: 0.5rem;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .demand__cards { grid-template-columns: 1fr; }
    .demand__bar-row { grid-template-columns: 110px 1fr; }
  }
</style>
