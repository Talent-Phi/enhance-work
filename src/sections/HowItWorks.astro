---
const steps = [
  {
    number: '01',
    title: 'Create your profile',
    desc: 'Build a professional profile highlighting your certifications, experience, and aesthetic specialties.',
  },
  {
    number: '02',
    title: 'Get matched',
    desc: 'Our platform connects you with clinics and opportunities that fit your skills and career goals.',
  },
  {
    number: '03',
    title: 'Start working',
    desc: 'Accept placements, build your reputation, and grow your career in South Florida aesthetics.',
  },
];
---

<section class="how" id="how-it-works">
  <div class="container">
    <div class="how__header">
      <span class="label">How it works</span>
      <h2 class="h2">From profile to placement —<br />Enhance makes it simple</h2>
      <p class="how__sub">Everything aesthetic professionals need to take the next step in their career.</p>
    </div>

    <div class="how__steps">
      {steps.map((step) => (
        <div class="how__step">
          <span class="how__step-num">{step.number}</span>
          <h3 class="h3">{step.title}</h3>
          <p>{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how {
    padding: var(--section-padding);
    background: #18232c; /* Figma dark section */
  }

  .how__header .label { color: #dff5f3; }
  .how__header .h2 { color: #dff5f3; }
  .how__header .how__sub { color: rgba(223,245,243,.6); }

  .how__header {
    max-width: 640px;
    margin: 0 auto 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .how__sub {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.7;
  }

  .how__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .how__step {
    background: rgba(255,255,255,.05);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid rgba(255,255,255,.08);
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .how__step .h3 { color: #dff5f3; }

  .how__step-num {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .how__step p {
    color: rgba(223,245,243,.55);
    font-size: .95rem;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .how__steps { grid-template-columns: 1fr; }
  }
</style>
