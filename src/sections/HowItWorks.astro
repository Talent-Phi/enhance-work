---
const steps = [
  {
    number: 'STEP 01',
    title: 'Join the Enhance.Work Network',
    desc: 'Create your profile, add your specialty, and let South Florida practices find you.',
    card: '/images/hiw-step1-mockup.png',
    cardAlt: 'Profile creation mockup',
  },
  {
    number: 'STEP 02',
    title: 'Match Your Skills With the Right Opportunities',
    desc: 'Get discovered by aesthetic practices across South Florida.',
    card: '/images/hiw-step2-mockup.png',
    cardAlt: 'Job matching mockup',
  },
  {
    number: 'STEP 03',
    title: 'Start and Grow Your Career in Aesthetics',
    desc: 'Apply or get invited to opportunities that fit your experience.',
    card: '/images/hiw-step3-mockup.png',
    cardAlt: 'Career growth mockup',
  },
];
---

<section class="how" id="how-it-works">
  <!-- bg image from Figma -->
  <div class="how__bg"></div>

  <div class="container how__inner">
    <div class="how__header">
      <div class="label-divider label-divider--dark"><span class="label how__label">How it works</span></div>
      <h2 class="h2 how__h2">Three steps to your next role in <span class="how__accent">South Florida.</span></h2>
      <p class="how__sub">Fill out your profile, get discovered by South Florida practices,<br />and let clinics come to you.</p>
    </div>

    <!-- Horizontal expanding glassmorphism cards -->
    <div class="how__row" id="how-row">
      {steps.map((step, i) => (
        <div class="how__card" data-index={i}>
          <button class="how__card-btn" aria-expanded="false">
            <!-- STEP number: 50px gradient purple→lavender -->
            <span class="how__num">{step.number}</span>
            <h3 class="how__title">{step.title}</h3>
            <p class="how__desc"><span class="how__desc-inner">{step.desc}</span></p>
          </button>
          <!-- Mockup — always at bottom, partially visible when collapsed -->
          <div class="how__card-mockup">
            <img src={step.card} alt={step.cardAlt} class="how__card-img" loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const cards = Array.from(document.querySelectorAll('.how__card'));

  cards.forEach((card) => {
    card.querySelector('.how__card-btn')?.addEventListener('click', () => {
      const isActive = card.classList.contains('active');
      // Close all
      cards.forEach(c => {
        c.classList.remove('active');
        c.querySelector('.how__card-btn')?.setAttribute('aria-expanded', 'false');
      });
      // Toggle open
      if (!isActive) {
        card.classList.add('active');
        card.querySelector('.how__card-btn')?.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<style>
  .how {
    padding: var(--section-padding);
    background: #0f1b24;
    position: relative;
    overflow: hidden;
  }

  /* Background image from Figma */
  .how__bg {
    position: absolute;
    inset: 0;
    background: url('/images/hiw-bg.png') center center / cover no-repeat;
    opacity: 0.22;
    pointer-events: none;
    z-index: 0;
  }

  .how__inner {
    position: relative;
    z-index: 1;
  }

  .how__label {
    color: #2bbcb0 !important;
    background: rgba(43,188,176,0.15) !important;
    border: 1px solid rgba(43,188,176,0.3);
  }

  .how__h2 {
    color: #ffffff;
    font-size: clamp(1.8rem, 3.5vw, 2.9rem);
  }

  .how__accent {
    color: var(--color-accent);
  }

  .how__sub {
    color: rgba(255,255,255,0.55);
    font-size: .95rem;
    line-height: 1.65;
  }

  .how__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    max-width: 680px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Horizontal row of 3 glassmorphism cards ── */
  .how__row {
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
    /* Fixed height so collapsed cards clip the mockup at bottom */
    height: 520px;
  }

  /* Glassmorphism card — rgba(255,255,255,0.12) over dark bg */
  .how__card {
    flex: 1;
    min-width: 0;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 15px;
    overflow: hidden;         /* clips mockup at card bottom when collapsed */
    cursor: pointer;
    transition:
      flex 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .how__card.active {
    flex: 3;
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(151, 100, 212, 0.45);
    box-shadow: 0 0 48px rgba(151, 100, 212, 0.18), 0 16px 40px rgba(0,0,0,0.4);
  }

  /* STEP number — 50px gradient from Figma: #9764d4 → #ebdbff */
  .how__num {
    font-family: var(--font-heading);
    font-size: 3.125rem; /* 50px */
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(90deg, #9764d4 0%, #ebdbff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    letter-spacing: -0.02em;
    margin-bottom: .75rem;
  }

  /* Button area — text content */
  .how__card-btn {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 1.75rem 1.5rem 1rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .how__title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.4;
    margin: 0 0 .5rem;
  }

  .how__desc {
    font-size: .8rem;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin: 0;
    /* Hidden when not active — collapses via grid trick */
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows .35s ease;
  }

  .how__desc-inner {
    overflow: hidden;
    min-height: 0;
  }

  .how__card.active .how__desc {
    grid-template-rows: 1fr;
  }

  /* Mockup area — always rendered at bottom, clipped by card overflow:hidden */
  .how__card-mockup {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 1.25rem 0;
    min-height: 0;
  }

  .how__card-img {
    width: 100%;
    max-width: 280px;
    border-radius: 12px 12px 0 0;
    box-shadow: 0 -4px 24px rgba(0,0,0,0.35);
    display: block;
    /* Always visible but clipped from bottom by container overflow */
    object-fit: cover;
    object-position: top;
  }

  /* Mobile: stack vertically */
  @media (max-width: 768px) {
    .how__header { text-align: left; margin: 0 0 1.5rem; }
    .how__h2 { font-size: 1.75rem; }
    .how__sub { font-size: .88rem; }

    .how__row {
      flex-direction: column;
      height: auto;
      gap: 0.75rem;
    }

    .how__card {
      flex: none !important;
      width: 100%;
      height: 260px;
    }

    .how__card.active {
      height: 480px;
    }

    .how__num { font-size: 2.5rem; }
    .how__card-img { max-width: 100%; border-radius: 12px 12px 0 0; }
  }
</style>
