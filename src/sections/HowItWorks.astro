---
const steps = [
  {
    number: 'STEP 01',
    title: 'Join the Enhance.Work Network',
    desc: 'Create your profile, add your specialty, and let South Florida practices find you.',
    card: '/images/hiw-step1-mockup.png',
    cardAlt: 'Profile creation mockup',
  },
  {
    number: 'STEP 02',
    title: 'Match Your Skills With the Right Opportunities',
    desc: 'Our platform evaluates your experience, professional goals, and employment expectations. We identify clinics and practices actively looking for professionals with your profile.',
    card: '/images/hiw-step2-mockup.png',
    cardAlt: 'Job matching mockup',
  },
  {
    number: 'STEP 03',
    title: 'Start and Grow Your Career in Aesthetics',
    desc: 'Apply or get invited to opportunities that fit your experience.',
    card: '/images/hiw-step3-mockup.png',
    cardAlt: 'Career growth mockup',
  },
];
---

<section class="how" id="how-it-works">
  <!-- bg image from Figma (Rectangle 1438) -->
  <div class="how__bg"></div>

  <div class="container how__inner">
    <div class="how__header">
      <div class="label-divider label-divider--dark"><span class="label how__label">How it works</span></div>
      <h2 class="h2 how__h2">Three steps to your next role in <span class="how__accent">South Florida.</span></h2>
      <p class="how__sub">Fill out your profile, get discovered by South Florida practices,<br class="how__br" /> and let clinics come to you.</p>
    </div>

    <!-- 3 equal glassmorphism cards — all content always visible -->
    <div class="how__row" id="howRow">
      {steps.map((step, i) => (
        <div class="how__card" data-index={i} tabindex="0" role="button">
          <!-- STEP number: gradient purple→lavender -->
          <span class="how__num">{step.number}</span>
          <h3 class="how__title">{step.title}</h3>
          <p class="how__desc">{step.desc}</p>
          <!-- Mockup at bottom -->
          <div class="how__mockup-wrap">
            <img src={step.card} alt={step.cardAlt} class="how__card-img" loading="lazy" />
          </div>
        </div>
      ))}
    </div>
    <!-- Carousel dots (mobile only) -->
    <div class="how__dots" id="howDots">
      {steps.map((_, i) => (
        <button class={`how__dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Step ${i + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<script>
  const howCards = document.querySelectorAll('.how__card');
  const howDots  = document.querySelectorAll('.how__dot');
  const howRow   = document.getElementById('howRow');

  // Desktop: click to highlight
  howCards.forEach(card => {
    card.addEventListener('click', () => {
      const isActive = card.classList.contains('active');
      howCards.forEach(c => c.classList.remove('active'));
      if (!isActive) card.classList.add('active');
    });
  });

  // Dots: click to scroll carousel to card
  howDots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.dataset.dot);
      const card = howRow.children[idx];
      howRow.scrollTo({ left: card.offsetLeft - howRow.offsetLeft, behavior: 'smooth' });
    });
  });

  // Sync dots on scroll
  if (howRow) {
    howRow.addEventListener('scroll', () => {
      const cardWidth = howRow.children[0]?.offsetWidth || 1;
      const idx = Math.round(howRow.scrollLeft / cardWidth);
      howDots.forEach((d, i) => d.classList.toggle('active', i === idx));
    }, { passive: true });
  }
</script>

<style>
  .how {
    padding: var(--section-padding);
    background: #0d1a23;
    position: relative;
    overflow: hidden;
  }

  /* Background photo from Figma (Rectangle 1438 — image fill) */
  .how__bg {
    position: absolute;
    inset: 0;
    background: url('/images/hiw-bg-photo.png') center center / cover no-repeat;
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
  }

  .how__inner {
    position: relative;
    z-index: 1;
  }

  /* Label pill */
  .how__label {
    color: #2bbcb0 !important;
    background: rgba(43,188,176,0.15) !important;
    border: 1px solid rgba(43,188,176,0.3);
  }

  /* Header */
  .how__h2 {
    color: #ffffff;
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .how__accent {
    color: var(--color-accent);
  }

  .how__sub {
    color: rgba(255,255,255,0.55);
    font-size: .95rem;
    line-height: 1.65;
  }

  .how__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    max-width: 720px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Horizontal flex row — cards expand on click ── */
  .how__row {
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
    min-height: 560px;
  }

  /* Glassmorphism card */
  .how__card {
    flex: 1;
    min-width: 140px;   /* prevents crushing on collapse */
    background: rgba(255, 255, 255, 0.09);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 15px;
    padding: 2rem 1.5rem 2rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: .75rem;
    overflow: hidden;
    box-sizing: border-box;
    transition:
      flex .5s cubic-bezier(0.4, 0, 0.2, 1),
      border-color .3s ease,
      background .3s ease,
      box-shadow .3s ease;
  }

  .how__card:hover {
    border-color: rgba(151, 100, 212, 0.3);
    box-shadow: 0 0 28px rgba(151, 100, 212, 0.1);
  }

  /* Active card grows to 3× */
  .how__card.active {
    flex: 3;
    border-color: rgba(151, 100, 212, 0.55);
    background: rgba(255,255,255,0.16);
    box-shadow: 0 0 48px rgba(151, 100, 212, 0.2), 0 12px 32px rgba(0,0,0,0.35);
  }

  /* STEP number — gradient #9764d4 → #ebdbff (from Figma, 50px 700) */
  .how__num {
    font-family: var(--font-heading);
    font-size: 3.125rem; /* 50px */
    font-weight: 600;
    line-height: 1;
    background: linear-gradient(90deg, #9764d4 0%, #ebdbff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    letter-spacing: -0.02em;
  }

  /* Title — 18px 600 white */
  .how__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.4;
    margin: 0;
    word-break: break-word;
  }

  /* Description — 12px/14px white 60% */
  .how__desc {
    font-size: .82rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.62);
    line-height: 1.65;
    margin: 0;
  }

  /* Description takes available space so mockup is always at bottom */
  .how__desc {
    flex-grow: 1;
  }

  /* Mockup at bottom */
  .how__mockup-wrap {
    margin-top: 1.25rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .how__card-img {
    width: 100%;
    max-width: 280px;
    border-radius: 12px 12px 0 0;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
    display: block;
  }

  /* Carousel dots */
  .how__dots {
    display: none; /* hidden on desktop */
    justify-content: center;
    gap: .5rem;
    margin-top: 1.25rem;
  }
  .how__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .25s, transform .25s;
  }
  .how__dot.active {
    background: var(--color-accent);
    transform: scale(1.25);
  }

  /* Mobile: horizontal carousel */
  @media (max-width: 768px) {
    /* Pull the row to full viewport width, breaking out of container padding */
    .how__row {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 1rem;
      padding-bottom: 1rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      margin-left: -1.5rem;
      margin-right: -1.5rem;
      min-height: unset;
      align-items: stretch;
      /* Hide scrollbar */
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .how__row::-webkit-scrollbar { display: none; }

    .how__card {
      /* Card = full viewport minus container padding on both sides */
      flex: 0 0 calc(100vw - 3rem);
      min-width: calc(100vw - 3rem);
      scroll-snap-align: start;
      padding: 1.5rem 1.25rem 0;
      flex-grow: 0;
    }

    /* First card active by default on mobile */
    .how__card:first-child {
      border-color: rgba(151, 100, 212, 0.55);
      background: rgba(255,255,255,0.16);
    }

    .how__num { font-size: 2.5rem; }
    .how__card-img { max-width: 100%; border-radius: 12px; }
    .how__br { display: none; }

    .how__h2 { font-size: 1.75rem; }
    .how__header { text-align: left; margin: 0 0 1.5rem; }
    .how__dots { display: flex; }
  }
</style>
