---
const steps = [
  {
    number: 'STEP 01',
    title: 'Join the Enhance.Work Network',
    desc: 'Create your profile and showcase your skills and certifications.',
    card: '/images/mockups/step1-card.png',
    cardAlt: 'Profile creation mockup',
  },
  {
    number: 'STEP 02',
    title: 'Match Your Skills With the Right Opportunities',
    desc: 'Get discovered by aesthetic practices across South Florida.',
    card: '/images/mockups/step2-card.png',
    cardAlt: 'Job matching mockup',
  },
  {
    number: 'STEP 03',
    title: 'Start and Grow Your Career in Aesthetics',
    desc: 'Apply or get invited to opportunities that fit your experience.',
    card: '/images/mockups/step3-card.png',
    cardAlt: 'Career growth mockup',
  },
];
---

<section class="how" id="how-it-works">
  <div class="container">
    <div class="how__header">
      <div class="label-divider label-divider--dark"><span class="label how__label">How it works</span></div>
      <h2 class="h2 how__h2">Three steps to your next<br />role in South Florida</h2>
      <p class="how__sub">No recruiters, no cold applications. Just a smart platform built for aesthetic professionals.</p>
    </div>

    <!-- Horizontal expanding cards -->
    <div class="how__row" id="how-row">
      {steps.map((step, i) => (
        <div class="how__card" data-index={i}>
          <button class="how__card-btn" aria-expanded="false">
            <span class="how__num">{step.number}</span>
            <h3 class="how__title">{step.title}</h3>
            <p class="how__desc">{step.desc}</p>
          </button>
          <div class="how__card-expand">
            <img src={step.card} alt={step.cardAlt} class="how__card-img" loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const cards = Array.from(document.querySelectorAll('.how__card'));

  cards.forEach((card) => {
    card.querySelector('.how__card-btn')?.addEventListener('click', () => {
      const isActive = card.classList.contains('active');

      // Close all
      cards.forEach(c => {
        c.classList.remove('active');
        c.querySelector('.how__card-btn')?.setAttribute('aria-expanded', 'false');
      });

      // If wasn't active, open it
      if (!isActive) {
        card.classList.add('active');
        card.querySelector('.how__card-btn')?.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<style>
  .how {
    padding: var(--section-padding);
    background: #18232c;
  }

  /* On dark bg: override pill to dark semi-transparent bg with teal text */
  .how__label {
    color: #2bbcb0 !important;
    background: rgba(43,188,176,0.15) !important;
    border: 1px solid rgba(43,188,176,0.3);
  }
  .how__h2 { color: #dff5f3; }

  .how__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    max-width: 640px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .how__sub {
    color: rgba(223,245,243,.55);
    font-size: 1rem;
    line-height: 1.7;
  }

  /* ── Horizontal row ── */
  .how__row {
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
  }

  .how__card {
    flex: 1;
    min-width: 0;
    /* Figma: step cards are white fill with text on dark section bg = white cards */
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 15px;    /* Figma: r=15 */
    overflow: hidden;
    cursor: pointer;
    transition:
      flex 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .how__card.active {
    flex: 3;
    background: rgba(255,255,255,.13);
    border-color: rgba(43,188,176,.5);
    box-shadow: 0 16px 40px rgba(0,0,0,0.3);
  }

  /* Button (text area — always visible) */
  .how__card-btn {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 1.75rem 1.5rem 1.25rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    flex-shrink: 0;
  }

  .how__num {
    font-family: var(--font-heading);
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .12em;
    color: #cbc5ff;
    display: block;
  }

  .how__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: #dff5f3;
    line-height: 1.35;
    margin: 0;
    /* On collapsed: clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .how__card.active .how__title {
    -webkit-line-clamp: unset;
    overflow: visible;
  }

  .how__desc {
    color: rgba(223,245,243,.55);
    font-size: .85rem;
    line-height: 1.6;
    margin: 0;
    /* Hidden when collapsed */
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height .45s ease, opacity .35s ease;
  }

  .how__card.active .how__desc {
    max-height: 120px;
    opacity: 1;
  }

  /* Expand area (card mockup) */
  .how__card-expand {
    flex: 1;
    padding: 0 1.5rem 1.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    /* Hidden when collapsed */
    opacity: 0;
    transform: translateY(12px) scale(0.97);
    max-height: 0;
    overflow: hidden;
    transition:
      opacity .4s ease .1s,
      transform .4s cubic-bezier(0.34, 1.2, 0.64, 1) .1s,
      max-height .5s ease;
  }

  .how__card.active .how__card-expand {
    opacity: 1;
    transform: translateY(0) scale(1);
    max-height: 400px;
    overflow: visible;
  }

  .how__card-img {
    width: 100%;
    max-width: 300px;
    border-radius: 12px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.4);
    display: block;
  }

  /* Mobile: carousel (one step at a time, swipe, dots) */
  @media (max-width: 768px) {
    .how__header { text-align: left; margin: 0 0 1.5rem; }
    .how__h2 { font-size: 1.75rem; }

    .how__row {
      flex-direction: column;
      gap: 0.75rem;
      overflow-x: visible;
    }

    .how__card {
      flex: none !important;
      width: 100%;
      min-height: auto;
    }

    .how__card.active .how__card-expand {
      max-height: 350px;
    }

    .how__card-img { max-width: 100%; }
  }
</style>
