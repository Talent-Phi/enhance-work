---
// All 6 are Port Medical logo (identical file from Figma)
const gridImages = Array(6).fill({ src: '/images/clinic-1.png', alt: 'Port Medical' });
---

<section class="trusted" id="trusted-by">
  <div class="container">
    <div class="trusted__header">
      <span class="label">Trusted by</span>
      <h2 class="h2">The clinics looking for you<br />are already here.</h2>
      <p class="trusted__sub">
        Leading practices across Florida use Enhance.work to find and hire aesthetic professionals.
      </p>
    </div>

    <div class="trusted__layout">
      <!-- Left: tall clinic photo -->
      <div class="trusted__hero-wrap">
        <img
          src="/images/trusted-clinic.png"
          alt="Aesthetic clinic interior"
          class="trusted__hero-img"
          loading="lazy"
        />
      </div>

      <!-- Right: 2-col × 3-row logo grid -->
      <div class="trusted__grid">
        {gridImages.map((img) => (
          <div class="trusted__img-wrap">
            <img src={img.src} alt={img.alt} class="trusted__img" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .trusted {
    padding: var(--section-padding);
    background: #ffffff;
  }

  .trusted__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 3rem;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .trusted__sub {
    color: #595959;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 560px;
  }

  /* Two-column layout: tall photo left + logo grid right */
  .trusted__layout {
    display: grid;
    grid-template-columns: 358fr 566fr;
    gap: 1.25rem;
    align-items: start;
  }

  /* Left: tall clinic photo */
  .trusted__hero-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 358 / 459;
    background: #dde8e6;
  }

  .trusted__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Right: 2-col logo grid (3 rows) */
  .trusted__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .trusted__img-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 267 / 133;
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.07);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .trusted__img-wrap:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(43,188,176,0.12);
  }

  .trusted__img {
    width: 75%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 768px) {
    .trusted__layout { grid-template-columns: 1fr; }
    .trusted__hero-wrap { aspect-ratio: 4/3; }
    .trusted__grid { grid-template-columns: 1fr 1fr; }
  }
</style>
