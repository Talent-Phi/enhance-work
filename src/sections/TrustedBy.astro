---
const gridImages = [
  { src: '/images/clinic-1.png', alt: 'Partner clinic 1' },
  { src: '/images/clinic-2.png', alt: 'Partner clinic 2' },
  { src: '/images/clinic-3.png', alt: 'Partner clinic 3' },
  { src: '/images/clinic-4.png', alt: 'Partner clinic 4' },
  { src: '/images/clinic-5.png', alt: 'Partner clinic 5' },
  { src: '/images/clinic-6.png', alt: 'Partner clinic 6' },
];
---

<section class="trusted" id="trusted-by">
  <div class="container">
    <div class="trusted__header">
      <span class="label">Trusted by</span>
      <h2 class="h2">The clinics looking for you<br />are already here.</h2>
      <p class="trusted__sub">
        Leading practices across Florida use Enhance.work to find and hire aesthetic professionals.
      </p>
    </div>

    <!-- Clinic logo grid: 3 columns × 2 rows -->
    <div class="trusted__grid">
      {gridImages.map((img) => (
        <div class="trusted__img-wrap">
          <img src={img.src} alt={img.alt} class="trusted__img" loading="lazy" />
        </div>
      ))}
    </div>

    <!-- Testimonial card (Figma: Megan Roberts) -->
    <div class="trusted__testimonial">
      <div class="trusted__quote-icon">"</div>
      <p class="trusted__quote">
        Enhance helped me connect with a clinic that perfectly matched my skills and schedule. Within two weeks I had my first interview.
      </p>
      <div class="trusted__stars">★★★★★</div>
      <div class="trusted__author">
        <div class="trusted__avatar">KL</div>
        <div>
          <div class="trusted__author-name">Megan Roberts</div>
          <div class="trusted__author-role">Nurse Injector · Miami, FL</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trusted {
    padding: var(--section-padding);
    background: #ffffff;
  }

  .trusted__header {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 3rem;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .trusted__sub {
    color: #595959;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 560px;
  }

  /* 3-column logo grid */
  .trusted__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .trusted__img-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 267 / 133;
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.07);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .trusted__img-wrap:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(43,188,176,0.12);
  }

  .trusted__img {
    width: 75%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* Testimonial card */
  .trusted__testimonial {
    max-width: 640px;
    margin: 0 auto;
    background: #fff;
    border-radius: 16px;
    padding: 2rem 2.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .trusted__quote-icon {
    font-size: 3rem;
    color: #b2ecec;
    line-height: 1;
    font-family: Georgia, serif;
  }

  .trusted__quote {
    color: #5c6b7a;
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  .trusted__stars { color: #2abfbf; font-size: 1.1rem; letter-spacing: 0.1em; }

  .trusted__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .trusted__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #2abfbf;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .trusted__author-name { font-weight: 600; color: #1e2b38; font-size: 0.9rem; }
  .trusted__author-role { color: #9aa5b1; font-size: 0.8rem; }

  @media (max-width: 768px) {
    .trusted__grid { grid-template-columns: repeat(2, 1fr); }
    .trusted__testimonial { padding: 1.5rem; }
  }

  @media (max-width: 480px) {
    .trusted__grid { grid-template-columns: 1fr 1fr; }
  }
</style>
