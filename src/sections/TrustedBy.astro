---
const clinicImages = [
  '/images/clinic-1.png',
  '/images/clinic-2.png',
  '/images/clinic-3.png',
  '/images/clinic-4.png',
  '/images/clinic-5.png',
  '/images/clinic-6.png',
];
---

<section class="trusted" id="trusted-by">
  <div class="container">
    <span class="label trusted__label">Trusted by</span>
    <h2 class="h2">The clinics looking for you<br />are already here.</h2>
    <p class="trusted__sub">
      Leading practices across Florida use Enhance to find and hire aesthetic professionals.
    </p>

    <div class="trusted__grid">
      {clinicImages.map((src, i) => (
        <div class="trusted__img-wrap">
          <img src={src} alt={`Partner clinic ${i + 1}`} class="trusted__img" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trusted {
    padding: var(--section-padding);
    text-align: center;
  }

  .trusted__label { display: block; margin-bottom: 1rem; }

  .trusted__sub {
    margin: 1.25rem auto 3rem;
    max-width: 480px;
    color: #606362;
    font-size: 1rem;
    line-height: 1.65;
  }

  .trusted__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .trusted__img-wrap {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3/2;
    background: #e0e0e0;
  }

  .trusted__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 600px) {
    .trusted__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
