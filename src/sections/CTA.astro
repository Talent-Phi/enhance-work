---
---

<section class="cta" id="apply">
  <div class="cta__inner">
    <span class="cta__label">Ready to grow?</span>

    <h2 class="cta__headline">
      Ready to grow your career<br />
      <em>in aesthetics?</em>
    </h2>

    <p class="cta__sub">
      Join the talent network used by leading aesthetic clinics across the country.
    </p>

    <div class="cta__actions">
      <button type="button" class="btn cta__btn-primary apply-btn">Create your professional profile</button>
      <a href="#roles" class="btn cta__btn-outline">Browse opportunities</a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem;
  }

  /* Clinic bg image */
  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/images/cta-bg.png') center/cover no-repeat;
    z-index: 0;
  }

  /* Dark overlay ~65% — same tone as the image */
  .cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(28, 40, 52, 0.72);
    z-index: 1;
  }

  /* Centered single column */
  .cta__inner {
    position: relative;
    z-index: 2;
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .cta__label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #2bbcb0;
    background: rgba(43,188,176,.18);
    padding: .35rem 1rem;
    border-radius: 100px;
  }

  .cta__headline {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(1.9rem, 3vw, 2.75rem);
    line-height: 1.2;
    color: #ffffff;
    margin: 0;
  }

  .cta__headline em {
    font-style: normal;
    color: #ffffff;
  }

  .cta__sub {
    color: rgba(255,255,255,.6);
    font-size: .95rem;
    line-height: 1.65;
    max-width: 460px;
    margin: 0;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem;
    justify-content: center;
    margin-top: .25rem;
  }

  /* Primary teal button */
  .cta__btn-primary {
    background: var(--color-accent);
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: .95rem;
    font-weight: 600;
    padding: .8rem 1.75rem;
    border-radius: 53px;
    border: none;
    cursor: pointer;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .cta__btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(43,188,176,0.35);
  }

  /* White/gray outline button */
  .cta__btn-outline {
    background: rgba(255,255,255,.12);
    color: rgba(255,255,255,.85);
    font-family: var(--font-heading);
    font-size: .95rem;
    font-weight: 600;
    padding: .8rem 1.75rem;
    border-radius: 53px;
    border: 1.5px solid rgba(255,255,255,.3);
    cursor: pointer;
    transition: border-color .2s ease, color .2s ease, transform .2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .cta__btn-outline:hover {
    border-color: rgba(255,255,255,.7);
    color: #fff;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .cta { padding: 4rem 1.25rem; }
    .cta__actions { flex-direction: column; align-items: center; }
    .cta__btn-primary, .cta__btn-outline { width: 100%; max-width: 300px; justify-content: center; }
  }
</style>
