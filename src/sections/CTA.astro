---

<section class="cta" id="apply">
  <div class="cta__inner">

    <!-- Left content -->
    <div class="cta__content">
      <span class="cta__label">Ready to grow?</span>

      <h2 class="cta__headline">
        Ready to grow your career<br />
        <em>in aesthetics?</em>
      </h2>

      <p class="cta__sub">
        Join the talent network used by leading aesthetic clinics across the country.
      </p>

      <div class="cta__actions">
        <button type="button" class="btn cta__btn-primary apply-btn">Create your professional profile</button>
        <a href="#roles" class="btn cta__btn-outline">Browse opportunities</a>
      </div>
    </div>

    <!-- Right: decorative teal radial glow (Figma: radial gradient rgba(42,191,191,0.18)→transparent) -->
    <div class="cta__right" aria-hidden="true"></div>

  </div>
</section>

<style>
  .cta {
    background: #1b2936;
    padding: 5rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  /* Dark clinic photo bg image (Figma: Rectangle 1425 IMAGE fill) */
  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/images/cta-bg.png') center/cover no-repeat;
    opacity: 0.15;
    pointer-events: none;
  }

  .cta__inner {
    position: relative;
    z-index: 1;
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 3rem;
    align-items: center;
  }

  .cta__content {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .cta__label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #b2ecec;
    background: rgba(43,188,176,.15);
    padding: .3rem .9rem;
    border-radius: 100px;
    width: fit-content;
  }

  .cta__headline {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1.2;
    color: #ffffff;
    margin: 0;
  }

  .cta__headline em {
    font-style: normal;
    color: #ffffff;
  }

  .cta__sub {
    color: rgba(255,255,255,.55);
    font-size: .95rem;
    line-height: 1.65;
    max-width: 480px;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .9rem;
    margin-top: .5rem;
  }

  /* Primary button — teal */
  .cta__btn-primary {
    background: var(--color-accent);   /* #2bbcb0 */
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: .95rem;
    font-weight: 600;
    padding: .8rem 1.75rem;
    border-radius: 53px;
    border: none;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition:
      background .22s ease,
      transform .22s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow .22s ease;
  }

  .cta__btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(43,188,176,0.35);
  }

  /* Outline button — white border on dark */
  .cta__btn-outline {
    background: transparent;
    color: rgba(255,255,255,.75);
    font-family: var(--font-heading);
    font-size: .95rem;
    font-weight: 600;
    padding: .8rem 1.75rem;
    border-radius: 53px;
    border: 1.5px solid rgba(255,255,255,.25);
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition:
      border-color .22s ease,
      color .22s ease,
      transform .22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .cta__btn-outline:hover {
    border-color: rgba(255,255,255,.65);
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Right: teal radial glow decoration (Figma: GRADIENT_RADIAL teal→transparent) */
  .cta__right {
    width: 100%;
    height: 400px;
    background: radial-gradient(circle at center, rgba(42,191,191,0.18) 0%, rgba(0,0,0,0) 65%);
    border-radius: 50%;
  }

  @media (max-width: 900px) {
    .cta__inner { grid-template-columns: 1fr; }
    .cta__right { display: none; }
  }
</style>
