---

<section class="cta" id="apply">
  <div class="cta__inner">
    <span class="cta__label">Ready to grow?</span>

    <h2 class="cta__headline">
      Are you ready to launch your career in the beauty industry in South Florida?
    </h2>

    <p class="cta__sub">
      Join the talent network used by leading aesthetic clinics across the country.
    </p>

    <div class="cta__actions">
      <a href="/candidate/registration/" class="btn cta__btn-primary apply-btn">Join for free</a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    padding: 9rem 1.5rem;
  }

  /* Clinic bg image */
  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('/images/cta-bg.jpg') center 65%/cover no-repeat;
    z-index: 0;
  }

  /* Dark overlay */
  .cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(28, 40, 52, 0.72);
    z-index: 1;
  }

  /* Centered single column */
  .cta__inner {
    position: relative;
    z-index: 2;
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  /* Glassmorphism label pill */
  .cta__label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #ffffff;
    background: rgba(43,188,176,.22);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(43,188,176,.45);
    padding: .38rem 1.1rem;
    border-radius: 100px;
  }

  .cta__headline {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    color: #ffffff;
    margin: 0;
  }

  .cta__sub {
    color: rgba(255,255,255,.75);
    font-size: 1rem;
    line-height: 1.65;
    max-width: 480px;
    margin: 0;
  }

  .cta__actions {
    display: flex;
    justify-content: center;
    margin-top: .5rem;
  }

  /* Wide glassmorphism teal button */
  .cta__btn-primary {
    background: rgba(43,188,176,.75);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    padding: .9rem 4rem;
    border-radius: 53px;
    border: 1px solid rgba(43,188,176,.6);
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    min-width: 260px;
    text-align: center;
    transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
  }
  .cta__btn-primary:hover {
    background: rgba(43,188,176,.9);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(43,188,176,0.4);
  }

  @media (max-width: 600px) {
    .cta { padding: 5rem 1.25rem; }
    .cta__btn-primary {
      width: 100%;
      min-width: unset;
      padding: .9rem 2rem;
    }
  }
</style>
