---
// StatCard — Figma Frame 6 exact values
// Numbers: Syne Bold 60px, color #F0F5F3 (on dark) or #0f1a17 (light)
// Label: Poppins Regular 20px, opacity 30% (dark) or #606362 (light)
interface Props {
  value: string;
  suffix?: string;
  label: string;
  dark?: boolean;
}
const { value, suffix = '', label, dark = false } = Astro.props;
---

<div class:list={['stat', { 'stat--dark': dark }]}>
  <p class="stat__value">{value}<span class="stat__suffix">{suffix}</span></p>
  <p class="stat__label">{label}</p>
</div>

<style>
  .stat { display: flex; flex-direction: column; gap: .2rem; }

  /* Light variant (hero section) */
  .stat__value {
    font-family: 'Syne', sans-serif;
    font-size: 3.75rem; /* 60px */
    font-weight: 700;
    line-height: 1;
    color: #404040;
  }

  .stat__suffix { color: var(--color-accent); }

  .stat__label {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: #606362;
  }

  /* Dark variant (CTA section) */
  .stat--dark .stat__value  { color: #f0f5f3; }
  .stat--dark .stat__label  { color: rgba(240,245,243,.35); }
</style>
