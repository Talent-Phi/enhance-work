<script>
(function() {
  const form    = document.getElementById('apply-modal');
  const steps   = Array.from(document.querySelectorAll('.ew-step'));
  const segs    = Array.from(document.querySelectorAll('.ew-seg'));
  const nextBtn = document.getElementById('ew-next');
  const backBtn = document.getElementById('ew-back');
  const cancelBtn = document.getElementById('ew-cancel');
  const stepLabel = document.getElementById('ew-step-label');
  const total = 6;
  let current = 1;

  function showStep(n) {
    steps.forEach(s => s.hidden = parseInt(s.dataset.step) !== n);
    segs.forEach((seg, i) => seg.classList.toggle('active', i < n));
    stepLabel.textContent = `STEP ${n} / ${total}`;
    backBtn.hidden = n === 1;
    nextBtn.textContent = n === total ? 'Finish' : 'Continue';
    current = n;
    form.scrollTop = 0;
  }

  function open() {
    form.hidden = false;
    showStep(1);
    document.body.style.overflow = 'hidden';
  }

  function close() {
    form.hidden = true;
    document.body.style.overflow = '';
  }

  // Open on any .apply-btn
  document.addEventListener('click', e => {
    if (e.target.closest('.apply-btn')) open();
  });

  cancelBtn.addEventListener('click', close);

  nextBtn.addEventListener('click', () => {
    if (current < total) showStep(current + 1);
    else { console.log('Form submitted'); close(); }
  });

  backBtn.addEventListener('click', () => {
    if (current > 1) showStep(current - 1);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !form.hidden) close();
  });

  // Skills (Enter key)
  const skillInput = document.getElementById('ew-skill-input');
  const skillChips = document.getElementById('ew-skill-chips');
  if (skillInput) {
    skillInput.addEventListener('keydown', e => {
      if (e.key === 'Enter' && skillInput.value.trim()) {
        e.preventDefault();
        const val = skillInput.value.trim();
        const chip = document.createElement('div');
        chip.className = 'ew-skill-tag';
        chip.innerHTML = `<span>${val}</span><button type="button" aria-label="Remove">×</button>`;
        chip.querySelector('button').addEventListener('click', () => chip.remove());
        skillChips.appendChild(chip);
        skillInput.value = '';
      }
    });
    // clicking the container focuses input
    document.getElementById('ew-skills-row')?.addEventListener('click', () => skillInput.focus());
  }

  // Clear licenses
  document.getElementById('ew-clear-licenses')?.addEventListener('click', () => {
    document.querySelectorAll('input[name="license"]').forEach(cb => cb.checked = false);
  });

  // Add license toggle
  document.getElementById('ew-add-license-btn')?.addEventListener('click', () => {
    const extra = document.getElementById('ew-license-extra');
    if (extra) { extra.hidden = !extra.hidden; if (!extra.hidden) extra.querySelector('input').focus(); }
  });

  // Add language toggle
  document.getElementById('ew-add-lang')?.addEventListener('click', () => {
    const extra = document.getElementById('ew-extra-lang');
    if (extra) { extra.hidden = !extra.hidden; if (!extra.hidden) extra.querySelector('input').focus(); }
  });

  // Toggle injector message
  document.getElementById('ew-toggle-msg')?.addEventListener('click', function() {
    const c = document.getElementById('ew-msg-content');
    if (c) { c.hidden = !c.hidden; this.textContent = c.hidden ? 'Click to read' : 'Hide'; }
  });

  // Resume label
  const resumeFile = document.getElementById('ew-resume-file');
  const resumeLabel = document.getElementById('ew-resume-label');
  resumeFile?.addEventListener('change', () => {
    if (resumeLabel) resumeLabel.textContent = resumeFile.files[0]?.name || 'Attatch Resume';
  });
})();
</script>
