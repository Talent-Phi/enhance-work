---
// ApplyModal.astro — 6-step application form
// Triggered by .apply-btn clicks anywhere on the page
---

<div id="apply-modal" class="modal" role="dialog" aria-modal="true" aria-label="Apply to Enhance.work" hidden>

  <div class="modal__panel">

    <!-- Header: logo + close -->
    <div class="modal__header">
      <div class="modal__logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="14" cy="14" r="14" fill="#2bbcb0"/>
          <path d="M8 14h12M14 8v12" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <span>enhance.work</span>
      </div>
      <button class="modal__close" id="modal-cancel" aria-label="Close">×</button>
    </div>

    <!-- Progress bar (6 steps) -->
    <div class="modal__progress" aria-hidden="true">
      <div class="progress__track">
        <div class="progress__bar" id="modal-progress-bar" style="width:16.66%"></div>
      </div>
      <span class="progress__label" id="modal-step-label">STEP 1 / 6</span>
    </div>

    <!-- Steps container -->
    <div class="modal__steps">

      <!-- ── STEP 1: Role ── -->
      <div class="modal__step" data-step="1">
        <h2 class="step__title">What role are you looking for?</h2>
        <p class="step__subtitle">Select all that apply</p>
        <p class="step__field-label">Select Position*</p>
        <div class="role-grid">
          <label class="role-chip"><input type="checkbox" name="role" value="aesthetic_provider"><span>Aesthetic Provider</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="patient_coordinator"><span>Patient Coordinator</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="medical_director"><span>Medical Director</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="sales_associate"><span>Sales Associate</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="medical_esthetician"><span>Medical Esthetician</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="marketing"><span>Marketing</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="laser_technician"><span>Laser Technician</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="practice_manager"><span>Practice Manager</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="body_technician"><span>Body Technician</span></label>
          <label class="role-chip"><input type="checkbox" name="role" value="medical_assistant"><span>Medical Assistant</span></label>
        </div>
      </div>

      <!-- ── STEP 2: Personal Info ── -->
      <div class="modal__step" data-step="2" hidden>
        <h2 class="step__title">Help us get in touch with you.</h2>
        <p class="step__subtitle">Personal information</p>
        <p class="step__hint">(This information is only used to verify your legal availability to work)</p>
        <div class="form-grid form-grid--2">
          <div class="form-field">
            <label>First name*</label>
            <input type="text" name="first_name" placeholder="Leo" autocomplete="given-name">
          </div>
          <div class="form-field">
            <label>Last name*</label>
            <input type="text" name="last_name" placeholder="Gibson" autocomplete="family-name">
          </div>
          <div class="form-field">
            <label>Email*</label>
            <input type="email" name="email" placeholder="l_gibson857@gmail.com" autocomplete="email">
          </div>
          <div class="form-field">
            <label>Phone number*</label>
            <input type="tel" name="phone" placeholder="+1 000 000 0000" autocomplete="tel">
          </div>
          <div class="form-field">
            <label>Date of birth*</label>
            <div class="dob-row">
              <select name="dob_month"><option value="">Month</option>
                <option>January</option><option>February</option><option>March</option>
                <option>April</option><option>May</option><option>June</option>
                <option>July</option><option>August</option><option>September</option>
                <option>October</option><option>November</option><option>December</option>
              </select>
              <select name="dob_day"><option value="">Day</option>
                <!-- JS fills 1-31 -->
              </select>
              <select name="dob_year"><option value="">Year</option>
                <!-- JS fills years -->
              </select>
            </div>
          </div>
          <div class="form-field">
            <label>Gender*</label>
            <select name="gender">
              <option value="">Select gender</option>
              <option>Male</option>
              <option>Female</option>
              <option>Non-binary</option>
              <option>Prefer not to say</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ── STEP 3: Location ── -->
      <div class="modal__step" data-step="3" hidden>
        <h2 class="step__title">Where are you located?</h2>
        <p class="step__subtitle">Your address details</p>
        <div class="form-grid form-grid--1">
          <div class="form-field">
            <label>Address*</label>
            <input type="text" name="address1" placeholder="Line 1" autocomplete="address-line1">
          </div>
          <div class="form-field">
            <input type="text" name="address2" placeholder="Line 2 (optional)" autocomplete="address-line2">
          </div>
        </div>
        <div class="form-grid form-grid--3">
          <div class="form-field">
            <label>State*</label>
            <select name="state">
              <option value="">Florida</option>
              <option>Alabama</option><option>Alaska</option><option>Arizona</option>
              <option>Arkansas</option><option>California</option><option>Colorado</option>
              <option>Connecticut</option><option>Delaware</option><option selected>Florida</option>
              <option>Georgia</option><option>Hawaii</option><option>Idaho</option>
              <option>Illinois</option><option>Indiana</option><option>Iowa</option>
              <option>Kansas</option><option>Kentucky</option><option>Louisiana</option>
              <option>Maine</option><option>Maryland</option><option>Massachusetts</option>
              <option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
              <option>Missouri</option><option>Montana</option><option>Nebraska</option>
              <option>Nevada</option><option>New Hampshire</option><option>New Jersey</option>
              <option>New Mexico</option><option>New York</option><option>North Carolina</option>
              <option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
              <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option>
              <option>South Carolina</option><option>South Dakota</option><option>Tennessee</option>
              <option>Texas</option><option>Utah</option><option>Vermont</option>
              <option>Virginia</option><option>Washington</option><option>West Virginia</option>
              <option>Wisconsin</option><option>Wyoming</option>
            </select>
          </div>
          <div class="form-field">
            <label>City*</label>
            <input type="text" name="city" placeholder="Miami" autocomplete="address-level2">
          </div>
          <div class="form-field">
            <label>Zip code*</label>
            <input type="text" name="zip" placeholder="00000" autocomplete="postal-code" maxlength="10">
          </div>
        </div>
      </div>

      <!-- ── STEP 4: Competences ── -->
      <div class="modal__step" data-step="4" hidden>
        <h2 class="step__title">Competences</h2>
        <p class="step__subtitle">Languages and licenses you hold</p>

        <div class="form-grid form-grid--2" style="margin-bottom:1.5rem">
          <div class="form-field">
            <label>Languages</label>
            <select name="language">
              <option value="">Select</option>
              <option>English</option><option>Spanish</option><option>French</option>
              <option>Portuguese</option><option>Mandarin</option><option>Other</option>
            </select>
          </div>
          <div class="form-field">
            <label>&nbsp;</label>
            <select name="language_level">
              <option value="">Level</option>
              <option>Basic</option><option>Conversational</option>
              <option>Fluent</option><option>Native</option>
            </select>
          </div>
        </div>

        <div class="form-field" style="margin-bottom:0.5rem">
          <label>Licenses you hold</label>
          <button type="button" class="link-btn" id="clear-licenses">Clear All</button>
        </div>
        <div class="license-grid">
          <label class="license-chip"><input type="checkbox" name="license" value="md_do"><span>M.D. / D.O.</span></label>
          <label class="license-chip"><input type="checkbox" name="license" value="np"><span>N.P.</span></label>
          <label class="license-chip"><input type="checkbox" name="license" value="pa"><span>P.A.</span></label>
          <label class="license-chip"><input type="checkbox" name="license" value="electrologist"><span>Electrologist</span></label>
          <label class="license-chip"><input type="checkbox" name="license" value="cosmetologist"><span>Cosmetologist</span></label>
          <label class="license-chip"><input type="checkbox" name="license" value="phlebotomist"><span>Phlebotomist</span></label>
          <label class="license-chip"><input type="checkbox" name="license" value="medical_assistant"><span>Medical Assistant</span></label>
        </div>
        <button type="button" class="add-btn" id="add-license-btn">
          <span class="add-btn__icon">+</span> Add something else.
        </button>
        <div id="add-license-extra" hidden style="margin-top:0.75rem">
          <input type="text" name="license_other" placeholder="Enter license or certification" style="width:100%">
        </div>
      </div>

      <!-- ── STEP 5: Experience ── -->
      <div class="modal__step" data-step="5" hidden>
        <h2 class="step__title">What is your Medical Aesthetics experience?</h2>
        <p class="step__subtitle">Tell us about your background</p>

        <div class="form-grid form-grid--2">
          <div class="form-field">
            <label>Years of experience*</label>
            <select name="years_experience">
              <option value="">Years</option>
              <option>Less than 1</option><option>1</option><option>2</option>
              <option>3</option><option>4</option><option>5+</option><option>10+</option>
            </select>
          </div>
          <div class="form-field">
            <label>When are you looking to start working?*</label>
            <div class="btn-group">
              <label class="option-chip"><input type="radio" name="start_date" value="asap"><span>ASAP</span></label>
              <label class="option-chip"><input type="radio" name="start_date" value="2_4_weeks"><span>2 - 4 Weeks</span></label>
              <label class="option-chip"><input type="radio" name="start_date" value="over_4_weeks"><span>Over 4 Weeks</span></label>
            </div>
          </div>
        </div>

        <div class="form-field" style="margin-top:1.25rem">
          <label>If you see fit, list some of your skills relevant to Aesthetics</label>
          <div class="skills-input-row">
            <div id="skills-chips"></div>
            <input type="text" id="skill-input" placeholder="| Skill" autocomplete="off">
          </div>
        </div>

        <div class="form-field" style="margin-top:1.25rem">
          <label>Are you currently employed?</label>
          <div class="radio-row">
            <label class="radio-opt"><input type="radio" name="employed" value="yes"><span>Yes</span></label>
            <label class="radio-opt"><input type="radio" name="employed" value="no"><span>No</span></label>
          </div>
        </div>
      </div>

      <!-- ── STEP 6: Compensation ── -->
      <div class="modal__step" data-step="6" hidden>
        <h2 class="step__title">What are your compensation expectations?</h2>
        <p class="step__subtitle">Final step — almost there</p>

        <div class="form-grid form-grid--2">
          <div class="form-field">
            <label>Salary expectations*</label>
            <input type="text" name="salary" placeholder="$0.00 USD">
          </div>
          <div class="form-field">
            <label>&nbsp;</label>
            <select name="pay_type">
              <option>Hourly</option>
              <option>Annual</option>
              <option>Per procedure</option>
              <option>Commission</option>
            </select>
          </div>
        </div>

        <div class="resume-upload" id="resume-upload">
          <input type="file" name="resume" id="resume-file" accept=".pdf,.doc,.docx" hidden>
          <label for="resume-file" class="resume-upload__label">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 5v10M7 10l5-5 5 5" stroke="#2bbcb0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 19h14" stroke="#2bbcb0" stroke-width="2" stroke-linecap="round"/></svg>
            <span id="resume-label-text">Attach Resume</span>
          </label>
        </div>

        <div class="message-box">
          <div class="message-box__header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#555" stroke-width="1.5"/><path d="M12 8v4M12 16h.01" stroke="#555" stroke-width="2" stroke-linecap="round"/></svg>
            <strong>Important message to New Injectors</strong>
            <button type="button" class="link-btn" id="toggle-message">Click to read</button>
          </div>
          <div id="message-content" hidden>
            <p>Before joining the platform, new injectors must provide proof of supervision or collaborative agreement with a licensed Medical Director. Make sure to upload your documentation or note it in your resume.</p>
          </div>
        </div>

        <div class="checkbox-row">
          <label class="checkbox-opt">
            <input type="checkbox" name="terms" required>
            <span>Agree terms and conditions.</span>
          </label>
          <label class="checkbox-opt">
            <input type="checkbox" name="injector_msg">
            <span>I've read New Injector's message.</span>
          </label>
        </div>

        <p class="recaptcha-notice">This site is protected by reCAPTCHA and the Google <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a> and <a href="https://policies.google.com/terms" target="_blank" rel="noopener">Terms of Service</a> apply.</p>
      </div>

    </div><!-- /.modal__steps -->

    <!-- Footer: action buttons -->
    <div class="modal__footer">
      <button type="button" class="btn btn--ghost" id="modal-back" hidden>← Back</button>
      <div class="modal__footer-right">
        <button type="button" class="btn btn--ghost" id="modal-cancel-2">Cancel</button>
        <button type="button" class="btn btn--primary" id="modal-next">Continue</button>
      </div>
    </div>

  </div><!-- /.modal__panel -->
</div><!-- /#apply-modal -->

<style>
/* ── Fullscreen overlay ── */
.modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  background: #fff;
  overflow-y: auto;
}
.modal[hidden] { display: none !important; }

/* ── Panel — full viewport ── */
.modal__panel {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  width: 100%;
  max-width: 860px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* ── Header ── */
.modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem 1.75rem 0;
}
.modal__logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: #18232c;
}
.modal__close {
  background: none;
  border: none;
  font-size: 1.75rem;
  line-height: 1;
  cursor: pointer;
  color: #888;
  padding: 0.25rem 0.5rem;
  border-radius: 6px;
  transition: background 0.15s;
}
.modal__close:hover { background: #f2f2f2; }

/* ── Progress ── */
.modal__progress {
  padding: 1.25rem 1.75rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.progress__track {
  width: 100%;
  height: 4px;
  background: #e8e8e8;
  border-radius: 4px;
  overflow: hidden;
}
.progress__bar {
  height: 100%;
  background: #2bbcb0;
  border-radius: 4px;
  transition: width 0.35s ease;
}
.progress__label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: #bbb;
  font-family: var(--font-body);
  text-transform: uppercase;
}

/* ── Steps ── */
.modal__steps {
  padding: 1.5rem 1.75rem;
  flex: 1;
}
.step__title {
  font-family: var(--font-heading);
  font-size: 1.35rem;
  font-weight: 600;
  color: #363636;
  margin-bottom: 0.3rem;
  line-height: 1.3;
}
.step__subtitle {
  font-size: 0.88rem;
  color: #7a7a7a;
  margin-bottom: 0.25rem;
}
.step__hint {
  font-size: 0.78rem;
  color: #bbb;
  margin-bottom: 1.25rem;
}
.step__field-label {
  font-size: 0.82rem;
  color: #7a7a7a;
  margin-bottom: 0.75rem;
}

/* ── Role chips ── */
.role-grid, .license-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 0.5rem;
  margin-top: 0.5rem;
}
.role-chip, .license-chip {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.55rem 0.9rem;
  border: 1.5px solid #e5e5e5;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.85rem;
  color: #1a1c1b;
  background: #fff;
  transition: border-color 0.15s, background 0.15s;
  user-select: none;
}
.role-chip input, .license-chip input { display: none; }
.role-chip:has(input:checked), .license-chip:has(input:checked) {
  border-color: #2bbcb0;
  background: #f0fbfa;
  color: #2bbcb0;
  font-weight: 500;
}
.role-chip:hover, .license-chip:hover { border-color: #2bbcb0; }

/* ── Forms ── */
.form-grid { display: grid; gap: 1rem; }
.form-grid--1 { grid-template-columns: 1fr; }
.form-grid--2 { grid-template-columns: 1fr 1fr; }
.form-grid--3 { grid-template-columns: 1fr 1fr 1fr; }

.form-field {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.form-field label {
  font-size: 0.82rem;
  font-weight: 500;
  color: #333;
  font-family: var(--font-body);
}
.form-field input,
.form-field select {
  padding: 0.6rem 0.85rem;
  border: 1.5px solid #e5e5e5;
  border-radius: 8px;
  font-size: 0.88rem;
  color: #bbb;
  background: #fff;
  outline: none;
  font-family: var(--font-body);
  transition: border-color 0.15s;
  appearance: none;
  -webkit-appearance: none;
}
.form-field input:focus,
.form-field select:focus { border-color: #2bbcb0; color: #333; }
.form-field input::placeholder { color: #bbb; }

.dob-row {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1.2fr;
  gap: 0.5rem;
}
.dob-row select { color: #bbb; }

/* ── Option chips (radio-style) ── */
.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 0.4rem;
}
.option-chip {
  display: flex;
  align-items: center;
  padding: 0.45rem 0.9rem;
  border: 1.5px solid #e5e5e5;
  border-radius: 20px;
  cursor: pointer;
  font-size: 0.83rem;
  color: #333;
  background: #fff;
  transition: border-color 0.15s, background 0.15s;
  user-select: none;
}
.option-chip input { display: none; }
.option-chip:has(input:checked) {
  border-color: #2bbcb0;
  background: #f0fbfa;
  color: #2bbcb0;
  font-weight: 500;
}
.option-chip:hover { border-color: #2bbcb0; }

/* ── Radio opts ── */
.radio-row { display: flex; gap: 1.5rem; margin-top: 0.5rem; }
.radio-opt {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  cursor: pointer;
  font-size: 0.88rem;
  color: #333;
}
.radio-opt input[type="radio"] {
  width: 18px; height: 18px;
  accent-color: #2bbcb0;
}

/* ── Skills input ── */
.skills-input-row {
  border: 1.5px solid #e5e5e5;
  border-radius: 8px;
  padding: 0.5rem 0.75rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  align-items: center;
  min-height: 44px;
}
.skills-input-row:focus-within { border-color: #2bbcb0; }
#skill-input {
  border: none;
  outline: none;
  font-size: 0.85rem;
  color: #2bbcb0;
  flex: 1;
  min-width: 100px;
  padding: 0;
}
.skill-tag {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.25rem 0.6rem;
  background: #d1f5f1;
  color: #0faa82;
  border-radius: 6px;
  font-size: 0.8rem;
  font-weight: 500;
}
.skill-tag__remove {
  background: none;
  border: none;
  color: #0faa82;
  cursor: pointer;
  font-size: 1rem;
  line-height: 1;
  padding: 0;
}

/* ── Add / link buttons ── */
.add-btn {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  background: none;
  border: none;
  color: #2bbcb0;
  font-size: 0.88rem;
  cursor: pointer;
  padding: 0.6rem 0;
  font-family: var(--font-body);
}
.add-btn:hover { text-decoration: underline; }
.link-btn {
  background: none;
  border: none;
  color: #2bbcb0;
  font-size: 0.8rem;
  cursor: pointer;
  padding: 0;
  font-family: var(--font-body);
}
.link-btn:hover { text-decoration: underline; }

/* ── Resume upload ── */
.resume-upload {
  margin-top: 1.25rem;
  margin-bottom: 1.25rem;
}
.resume-upload__label {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border: 1.5px solid #2bbcb0;
  border-radius: 8px;
  padding: 0.6rem 1.1rem;
  color: #2bbcb0;
  font-size: 0.88rem;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.15s;
}
.resume-upload__label:hover { background: #f0fbfa; }

/* ── Message box ── */
.message-box {
  border: 1.5px solid #e5e5e5;
  border-radius: 10px;
  padding: 0.85rem 1rem;
  margin-bottom: 1rem;
  background: #fafafa;
}
.message-box__header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.message-box__header strong {
  flex: 1;
  font-size: 0.88rem;
  color: #333;
}
#message-content {
  margin-top: 0.6rem;
  font-size: 0.83rem;
  color: #666;
  line-height: 1.5;
}

/* ── Checkboxes ── */
.checkbox-row {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  margin-bottom: 1rem;
}
.checkbox-opt {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.88rem;
  color: #333;
  cursor: pointer;
}
.checkbox-opt input[type="checkbox"] {
  width: 18px; height: 18px;
  accent-color: #2bbcb0;
  flex-shrink: 0;
}

/* ── reCAPTCHA notice ── */
.recaptcha-notice {
  font-size: 0.72rem;
  color: #aaa;
  line-height: 1.4;
  margin-bottom: 0.5rem;
}
.recaptcha-notice a { color: #2bbcb0; text-decoration: none; }
.recaptcha-notice a:hover { text-decoration: underline; }

/* ── Footer ── */
.modal__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.75rem 1.5rem;
  border-top: 1px solid #f0f0f0;
  gap: 0.75rem;
}
.modal__footer-right {
  display: flex;
  gap: 0.75rem;
  margin-left: auto;
}
.btn {
  padding: 0.65rem 1.5rem;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  border: none;
  font-family: var(--font-body);
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.btn--primary {
  background: #2bbcb0;
  color: #fff;
}
.btn--primary:hover { background: #22a89d; }
.btn--ghost {
  background: #fff;
  color: #444;
  border: 1.5px solid #e5e5e5;
}
.btn--ghost:hover { border-color: #bbb; }

/* ── Mobile ── */
@media (max-width: 600px) {
  .modal__panel { padding: 0 1rem; }
  .modal__header,
  .modal__progress,
  .modal__steps { padding-left: 0; padding-right: 0; }
  .modal__footer { padding: 0.85rem 0 1.25rem; }

  .form-grid--2,
  .form-grid--3 { grid-template-columns: 1fr; }

  .role-grid, .license-grid {
    grid-template-columns: 1fr 1fr;
  }

  .dob-row { grid-template-columns: 1fr 1fr 1fr; }

  .step__title { font-size: 1.15rem; }
}
</style>

<script>
(function() {
  const modal      = document.getElementById('apply-modal');
  const steps      = Array.from(document.querySelectorAll('.modal__step'));
  const nextBtn    = document.getElementById('modal-next');
  const backBtn    = document.getElementById('modal-back');
  const cancelBtns = document.querySelectorAll('#modal-cancel, #modal-cancel-2');
  const progressBar = document.getElementById('modal-progress-bar');
  const stepLabel  = document.getElementById('modal-step-label');
  const totalSteps = 6;
  let current = 1;

  function showStep(n) {
    steps.forEach(s => {
      const sn = parseInt(s.dataset.step);
      s.hidden = sn !== n;
    });
    // Progress
    progressBar.style.width = ((n / totalSteps) * 100) + '%';
    stepLabel.textContent = 'STEP ' + n + ' / ' + totalSteps;
    // Buttons
    backBtn.hidden = n === 1;
    nextBtn.textContent = n === totalSteps ? 'Finish' : 'Continue';
    current = n;
  }

  function openModal() {
    modal.hidden = false;
    showStep(1);
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  // Open on any .apply-btn click
  document.addEventListener('click', e => {
    if (e.target.closest('.apply-btn')) openModal();
  });

  // Cancel buttons
  cancelBtns.forEach(btn => btn.addEventListener('click', closeModal));

  // Navigation
  nextBtn.addEventListener('click', () => {
    if (current < totalSteps) {
      showStep(current + 1);
    } else {
      // Submit
      console.log('Form submitted');
      closeModal();
    }
  });

  backBtn.addEventListener('click', () => {
    if (current > 1) showStep(current - 1);
  });

  // Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  // DOB: fill day/year dropdowns
  const dobDay  = document.querySelector('select[name="dob_day"]');
  const dobYear = document.querySelector('select[name="dob_year"]');
  if (dobDay) {
    for (let d = 1; d <= 31; d++) {
      const o = document.createElement('option');
      o.value = d; o.textContent = d;
      dobDay.appendChild(o);
    }
  }
  if (dobYear) {
    const now = new Date().getFullYear();
    for (let y = now - 18; y >= now - 80; y--) {
      const o = document.createElement('option');
      o.value = y; o.textContent = y;
      dobYear.appendChild(o);
    }
  }

  // Skills input (Enter to add chip)
  const skillInput = document.getElementById('skill-input');
  const skillsChips = document.getElementById('skills-chips');
  if (skillInput) {
    skillInput.addEventListener('keydown', e => {
      if ((e.key === 'Enter' || e.key === ',') && skillInput.value.trim()) {
        e.preventDefault();
        const val = skillInput.value.trim().replace(/,$/, '');
        if (!val) return;
        const chip = document.createElement('div');
        chip.className = 'skill-tag';
        chip.innerHTML = `<span>${val}</span><button class="skill-tag__remove" type="button" aria-label="Remove ${val}">×</button>`;
        chip.querySelector('.skill-tag__remove').addEventListener('click', () => chip.remove());
        skillsChips.appendChild(chip);
        skillInput.value = '';
      }
    });
  }

  // Clear licenses
  const clearLicenses = document.getElementById('clear-licenses');
  if (clearLicenses) {
    clearLicenses.addEventListener('click', () => {
      document.querySelectorAll('input[name="license"]').forEach(cb => cb.checked = false);
    });
  }

  // Add license toggle
  const addLicenseBtn = document.getElementById('add-license-btn');
  const addLicenseExtra = document.getElementById('add-license-extra');
  if (addLicenseBtn) {
    addLicenseBtn.addEventListener('click', () => {
      addLicenseExtra.hidden = !addLicenseExtra.hidden;
      if (!addLicenseExtra.hidden) addLicenseExtra.querySelector('input').focus();
    });
  }

  // Toggle injector message
  const toggleMsg = document.getElementById('toggle-message');
  const msgContent = document.getElementById('message-content');
  if (toggleMsg) {
    toggleMsg.addEventListener('click', () => {
      msgContent.hidden = !msgContent.hidden;
      toggleMsg.textContent = msgContent.hidden ? 'Click to read' : 'Hide';
    });
  }

  // Resume file label
  const resumeFile = document.getElementById('resume-file');
  const resumeLabelText = document.getElementById('resume-label-text');
  if (resumeFile) {
    resumeFile.addEventListener('change', () => {
      resumeLabelText.textContent = resumeFile.files[0]?.name || 'Attach Resume';
    });
  }
})();
</script>
