---
// Nav — transparent on load, solid on scroll
---

<nav class="nav" id="main-nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <img src="/images/logo.png" alt="enhance.work logo" class="nav__logo-img" />
    </a>

    <a href="/candidate/registration/" class="btn btn-primary nav__cta">APPLY</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    /* start transparent */
    background: transparent;
    border-bottom: 1px solid transparent;
    padding: 0 141px;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  /* solid state when scrolled */
  .nav.scrolled {
    background: #ffffff;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .nav__logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* Nav APPLY button — Figma: r=23, teal */
  .nav__cta {
    font-family: var(--font-heading);
    font-size: .875rem;
    font-weight: 600;
    letter-spacing: .02em;
    padding: .45rem 1.25rem;
    border-radius: 23px;
    background: var(--color-accent);
    color: #ffffff;
    border: none;
    transition: background .2s ease, transform .2s ease;
  }

  .nav__cta:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .nav { padding: 0 1.25rem; }
  }
</style>

<script>
  const nav = document.getElementById('main-nav');
  function updateNav() {
    if (window.scrollY > 10) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav(); // run on load
</script>
