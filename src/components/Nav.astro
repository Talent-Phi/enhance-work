---
// Nav — from Frame 6 Figma
---

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      <span class="nav__logo-text">enhance<span class="nav__logo-dot">.</span>work</span>
    </a>

    <ul class="nav__links">
      <li><a href="#how-it-works">How it works</a></li>
      <li><a href="#roles">Roles</a></li>
      <li><a href="#why-join">Why join</a></li>
      <li><a href="#trusted-by">Clinics</a></li>
    </ul>

    <a href="#apply" class="btn btn-primary nav__cta">Apply now</a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 2rem;
  }

  .nav__logo-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .nav__logo-dot { color: var(--color-accent); }

  .nav__links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0 auto;
  }

  .nav__links a {
    font-size: .9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color .15s;
  }

  .nav__links a:hover { color: var(--color-accent); }

  .nav__cta { font-size: .875rem; padding: .6rem 1.25rem; }

  @media (max-width: 768px) {
    .nav__links { display: none; }
  }
</style>
