---
// Nav — Figma Frame 6: logo left (x=141) + APPLY button right (x=1232)
---

<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <img src="/images/logo.png" alt="enhance.work logo" class="nav__logo-img" />
    </a>

    <a href="#apply" class="btn btn-primary nav__cta">APPLY</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
    padding: 0 141px;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .nav__logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  .nav__cta {
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .08em;
    padding: .5rem 1.4rem;
    border-radius: 6px;
  }

  @media (max-width: 768px) {
    .nav { padding: 0 1.25rem; }
  }
</style>
