---
// Nav — Figma Frame 6: logo left (x=141) + APPLY button right (x=1232)
---

<nav class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <img src="/logo-placeholder.svg" alt="enhance.work" class="nav__logo-img" />
      <span class="nav__logo-text">enhance<span class="nav__logo-accent">.</span>work</span>
    </a>

    <a href="#apply" class="btn btn-primary nav__cta">APPLY</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
    padding: 0 141px;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .nav__logo-img { display: none; /* swap with real logo SVG */ }

  .nav__logo-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -.01em;
  }

  .nav__logo-accent { color: var(--color-accent); }

  .nav__cta {
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .08em;
    padding: .5rem 1.4rem;
    border-radius: 6px;
  }

  @media (max-width: 768px) {
    .nav { padding: 0 1.25rem; }
  }
</style>
