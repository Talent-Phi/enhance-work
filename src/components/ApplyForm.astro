---
// ApplyForm.astro — standalone page version of the application form
// Served at /candidate/registration/
---

<main class="ew-form ew-form--page" id="apply-modal">

  <!-- Logo above card (same as navbar) -->
  <div class="ew-form__logo-wrap">
    <img src="/images/logo.png" alt="enhance.work" class="ew-form__logo-img">
  </div>

  <!-- Card -->
  <div class="ew-form__card">

    <!-- Progress bar row -->
    <div class="ew-form__progress-row">
      <button class="ew-back-btn" id="ew-back" aria-label="Go back" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="ew-segments" aria-hidden="true">
        <div class="ew-seg" data-seg="1"></div>
        <div class="ew-seg" data-seg="2"></div>
        <div class="ew-seg" data-seg="3"></div>
        <div class="ew-seg" data-seg="4"></div>
        <div class="ew-seg" data-seg="5"></div>
        <div class="ew-seg" data-seg="6"></div>
      </div>
      <span class="ew-step-label" id="ew-step-label">STEP 1 / 6</span>
    </div>

    <!-- Steps -->
    <div class="ew-form__body">

      <!-- ── STEP 1 ── -->
      <div class="ew-step" data-step="1">
        <h2 class="ew-title">What role are you looking for?</h2>
        <hr class="ew-divider">
        <div class="ew-role-grid ew-role-grid--main">
          <label class="ew-role-card">
            <input type="radio" name="role" value="aesthetic_provider">
            <div class="ew-role-card__img"><img src="/images/form/role-aesthetic-provider.jpg" alt="Aesthetic Provider"></div>
            <span>Aesthetic Provider</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="medical_director">
            <div class="ew-role-card__img"><img src="/images/form/role-medical-director.jpg" alt="Medical Director"></div>
            <span>Medical Director</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="medical_esthetician">
            <div class="ew-role-card__img"><img src="/images/form/role-medical-esthetician.jpg" alt="Medical Esthetician"></div>
            <span>Medical Esthetician</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="laser_technician">
            <div class="ew-role-card__img"><img src="/images/form/role-laser-technician.jpg" alt="Laser Technician"></div>
            <span>Laser Technician</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="body_technician">
            <div class="ew-role-card__img"><img src="/images/form/role-body-technician.jpg" alt="Body Technician"></div>
            <span>Body Technician</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="patient_coordinator">
            <div class="ew-role-card__img"><img src="/images/form/role-patient-coordinator.jpg" alt="Patient Coordinator"></div>
            <span>Patient Coordinator</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="sales_associate">
            <div class="ew-role-card__img"><img src="/images/form/role-sales-associate.jpg" alt="Sales Associate"></div>
            <span>Sales Associate</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="marketing">
            <div class="ew-role-card__img"><img src="/images/form/role-marketing.jpg" alt="Marketing"></div>
            <span>Marketing</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="practice_manager">
            <div class="ew-role-card__img"><img src="/images/form/role-practice-manager.jpg" alt="Practice Manager"></div>
            <span>Practice Manager</span>
          </label>
          <label class="ew-role-card">
            <input type="radio" name="role" value="medical_assistant">
            <div class="ew-role-card__img"><img src="/images/form/role-medical-assistant.jpg" alt="Medical Assistant"></div>
            <span>Medical Assistant</span>
          </label>
        </div>
      </div>

      <!-- ── STEP 2 ── -->
      <div class="ew-step" data-step="2" hidden>
        <h2 class="ew-title">Help us get in touch with you.</h2>
        <p class="ew-subtitle">Personal information</p>
        <hr class="ew-divider">
        <div class="ew-step-content">
        <div class="ew-grid-3">
          <div class="ew-field">
            <label>First name<span class="req">*</span></label>
            <input type="text" name="first_name" placeholder="Leo" autocomplete="given-name">
          </div>
          <div class="ew-field">
            <label>Last name<span class="req">*</span></label>
            <input type="text" name="last_name" placeholder="Gibson" autocomplete="family-name">
          </div>
          <div class="ew-field">
            <label>Gender<span class="req">*</span></label>
            <div class="ew-select-wrap">
              <select name="gender">
                <option value="">Select gender</option>
                <option>Male</option>
                <option>Female</option>
                <option>Non-binary</option>
                <option>Prefer not to say</option>
              </select>
              <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </div>
        </div>
        <div class="ew-field">
          <label>Date of birth<span class="req">*</span></label>
          <div class="ew-dob">
            <input type="text" name="dob_month" placeholder="Month" maxlength="2">
            <input type="text" name="dob_day"   placeholder="Day"   maxlength="2">
            <input type="text" name="dob_year"  placeholder="Year"  maxlength="4">
          </div>
        </div>
        <p class="ew-hint">(This information is only used to verify your legal availability to work)</p>
        <div class="ew-grid-2">
          <div class="ew-field">
            <label>Email<span class="req">*</span></label>
            <input type="email" name="email" placeholder="injector@enhance.work" autocomplete="email">
          </div>
          <div class="ew-field">
            <label>Phone number<span class="req">*</span></label>
            <div class="ew-phone-wrap">
              <div class="ew-select-wrap ew-country-select-wrap">
                <select name="phone_country_code" id="ew-phone-country" class="ew-country-select" aria-label="Country code">
                  <option value="+1" data-flag="🇺🇸" selected>🇺🇸 +1</option>
                  <option value="+52" data-flag="🇲🇽">🇲🇽 +52</option>
                  <option value="+57" data-flag="🇨🇴">🇨🇴 +57</option>
                  <option value="+54" data-flag="🇦🇷">🇦🇷 +54</option>
                  <option value="+58" data-flag="🇻🇪">🇻🇪 +58</option>
                  <option value="+51" data-flag="🇵🇪">🇵🇪 +51</option>
                  <option value="+56" data-flag="🇨🇱">🇨🇱 +56</option>
                  <option value="+593" data-flag="🇪🇨">🇪🇨 +593</option>
                  <option value="+502" data-flag="🇬🇹">🇬🇹 +502</option>
                  <option value="+503" data-flag="🇸🇻">🇸🇻 +503</option>
                  <option value="+504" data-flag="🇭🇳">🇭🇳 +504</option>
                  <option value="+505" data-flag="🇳🇮">🇳🇮 +505</option>
                  <option value="+506" data-flag="🇨🇷">🇨🇷 +506</option>
                  <option value="+507" data-flag="🇵🇦">🇵🇦 +507</option>
                  <option value="+53" data-flag="🇨🇺">🇨🇺 +53</option>
                  <option value="+1-787" data-flag="🇵🇷">🇵🇷 +1</option>
                  <option value="+1-809" data-flag="🇩🇴">🇩🇴 +1</option>
                  <option value="+34" data-flag="🇪🇸">🇪🇸 +34</option>
                  <option value="+44" data-flag="🇬🇧">🇬🇧 +44</option>
                  <option value="+33" data-flag="🇫🇷">🇫🇷 +33</option>
                  <option value="+49" data-flag="🇩🇪">🇩🇪 +49</option>
                  <option value="+39" data-flag="🇮🇹">🇮🇹 +39</option>
                  <option value="+55" data-flag="🇧🇷">🇧🇷 +55</option>
                  <option value="+1-CA" data-flag="🇨🇦">🇨🇦 +1</option>
                </select>
                <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              </div>
              <input type="tel" name="phone" placeholder="(305) 123-4567" autocomplete="tel" class="ew-phone-input">
            </div>
          </div>
        </div>
        </div><!-- /.ew-step-content -->
      </div>

      <!-- ── STEP 3 ── -->
      <div class="ew-step" data-step="3" hidden>
        <h2 class="ew-title">Where are you located?</h2>
        <p class="ew-subtitle">Your address details</p>
        <hr class="ew-divider">
        <div class="ew-step-content">
        <div class="ew-field">
          <label>Address<span class="req">*</span></label>
          <input type="text" name="address1" placeholder="Line 1" autocomplete="address-line1">
        </div>
        <div class="ew-field">
          <input type="text" name="address2" placeholder="Line 2 (optional)" autocomplete="address-line2">
        </div>
        <div class="ew-grid-2">
          <div class="ew-field">
            <label>State<span class="req">*</span></label>
            <div class="ew-select-wrap">
              <select name="state">
                <option value="" selected>Florida</option>
                <option>Alabama</option><option>Alaska</option><option>Arizona</option>
                <option>Arkansas</option><option>California</option><option>Colorado</option>
                <option>Connecticut</option><option>Delaware</option><option>Florida</option>
                <option>Georgia</option><option>Hawaii</option><option>Idaho</option>
                <option>Illinois</option><option>Indiana</option><option>Iowa</option>
                <option>Kansas</option><option>Kentucky</option><option>Louisiana</option>
                <option>Maine</option><option>Maryland</option><option>Massachusetts</option>
                <option>Michigan</option><option>Minnesota</option><option>Mississippi</option>
                <option>Missouri</option><option>Montana</option><option>Nebraska</option>
                <option>Nevada</option><option>New Hampshire</option><option>New Jersey</option>
                <option>New Mexico</option><option>New York</option><option>North Carolina</option>
                <option>North Dakota</option><option>Ohio</option><option>Oklahoma</option>
                <option>Oregon</option><option>Pennsylvania</option><option>Rhode Island</option>
                <option>South Carolina</option><option>South Dakota</option><option>Tennessee</option>
                <option>Texas</option><option>Utah</option><option>Vermont</option>
                <option>Virginia</option><option>Washington</option><option>West Virginia</option>
                <option>Wisconsin</option><option>Wyoming</option>
              </select>
              <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </div>
          <div class="ew-field">
            <label>City<span class="req">*</span></label>
            <input type="text" name="city" placeholder="City" autocomplete="address-level2">
          </div>
        </div>
        <div class="ew-field" style="max-width:340px">
          <label>Zip code<span class="req">*</span></label>
          <input type="text" name="zip" id="ew-zip" placeholder="e.g. 33101" maxlength="10" autocomplete="postal-code">
          <p class="ew-zip-status" id="ew-zip-status" hidden></p>
        </div>
        </div><!-- /.ew-step-content -->
      </div>

      <!-- ── STEP 4 ── -->
      <div class="ew-step" data-step="4" hidden>
        <h2 class="ew-title">Competences</h2>
        <p class="ew-subtitle">Languages and licenses you hold</p>
        <hr class="ew-divider">
        <div class="ew-step-content">
        <div class="ew-field">
          <label>Languages</label>
        </div>
        <div class="ew-grid-2">
          <div class="ew-select-wrap">
            <select name="language">
              <option value="">Select</option>
              <option>English</option><option>Spanish</option><option>French</option>
              <option>Portuguese</option><option>Mandarin</option><option>Other</option>
            </select>
            <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </div>
          <div class="ew-select-wrap">
            <select name="language_level">
              <option value="">Level</option>
              <option>Basic</option><option>Conversational</option>
              <option>Fluent</option><option>Native</option>
            </select>
            <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </div>
        </div>
        <button type="button" class="ew-link-btn" id="ew-add-lang">
          <span style="font-size:1.1rem;line-height:1">+</span> Add another language
        </button>
        <div id="ew-extra-lang" hidden style="margin:0.5rem 0 0.75rem">
          <div class="ew-grid-2">
            <div class="ew-select-wrap">
              <select name="language_other">
                <option value="">Select</option>
                <option>English</option><option>Spanish</option><option>French</option>
                <option>Portuguese</option><option>Mandarin</option><option>Other</option>
              </select>
              <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
            <div class="ew-select-wrap">
              <select name="language_other_level">
                <option value="">Level</option>
                <option>Basic</option><option>Conversational</option>
                <option>Fluent</option><option>Native</option>
              </select>
              <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </div>
        </div>

        <div class="ew-licenses-header">
          <label class="ew-field-label">Licenses you hold</label>
          <button type="button" class="ew-clear-btn" id="ew-clear-licenses">Clear All</button>
        </div>
        <div class="ew-license-grid">
          <label class="ew-license-chip"><input type="checkbox" name="license" value="md_do"><span class="ew-radio-dot"></span>M.D. / D.O.</label>
          <label class="ew-license-chip"><input type="checkbox" name="license" value="np"><span class="ew-radio-dot"></span>N.P.</label>
          <label class="ew-license-chip"><input type="checkbox" name="license" value="pa"><span class="ew-radio-dot"></span>P.A.</label>
          <label class="ew-license-chip"><input type="checkbox" name="license" value="cosmetologist"><span class="ew-radio-dot"></span>Cosmetologist</label>
          <label class="ew-license-chip"><input type="checkbox" name="license" value="electrologist"><span class="ew-radio-dot"></span>Electrologist</label>
          <label class="ew-license-chip"><input type="checkbox" name="license" value="phlebotomist"><span class="ew-radio-dot"></span>Phlebotomist</label>
          <label class="ew-license-chip"><input type="checkbox" name="license" value="medical_assistant"><span class="ew-radio-dot"></span>Medical Assistant</label>
          <button type="button" class="ew-license-chip ew-license-add" id="ew-add-license-btn">
            <span class="ew-license-add__icon">+</span> Add licenses
          </button>
        </div>
        <div id="ew-license-extra" hidden>
          <div id="ew-license-chips" class="ew-license-chips-row"></div>
          <div class="ew-skill-input-row" style="max-width:340px">
            <input type="text" name="license_other" id="ew-license-input" placeholder="Enter license or certification" style="font-size:0.78rem">
            <button type="button" class="ew-skill-confirm" id="ew-license-confirm" title="Confirm" aria-label="Confirm license">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8l4 4 6-7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
        </div><!-- /.ew-step-content -->
      </div>

      <!-- ── STEP 5 ── -->
      <div class="ew-step" data-step="5" hidden>
        <h2 class="ew-title">What is your Medical Aesthetics experience?</h2>
        <p class="ew-subtitle">Tell us about your background</p>
        <hr class="ew-divider">
        <div class="ew-step-content">

        <div class="ew-field" style="max-width:280px;margin-bottom:1.25rem">
          <label style="white-space: nowrap;">Years of experience in aesthetics<span class="req">*</span></label>
          <input type="number" name="years_experience" placeholder="Years" min="0" max="60" inputmode="numeric">
        </div>

        <div class="ew-field">
          <label>If you see fit, list some of your skills relevant to Aesthetics</label>
          <div class="ew-skills-row" id="ew-skills-row">
            <div id="ew-skill-chips"></div>
            <div class="ew-skill-input-row">
              <input type="text" id="ew-skill-input" placeholder="Type a skill…" autocomplete="off">
              <button type="button" class="ew-skill-confirm" id="ew-skill-add" title="Add skill" aria-label="Add skill">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8l4 4 6-7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </div>
          </div>
        </div>

        <div class="ew-field">
          <label>When are you looking to start working?<span class="req">*</span></label>
          <div class="ew-start-opts">
            <label class="ew-start-opt"><input type="radio" name="start_date" value="asap"><span class="ew-radio-dot"></span>ASAP</label>
            <label class="ew-start-opt"><input type="radio" name="start_date" value="2_4_weeks"><span class="ew-radio-dot"></span>2 - 4 Weeks</label>
            <label class="ew-start-opt"><input type="radio" name="start_date" value="over_4"><span class="ew-radio-dot"></span>Over 4 Weeks</label>
          </div>
        </div>

        <div class="ew-field">
          <label>Are you currently employed?</label>
          <div class="ew-radio-row">
            <label class="ew-radio-opt"><input type="radio" name="employed" value="yes"><span class="ew-radio-circle" data-active></span>Yes</label>
            <label class="ew-radio-opt"><input type="radio" name="employed" value="no"><span class="ew-radio-circle"></span>No</label>
          </div>
        </div>
        </div><!-- /.ew-step-content -->
      </div>

      <!-- ── STEP 6 ── -->
      <div class="ew-step" data-step="6" hidden>
        <h2 class="ew-title">What are your compensation expectations?</h2>
        <p class="ew-subtitle">Final step almost there</p>
        <hr class="ew-divider">
        <div class="ew-step-content">

        <div class="ew-field">
          <label>Salary expectations<span class="req">*</span></label>
          <div class="ew-salary-row">
            <input type="number" name="salary" placeholder="0" min="0" inputmode="numeric" class="ew-salary-input">
            <div class="ew-select-wrap ew-salary-type-wrap">
              <select name="pay_type">
                <option>Hourly</option>
                <option>Monthly</option>
                <option>Yearly</option>
              </select>
              <span class="ew-chevron"><svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </div>
        </div>

        <!-- Important message box -->
        <div class="ew-msg-box">
          <div class="ew-msg-box__row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="#2bbcb0" stroke-width="1.5"/><path d="M12 8v4M12 16h.01" stroke="#2bbcb0" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="ew-msg-box__title">Important message to New Injectors</span>
            <button type="button" class="ew-clear-btn" id="ew-toggle-msg">Click to read</button>
          </div>
          <div id="ew-msg-content" hidden style="padding:0.6rem 0 0 1.5rem;font-size:0.82rem;color:#666;line-height:1.5">
            Before joining the platform, new injectors must provide proof of supervision or collaborative agreement with a licensed Medical Director. Make sure to upload your documentation or note it in your resume.
          </div>
        </div>

        <!-- Checkboxes -->
        <div class="ew-checkbox-row">
          <label class="ew-checkbox-opt">
            <span class="ew-checkbox-box"><input type="checkbox" name="injector_msg"></span>
            I've read New Injector's message.
          </label>
          <label class="ew-checkbox-opt">
            <span class="ew-checkbox-box"><input type="checkbox" name="terms"></span>
            Agree terms and conditions.
          </label>
        </div>

        <!-- Attach resume -->
        <div style="text-align:center;margin-bottom:1rem">
          <input type="file" name="resume" id="ew-resume-file" accept=".pdf,.doc,.docx" hidden>
          <label for="ew-resume-file" class="ew-resume-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v10M7 10l5-5 5 5" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 19h14" stroke="#555" stroke-width="2" stroke-linecap="round"/></svg>
            <span id="ew-resume-label">Attatch Resume</span>
          </label>
        </div>

        <p class="ew-recaptcha">This site is protected by reCAPTCHA and the Google <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacy Policy</a> and <a href="https://policies.google.com/terms" target="_blank" rel="noopener">Terms of Service</a> apply.</p>
        </div><!-- /.ew-step-content -->
      </div>

    </div><!-- /.ew-form__body -->

    <!-- Footer buttons -->
    <div class="ew-form__footer">
      <button type="button" class="ew-btn ew-btn--cancel" id="ew-cancel">Cancel</button>
      <button type="button" class="ew-btn ew-btn--continue" id="ew-next">Continue</button>
      <div class="ew-footer-error" id="ew-footer-error" hidden></div>
    </div>

  </div><!-- /.ew-form__card -->

  <!-- ── Confirmation modal (overlay inside fullscreen) ── -->
  <div id="ew-confirm-modal" class="ew-confirm" hidden aria-modal="true" role="dialog" aria-label="Confirm submission">
    <div class="ew-confirm__box">
      <div class="ew-confirm__icon">
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
          <circle cx="22" cy="22" r="22" fill="#e4f7f6"/>
          <path d="M14 22l6 6 10-12" stroke="#2bbcb0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="ew-confirm__title">Ready to submit?</h3>
      <p class="ew-confirm__sub">Please review your information before submitting. Once sent, our team will review your application and reach out to you.</p>
      <div class="ew-confirm__actions">
