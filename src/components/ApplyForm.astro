  gap: 0.35rem;
  border: 1.5px solid #ddd;
  border-radius: 8px;
  padding: 0.4rem 0.4rem 0.4rem 0.75rem;
  background: #fff;
  transition: border-color 0.15s;
  width: 100%;
  max-width: 340px;
  box-sizing: border-box;
}
.ew-skill-input-row:focus-within { border-color: #2bbcb0; }
.ew-skill-input-row input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  padding: 0;
  font-size: 0.875rem;
  font-family: var(--font-body);
  color: #333;
  min-width: 0;
  line-height: 1.4;
}
.ew-skill-confirm {
  flex-shrink: 0;
  width: 20px; height: 20px;
  border-radius: 4px;
  background: #2bbcb0;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
  padding: 0;
}
.ew-skill-confirm:hover { background: #27a89e; }
.ew-license-chips-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 0.5rem;
}
.ew-license-chips-row:empty { display: none; }

/* ── Mobile ── */
@media (max-width: 700px) {
  /* ── Container & card ── */
  .ew-form {
    padding: 0;
    justify-content: flex-start;
    align-items: stretch;
    overflow-x: hidden;
  }

  /* Logo + back arrow row outside card */
  .ew-form__logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 1rem 1.25rem 0.75rem;
    margin-bottom: 0;
  }
  .ew-form__logo-img {
    height: 26px;
  }

  /* Card: fills available height so footer stays at bottom */
  .ew-form__card {
    border-radius: 16px;
    height: calc(100dvh - 6rem); /* full viewport minus logo bar */
    min-height: 0;
    margin: 0 0.75rem 0.75rem;
    width: calc(100% - 1.5rem);
    max-width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  /* Body scrolls, footer stays pinned at bottom of card */
  .ew-form__body {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1.25rem 0.75rem;
    min-height: 0;
  }
  .ew-form__footer {
    flex-shrink: 0;
    padding: 0.75rem 1.25rem 1rem;
    border-top: 1px solid #f2f2f2;
  }

  /* Inner padding */
  .ew-form__progress-row { padding: 1rem 1.25rem 0; }

  /* Step: fills body, content scrolls */
  .ew-step { flex: 1; min-height: 0; }
  .ew-step-content { justify-content: flex-start; gap: 1rem; }

  /* Typography */
  .ew-title { font-size: 1.2rem; text-align: left; }
  .ew-subtitle { text-align: left; }

  /* Grids → single column */
  .ew-grid-2,
  .ew-grid-3 { grid-template-columns: 1fr; gap: 0.75rem; }
  .ew-grid-salary { grid-template-columns: 1fr auto; gap: 0.5rem; }

  /* DOB row stays 3 cols but smaller — prevent overflow */
  .ew-dob { width: 100%; max-width: 100%; overflow: hidden; }
  .ew-dob input[name="dob_month"],
  .ew-dob input[name="dob_day"],
  .ew-dob input[name="dob_year"] { flex: 1; width: auto; min-width: 0; }

  /* Prevent any field from causing horizontal scroll */
  .ew-step-content, .ew-step-content * { max-width: 100%; box-sizing: border-box; }
  /* Exception: country select must keep min-width */
  .ew-country-select { min-width: 95px !important; max-width: 120px !important; }
  .ew-phone-wrap { width: 100%; }
  .ew-phone-input { flex: 1 1 auto; min-width: 80px; }
  /* Prevent iOS zoom */
  .ew-field input,
  .ew-field select,
  .ew-form__card input[type="text"],
  .ew-form__card input[type="email"],
  .ew-form__card input[type="tel"],
  .ew-form__card select,
  .ew-country-select { font-size: 16px !important; }
  .ew-skill-input-row { max-width: 100%; }
  .ew-form__footer { padding: 0.75rem 1.25rem 1.25rem; flex-wrap: wrap; }
  .ew-footer-error { font-size: 0.75rem; }

  /* Role grid: 2 columns, remove desktop padding */
  .ew-role-grid,
  .ew-role-grid--main {
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: auto;
    gap: 0.6rem;
    flex: none;
    padding: 0 !important;
  }
  .ew-field-label--grid { padding: 0 0 0.4rem !important; }
  .ew-role-card__img { flex: 1; min-height: 60px; }

  /* License grid: 2 cols */
  .ew-license-grid { grid-template-columns: 1fr 1fr; }

  /* Start date: ASAP + 2-4W side by side, Over 4W full width below */
  .ew-start-opts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .ew-start-opts .ew-start-opt:last-child {
    grid-column: 1 / -1;   /* Over 4 Weeks spans full width */
  }

  /* Checkboxes: vertical */
  .ew-checkbox-row { flex-direction: column; gap: 0.75rem; align-items: center; }

  /* Footer buttons: centered side-by-side */
  .ew-form__footer {
    justify-content: center;
    border-top: 1px solid #f2f2f2;
  }
  .ew-btn {
    flex: 1;
    max-width: 160px;
    text-align: center;
    justify-content: center;
  }

  /* Message box toggle: use chevron style */
  .ew-msg-box { cursor: pointer; }
}
</style>

<script>
(function() {

  // ── Date field validation ──────────────────────────────────────────────────
  function daysInMonth(month, year) {
    const m = parseInt(month, 10);
    const y = parseInt(year, 10) || new Date().getFullYear();
    if (!m || m < 1 || m > 12) return 31;
    return new Date(y, m, 0).getDate(); // last day of that month
  }

  const dobMonth = document.querySelector('[name="dob_month"]');
  const dobDay   = document.querySelector('[name="dob_day"]');
  const dobYear  = document.querySelector('[name="dob_year"]');

  function clamp(input, min, max) {
    const val = parseInt(input.value, 10);
    if (!isNaN(val) && val > max) input.value = max;
    if (!isNaN(val) && val < 1 && input.value.length >= 2) input.value = min;
  }

  dobMonth?.addEventListener('input', () => {
    dobMonth.value = dobMonth.value.replace(/\D/g, '');
    clamp(dobMonth, 1, 12);
    // re-clamp day if month changed
    if (dobDay?.value) clamp(dobDay, 1, daysInMonth(dobMonth.value, dobYear?.value));
  });

  dobDay?.addEventListener('input', () => {
    dobDay.value = dobDay.value.replace(/\D/g, '');
    const maxDays = daysInMonth(dobMonth?.value, dobYear?.value);
    clamp(dobDay, 1, maxDays);
  });

  dobYear?.addEventListener('input', () => {
    dobYear.value = dobYear.value.replace(/\D/g, '');
    const currentYear = new Date().getFullYear();
    if (dobYear.value.length === 4) {
      const y = parseInt(dobYear.value, 10);
      if (y > currentYear) dobYear.value = currentYear;
      if (y < 1900) dobYear.value = 1900;
      // re-clamp day with new year (leap year check)
      if (dobDay?.value) clamp(dobDay, 1, daysInMonth(dobMonth?.value, dobYear.value));
    }
  });
  // ──────────────────────────────────────────────────────────────────────────

  const form    = document.getElementById('apply-modal');
  const formBody = form.querySelector('.ew-form__body');
  const steps   = Array.from(document.querySelectorAll('.ew-step'));
  const segs    = Array.from(document.querySelectorAll('.ew-seg'));
  const nextBtn = document.getElementById('ew-next');
  const backBtn = document.getElementById('ew-back');
  const cancelBtn = document.getElementById('ew-cancel');
  const stepLabel = document.getElementById('ew-step-label');
  const total = 6;
  let current = 1;

  function showStep(n) {
    steps.forEach(s => s.hidden = parseInt(s.dataset.step) !== n);
    segs.forEach((seg, i) => seg.classList.toggle('active', i < n));
    stepLabel.textContent = `STEP ${n} / ${total}`;
    backBtn.hidden = n === 1;
    // Cancel only visible on step 1
    cancelBtn.style.display = n === 1 ? '' : 'none';
    nextBtn.textContent = n === total ? 'Finish' : 'Continue';
    clearError();
    current = n;
    if (formBody) formBody.scrollTop = 0;
  }

  function open() { /* page version — always visible */ }

  function close() {
    // On standalone page, Cancel goes back to home
    window.location.href = '/';
  }

  function showConfirm() {
    const confirmModal = document.getElementById('ew-confirm-modal');
    if (confirmModal) confirmModal.hidden = false;
  }

  function hideConfirm() {
    const confirmModal = document.getElementById('ew-confirm-modal');
    if (confirmModal) confirmModal.hidden = true;
  }

  function showSuccess() {
    hideConfirm();
    const successEl = document.getElementById('ew-success');
    if (successEl) successEl.hidden = false;
  }

  // Confirm modal buttons
  document.getElementById('ew-confirm-cancel')?.addEventListener('click', hideConfirm);
  document.getElementById('ew-success-close')?.addEventListener('click', close);
  document.getElementById('ew-confirm-submit')?.addEventListener('click', async () => {
    hideConfirm();
    _confirmingSubmit = true;
    nextBtn?.click();
  });

  // Standalone page — form is always visible, show step 1
  showStep(1);

  cancelBtn.addEventListener('click', close);

  let _confirmingSubmit = false;

  // ── Validation ──────────────────────────────────────────────────────────────
  function showError(msg) {
    const el = document.getElementById('ew-footer-error');
    if (el) { el.textContent = msg; el.hidden = false; }
  }

  function clearError() {
    const el = document.getElementById('ew-footer-error');
    if (el) { el.textContent = ''; el.hidden = true; }
  }

  function markInvalid(el) {
    el.style.borderColor = '#e05252';
    el.addEventListener('input', () => { el.style.borderColor = ''; }, { once: true });
    el.addEventListener('change', () => { el.style.borderColor = ''; }, { once: true });
  }

  function validateStep(step) {
    const f = form;
    clearError();
    if (step === 1) {
      const selected = f.querySelector('input[name="role"]:checked');
      if (!selected) { showError('Please select a role to continue.'); return false; }
    }
    if (step === 2) {
      const firstName = f.querySelector('[name="first_name"]');
      const lastName  = f.querySelector('[name="last_name"]');
      const email     = f.querySelector('[name="email"]');
      const phone     = f.querySelector('[name="phone"]');
      const missing = [];
      if (!firstName?.value.trim()) { markInvalid(firstName); missing.push('First name'); }
      if (!lastName?.value.trim())  { markInvalid(lastName);  missing.push('Last name'); }
      if (!email?.value.trim())     { markInvalid(email);     missing.push('Email'); }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) { markInvalid(email); missing.push('Valid email'); }
      if (!phone?.value.trim())     { markInvalid(phone);     missing.push('Phone'); }
      if (missing.length) { showError(`Required: ${missing.join(', ')}.`); return false; }
    }
    if (step === 3) {
      const addr1 = f.querySelector('[name="address1"]');
      const state = f.querySelector('[name="state"]');
      const city  = f.querySelector('[name="city"]');
      const zip   = f.querySelector('[name="zip"]');
      const missing = [];
      if (!addr1?.value.trim()) { markInvalid(addr1); missing.push('Address'); }
      if (!state?.value.trim()) { markInvalid(state); missing.push('State'); }
      if (!city?.value.trim())  { markInvalid(city);  missing.push('City'); }
      if (!zip?.value.trim())   { markInvalid(zip);   missing.push('Zip code'); }
      if (missing.length) { showError(`Required: ${missing.join(', ')}.`); return false; }
    }
    if (step === 5) {
      const yrs = f.querySelector('[name="years_experience"]');
      const start = f.querySelector('input[name="start_date"]:checked');
      const missing = [];
      if (!yrs?.value.trim())  { markInvalid(yrs); missing.push('Years of experience'); }
      if (!start)              { missing.push('Availability / start date'); }
      if (missing.length) { showError(`Required: ${missing.join(', ')}.`); return false; }
    }
    if (step === 6) {
      const terms = f.querySelector('input[name="terms"]');
      if (!terms?.checked) {
        showError('Please agree to the terms and conditions to submit.');
        return false;
      }
    }
    return true;
  }
  // ──────────────────────────────────────────────────────────────────────────

  nextBtn.addEventListener('click', async () => {
    if (!validateStep(current)) return;
    if (current < total) {
      showStep(current + 1);
      return;
    }
    // On last step: first show confirm modal, then submit on confirm
    if (!_confirmingSubmit) {
      showConfirm();
      return;
    }
    _confirmingSubmit = false;
    nextBtn.disabled = true;
    nextBtn.textContent = 'Sending...';
    try {
        const formData = new FormData();

        const role = form.querySelector('input[name="role"]:checked');
        formData.append('role', role ? role.value : '');

        // Combine country code + phone number before sending
        const phoneCountryEl = form.querySelector('[name="phone_country_code"]');
        const phoneEl = form.querySelector('[name="phone"]');
        const phoneCountry = phoneCountryEl ? phoneCountryEl.value : '+1';
        const phoneNumber = phoneEl ? phoneEl.value.trim() : '';
        const fullPhone = phoneNumber ? `${phoneCountry}${phoneNumber.replace(/^\+/, '')}` : '';
        formData.append('phone', fullPhone);

        ['first_name','last_name','gender','dob_month','dob_day','dob_year',
         'email','address1','address2','state','city','zip',
         'language','language_level','language_other','language_other_level','license_other',
         'years_experience','salary','pay_type'].forEach(name => {
          const el = form.querySelector(`[name="${name}"]`);
          if (el) formData.append(name, el.value);
        });

        form.querySelectorAll('input[name="license"]:checked').forEach(cb => {
          formData.append('licenses', cb.value);
        });

        const skillChipEls = form.querySelectorAll('.ew-skill-tag span');
        skillChipEls.forEach(s => formData.append('skills', s.textContent));

        const startDate = form.querySelector('input[name="start_date"]:checked');
        formData.append('start_date', startDate ? startDate.value : '');

        const employed = form.querySelector('input[name="employed"]:checked');
        formData.append('employed', employed ? employed.value : '');

        const injectorMsg = form.querySelector('input[name="injector_msg"]');
        formData.append('injector_msg_read', injectorMsg ? injectorMsg.checked : false);

        const terms = form.querySelector('input[name="terms"]');
        formData.append('terms_agreed', terms ? terms.checked : false);

        const resumeInput = form.querySelector('input[name="resume"]');
        if (resumeInput && resumeInput.files[0]) {
          formData.append('resume', resumeInput.files[0]);
        }

        const resp = await fetch('/api/apply', { method: 'POST', body: formData });
        const result = await resp.json();

        if (result.success) {
          showSuccess();
        } else {
          alert('There was an error submitting your application. Please try again.');
          nextBtn.disabled = false;
          nextBtn.textContent = 'Finish';
        }
      } catch (err) {
        console.error('Submit error:', err);
        alert('There was an error submitting your application. Please try again.');
      } finally {
        nextBtn.disabled = false;
        nextBtn.textContent = 'Finish';
      }
  });

  backBtn.addEventListener('click', () => {
    if (current > 1) showStep(current - 1);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !form.hidden) close();
  });

  // Skills — badge input
  const skillInput = document.getElementById('ew-skill-input');
  const skillChips = document.getElementById('ew-skill-chips');
  const skillsRow = document.getElementById('ew-skills-row');
  const addBtn = document.getElementById('ew-skill-add');
  function addSkill() {
    if (!skillInput || !skillInput.value.trim()) return;
    const val = skillInput.value.trim();
    const chip = document.createElement('div');
    chip.className = 'ew-skill-tag';
    chip.innerHTML = `<span>${val}</span><button type="button" aria-label="Remove">×</button>`;
    chip.querySelector('button').addEventListener('click', () => chip.remove());
    skillChips.appendChild(chip);
    skillInput.value = '';
    skillInput.focus();
  }
  if (skillInput) {
    skillInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') { e.preventDefault(); addSkill(); }
    });
    document.getElementById('ew-skill-add')?.addEventListener('click', e => {
      e.preventDefault();
      addSkill();
    });
    document.getElementById('ew-skills-row')?.addEventListener('click', () => skillInput.focus());
  }

  // License confirm button (green check) — adds chip
  function addLicenseChip() {
    const inp = document.getElementById('ew-license-input');
    const chipsRow = document.getElementById('ew-license-chips');
    if (!inp || !chipsRow) return;
    const val = inp.value.trim();
    if (!val) return;
    const chip = document.createElement('div');
    chip.className = 'ew-skill-tag';
    chip.innerHTML = `<span>${val}</span><button type="button" aria-label="Remove">×</button>`;
    chip.querySelector('button').addEventListener('click', () => chip.remove());
    chipsRow.appendChild(chip);
    inp.value = '';
    inp.focus();
  }
  document.getElementById('ew-license-confirm')?.addEventListener('click', addLicenseChip);
  document.getElementById('ew-license-input')?.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); addLicenseChip(); }
  });

  // Clear licenses
  document.getElementById('ew-clear-licenses')?.addEventListener('click', () => {
    document.querySelectorAll('input[name="license"]').forEach(cb => cb.checked = false);
  });

  // Add license toggle
  document.getElementById('ew-add-license-btn')?.addEventListener('click', () => {
    const extra = document.getElementById('ew-license-extra');
    if (extra) { extra.hidden = !extra.hidden; if (!extra.hidden) extra.querySelector('input').focus(); }
  });

  // Add language toggle
  document.getElementById('ew-add-lang')?.addEventListener('click', () => {
    const extra = document.getElementById('ew-extra-lang');
    if (extra) { extra.hidden = !extra.hidden; if (!extra.hidden) extra.querySelector('input').focus(); }
  });

  // Toggle injector message
  document.getElementById('ew-toggle-msg')?.addEventListener('click', function() {
    const c = document.getElementById('ew-msg-content');
    if (c) { c.hidden = !c.hidden; this.textContent = c.hidden ? 'Click to read' : 'Hide'; }
  });

  // Resume label
  const resumeFile = document.getElementById('ew-resume-file');
  const resumeLabel = document.getElementById('ew-resume-label');
  resumeFile?.addEventListener('change', () => {
    if (resumeLabel) resumeLabel.textContent = resumeFile.files[0]?.name || 'Attatch Resume';
  });

  // Zip code → auto-fill city & state via zippopotam.us
  const zipInput = document.getElementById('ew-zip');
  const zipStatus = document.getElementById('ew-zip-status');
  const stateSelect = form.querySelector('select[name="state"]');
  const cityInput = form.querySelector('input[name="city"]');
  let zipTimeout = null;

  if (zipInput) {
    zipInput.addEventListener('input', () => {
      const val = zipInput.value.replace(/\D/g, '');
      if (zipTimeout) clearTimeout(zipTimeout);
      if (val.length === 5) {
        zipStatus.textContent = 'Looking up...';
        zipStatus.hidden = false;
        zipStatus.style.color = '#888';
        zipTimeout = setTimeout(() => {
          fetch(`/api/zip/${val}`)
            .then(r => {
              if (!r.ok) throw new Error('not found');
              return r.json();
            })
            .then(data => {
              const place = data.places?.[0];
              if (place) {
                if (cityInput) cityInput.value = place['place name'];
                if (stateSelect) {
                  const stateName = place['state'];
                  for (const opt of stateSelect.options) {
                    if (opt.textContent === stateName || opt.value === stateName) {
                      stateSelect.value = opt.value || opt.textContent;
                      break;
                    }
                  }
                }
                zipStatus.textContent = `${place['place name']}, ${place['state abbreviation']}`;
                zipStatus.style.color = '#2bbcb0';
              }
            })
            .catch(() => {
              zipStatus.textContent = 'Zip code not found';
              zipStatus.style.color = '#e05555';
            });
        }, 300);
      } else {
        zipStatus.hidden = true;
      }
    });
  }

  // iOS keyboard gap fix:
  // When keyboard closes, iOS doesn't restore window scroll → leaves dead space below.
  // Fix: track window scroll before keyboard opens, restore it after.
  const formBody = document.querySelector('.ew-form__body');
  let savedScrollY = 0;

  document.querySelectorAll('.ew-form input, .ew-form select, .ew-form textarea').forEach(el => {
    el.addEventListener('focus', () => {
      savedScrollY = window.scrollY;
    });
    el.addEventListener('blur', () => {
      setTimeout(() => {
        window.scrollTo({ top: savedScrollY, behavior: 'instant' });
      }, 150);
    });
  });

  // Also catch keyboard dismiss via visualViewport resize (most reliable on iOS)
  if (window.visualViewport) {
    let prevHeight = window.visualViewport.height;
    window.visualViewport.addEventListener('resize', () => {
      const newHeight = window.visualViewport.height;
      // Keyboard closed: viewport grew back
      if (newHeight > prevHeight + 100) {
        setTimeout(() => {
          window.scrollTo({ top: savedScrollY, behavior: 'instant' });
        }, 100);
      }
      prevHeight = newHeight;
    });
  }
})();
</script>
