---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'enhance.work — Your Aesthetic Career in South Florida',
  description = 'The hiring platform built for aesthetic professionals. Connect with 1.2k+ active professionals and 318+ partner clinics in South Florida.',
} = Astro.props;
---

