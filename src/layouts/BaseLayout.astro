---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: string;
  publishedTime?: string;
  author?: string;
}

const {
  title = 'Aesthetic Medicine Jobs in South Florida | Enhance.work',
  description = 'Nurse injector, esthetician, laser tech, and medical assistant roles at med spas across Miami-Dade, Broward, and Palm Beach. Free to register. Practices contact you.',
  ogImage = 'https://enhance.work/images/hero-photo.png',
  canonicalUrl,
  ogType = 'website',
  publishedTime,
  author,
} = Astro.props;

const siteUrl = 'https://enhance.work';
const canonical = canonicalUrl || (siteUrl + Astro.url.pathname);
const fullOgImage = ogImage.startsWith('http') ? ogImage : siteUrl + ogImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Enhance.work" />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-ND2BNFV5');</script>
    <!-- End Google Tag Manager -->

    <!-- Meta CAPI + Pixel with Deduplication -->
    <script is:inline>
    (function() {
      var PIXEL_ID = '322421330936674';

      function genEventId() {
        return 'ev_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
      }

      function sendCAPIviaServer(eventName, eventId, userData) {
        var cookies = document.cookie.split(';').reduce(function(acc, c) {
          var p = c.trim().split('='); acc[p[0]] = p[1]; return acc;
        }, {});

        var payload = {
          event_name: eventName,
          event_id: eventId,
          event_source_url: window.location.href,
          user_data: Object.assign({}, userData || {})
        };
        if (cookies['_fbp']) payload.user_data.fbp = cookies['_fbp'];
        if (cookies['_fbc']) payload.user_data.fbc = cookies['_fbc'];

        fetch('/api/meta-capi', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(d) { console.log('[MetaCAPI Server]', eventName, d); })
        .catch(function(e) { console.warn('[MetaCAPI] Error:', e); });
      }

      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}
      (window,document,'script','https://connect.facebook.net/en_US/fbevents.js');

      fbq('init', PIXEL_ID);

      if (!window._fbPageViewFired) {
        window._fbPageViewFired = true;
        var pvId = genEventId();
        console.log('[MetaPixel Browser] PageView eventID:', pvId);
        fbq('track', 'PageView', {}, { eventID: pvId });
        sendCAPIviaServer('PageView', pvId, {});
      }

      window.fbTrackCompleteRegistration = function(userData) {
        var evId = genEventId();
        fbq('track', 'CompleteRegistration', { status: true }, { eventID: evId });
        sendCAPIviaServer('CompleteRegistration', evId, userData || {});
      };

      // Generic tracker usable from any page
      window.fbTrack = function(eventName, customData, userData) {
        var evId = genEventId();
        fbq('track', eventName, customData || {}, { eventID: evId });
        var payload = Object.assign({ custom_data: customData || {} }, { event_name: eventName, event_id: evId, event_source_url: window.location.href, user_data: userData || {} });
        var cookies = document.cookie.split(';').reduce(function(acc, c) { var p = c.trim().split('='); acc[p[0]] = p[1]; return acc; }, {});
        if (cookies['_fbp']) payload.user_data.fbp = cookies['_fbp'];
        if (cookies['_fbc']) payload.user_data.fbc = cookies['_fbc'];
        fetch('/api/meta-capi', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
          .then(function(r) { return r.json(); })
          .then(function(d) { console.log('[MetaPixel Browser]', eventName, 'eventID:', evId); })
          .catch(function(e) { console.warn('[MetaCAPI] Error:', e); });
        return evId;
      };
    })();
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=322421330936674&ev=PageView&noscript=1" /></noscript>
    <!-- End Meta CAPI + Pixel -->

    <!-- Microsoft Clarity -->
    <script is:inline>
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window,document,"clarity","script","svywuv9yv3");
    </script>
    <!-- End Microsoft Clarity -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-ND2BNFV5" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />

    <!-- UTM capture — runs on every page so params survive navigation to the form -->
    <script is:inline>
    (function() {
      // Captura TODOS los parámetros que empiecen con utm_, fb, gclid, gbraid, wbraid, gad, o cualquier parámetro de tracking
      var params = new URLSearchParams(window.location.search);
      var stored = {};
      
      // Capturar todos los parámetros de la URL
      params.forEach(function(value, key) {
        // Capturar parámetros UTM y de tracking conocidos
        if (
          key.startsWith('utm_') ||           // Todos los UTMs
          key.startsWith('fb') ||              // Facebook/Meta
          key.startsWith('gclid') ||           // Google Click ID
          key.startsWith('gbraid') ||          // Google Brand ID
          key.startsWith('wbraid') ||          // Google Web Brand ID
          key.startsWith('gad') ||             // Google Ads
          key.startsWith('msclkid') ||         // Microsoft/Bing Ads
          key.startsWith('ttclid') ||          // TikTok
          key.startsWith('li_') ||             // LinkedIn
          key.startsWith('twclid') ||          // Twitter/X
          key.startsWith('pin_') ||            // Pinterest
          key.startsWith('sc_') ||             // Snapchat
          key.startsWith('yclid') ||           // Yahoo
          key.startsWith('irclickid') ||       // Impact Radius
          key === 'ref' ||                     // Referral
          key === 'source' ||                  // Source
          key === 'campaign'                   // Campaign
        ) {
          stored[key] = value;
        }
      });
      
      if (Object.keys(stored).length) {
        sessionStorage.setItem('ew_utms', JSON.stringify(stored));
      } else {
        // Referrer fallback — if no UTMs in URL but came from a known partner
        var existing = sessionStorage.getItem('ew_utms');
        if (!existing) {
          var ref = document.referrer || '';
          var refFallback = null;
          if (ref.indexOf('perfectb.com') !== -1) {
            refFallback = { utm_source: 'perfectb', utm_medium: 'referral', utm_campaign: 'careers' };
          }
          // Add more partners here as needed:
          // else if (ref.indexOf('otherpartner.com') !== -1) { ... }
          if (refFallback) {
            sessionStorage.setItem('ew_utms', JSON.stringify(refFallback));
          }
        }
      }
      
      // Agregar UTMs a todos los enlaces de registro
      function addUtmsToLinks() {
        var storedUtms = sessionStorage.getItem('ew_utms');
        if (!storedUtms) return;
        
        try {
          var utms = JSON.parse(storedUtms);
          var utmString = new URLSearchParams(utms).toString();
          
          // Encontrar todos los enlaces que apunten a /candidate/registration/
          var links = document.querySelectorAll('a[href*="/candidate/registration"]');
          links.forEach(function(link) {
            var href = link.getAttribute('href');
            if (href) {
              var separator = href.indexOf('?') > -1 ? '&' : '?';
              // Solo agregar si no tiene UTMs ya
              if (href.indexOf('utm_') === -1 && href.indexOf('gclid') === -1 && href.indexOf('fbclid') === -1) {
                link.setAttribute('href', href + separator + utmString);
              }
            }
          });
          
          // También agregar a botones con clase apply-btn que abren el modal
          var applyButtons = document.querySelectorAll('.apply-btn');
          applyButtons.forEach(function(btn) {
            btn.setAttribute('data-utms', utmString);
          });
        } catch (e) {
          console.warn('Error adding UTMs to links:', e);
        }
      }
      
      // Ejecutar cuando el DOM esté listo
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', addUtmsToLinks);
      } else {
        addUtmsToLinks();
      }
      
      // También ejecutar después de un pequeño delay para capturar enlaces dinámicos
      setTimeout(addUtmsToLinks, 500);
    })();
    </script>
    <!-- End UTM capture -->
  </body>
</html>
